        <register>
          <name>CFR</name>
          <displayName>CFR</displayName>
          <addressOffset>0x84</addressOffset>
          <size>0x20</size>
          <resetValue>0x00000000</resetValue>
          <resetMask>0xFFFFFFFF</resetMask>
          <fields>
            <field>
              <name>CSOF0</name>
              <description>清除同步溢出事件标志。向指定位写入 1 将清除 DMAMUX_CSR 寄存器中对应的溢出标志 SOFx。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
              <access>write-only</access>
            </field>
            <field>
              <name>CSOF1</name>
              <description>清除同步溢出事件标志。向指定位写入 1 将清除 DMAMUX_CSR 寄存器中对应的溢出标志 SOFx。</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
              <access>write-only</access>
            </field>
            <field>
              <name>CSOF2</name>
              <description>清除同步溢出事件标志。向指定位写入 1 将清除 DMAMUX_CSR 寄存器中对应的溢出标志 SOFx。</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
              <access>write-only</access>
            </field>
            <field>
              <name>CSOF3</name>
              <description>清除同步溢出事件标志。向指定位写入 1 将清除 DMAMUX_CSR 寄存器中对应的溢出标志 SOFx。</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
              <access>write-only</access>
            </field>
            <field>
              <name>CSOF4</name>
              <description>清除同步溢出事件标志。向指定位写入 1 将清除 DMAMUX_CSR 寄存器中对应的溢出标志 SOFx。</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
              <access>write-only</access>
            </field>
            <field>
              <name>CSOF5</name>
              <description>清除同步溢出事件标志。向指定位写入 1 将清除 DMAMUX_CSR 寄存器中对应的溢出标志 SOFx。</description>
              <bitOffset>5</bitOffset>
              <bitWidth>1</bitWidth>
              <access>write-only</access>
            </field>
            <field>
              <name>CSOF6</name>
              <description>清除同步溢出事件标志。向指定位写入 1 将清除 DMAMUX_CSR 寄存器中对应的溢出标志 SOFx。</description>
              <bitOffset>6</bitOffset>
              <bitWidth>1</bitWidth>
              <access>write-only</access>
            </field>
            <field>
              <name>CSOF7</name>
              <description>清除同步溢出事件标志。向指定位写入 1 将清除 DMAMUX_CSR 寄存器中对应的溢出标志 SOFx。</description>
