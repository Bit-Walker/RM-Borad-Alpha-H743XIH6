              <description>颜色分量数 此字段定义颜色分量数减 1。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>DE</name>
              <description>解码使能 此位选择编码或解码过程。</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>COLORSPACE</name>
              <description>颜色空间 此字段定义输出流中要插入的量化表数量减 1。</description>
              <bitOffset>4</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>NS</name>
              <description>扫描分量数 此字段定义扫描头标记段的分量数减 1。</description>
              <bitOffset>6</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>HDR</name>
              <description>头处理 此位使能头处理（生成/解析）。</description>
              <bitOffset>8</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>YSIZE</name>
              <description>Y 方向尺寸 此字段定义源图像的行数。</description>
              <bitOffset>16</bitOffset>
              <bitWidth>16</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>CONFR2</name>
          <displayName>CONFR2</displayName>
          <description>JPEG 编解码器配置寄存器 2</description>
          <addressOffset>0x8</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>NMCU</name>
              <description>MCU 数量 编码时：此字段定义要编码的 MCU 单元数减 1。解码时：此字段指示要解码的完整 MCU 单元数减 1（此字段在 JPEG 头解析后更新）。如果解码图像的 X 或 Y 尺寸不是 8 或 16 的倍数（取决于子采样过程），则需将由此产生的不完整或空的 MCU 计入此值，以得到生成的总 MCU 数。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>26</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>CONFR3</name>
          <displayName>CONFR3</displayName>
