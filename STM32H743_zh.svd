            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C14ISR</name>
          <displayName>MDMA_C14ISR</displayName>
          <description>MDMA 通道 x 中断/状态寄存器</description>
          <addressOffset>0x3C0</addressOffset>
          <size>0x20</size>
          <access>read-only</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>TEIF14</name>
              <description>通道 x 传输错误中断标志。此位由硬件置位。软件向 DMA_IFCRy 寄存器的对应位写 1 可将其清零。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CTCIF14</name>
              <description>通道 x 通道传输完成中断标志。此位由硬件置位。软件向 DMA_IFCRy 寄存器的对应位写 1 可将其清零。当最后一个块传输完成且通道已自动禁用时，CTC 置位。当通道因 EN 位写 0 而挂起时，CTC 同样置位。</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>BRTIF14</name>
              <description>通道 x 块重复传输完成中断标志。此位由硬件置位。软件向 DMA_IFCRy 寄存器的对应位写 1 可将其清零。</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>BTIF14</name>
              <description>通道 x 块传输完成中断标志。此位由硬件置位。软件向 DMA_IFCRy 寄存器的对应位写 1 可将其清零。</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>TCIF14</name>
              <description>通道 x 缓冲区传输完成</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CRQA14</name>
              <description>通道 x 请求活跃标志</description>
              <bitOffset>16</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C14IFCR</name>
          <displayName>MDMA_C14IFCR</displayName>
          <description>MDMA 通道 x 中断标志清除寄存器</description>
          <addressOffset>0x3C4</addressOffset>
          <size>0x20</size>
          <access>write-only</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>CTEIF14</name>
              <description>通道 x 清除传输错误中断标志。向此位写 1 可将 MDMA_ISRy 寄存器中的 TEIFx 清零。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CCTCIF14</name>
              <description>通道 x 清除通道传输完成中断标志。向此位写 1 可将 MDMA_ISRy 寄存器中的 CTCIFx 清零。</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CBRTIF14</name>
              <description>通道 x 清除块重复传输完成中断标志。向此位写 1 可将 MDMA_ISRy 寄存器中的 BRTIFx 清零。</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CBTIF14</name>
              <description>通道 x 清除块传输完成中断标志。向此位写 1 可将 MDMA_ISRy 寄存器中的 BTIFx 清零。</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CLTCIF14</name>
              <description>通道 x 清除缓冲区传输完成中断标志。向此位写 1 可将 MDMA_ISRy 寄存器中的 TCIFx 清零。</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C14ESR</name>
          <displayName>MDMA_C14ESR</displayName>
          <description>MDMA 通道 x 错误状态寄存器</description>
          <addressOffset>0x3C8</addressOffset>
          <size>0x20</size>
          <access>read-only</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>TEA</name>
              <description>传输错误地址。在 MDMA 数据传输发生错误时，这些位由硬件置位与清零，与 TED 配合使用。该字段指示引发传输/访问错误的地址的低 7 位。软件可将其（截断至缓冲区传输长度大小）与当前 SAR/DAR 值相加来还原故障地址。注意：由于 FIFO 管理机制，SAR/DAR 当前值并不反映该最后地址。SAR/DAR 仅在（缓冲区）传完 TLEN+1 字节后才更新。注意：发生链接数据错误时此字段不会置位。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>7</bitWidth>
            </field>
            <field>
              <name>TED</name>
              <description>传输错误方向。在 MDMA 数据传输发生错误时，此位由硬件置位与清零。</description>
              <bitOffset>7</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>TELD</name>
              <description>传输错误（链接数据）。当读取块链接数据结构发生传输错误时，此位由硬件置位。软件向 DMA_IFCRy 寄存器中的 CTEIFx 位写 1 可将其清零。</description>
              <bitOffset>8</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>TEMD</name>
              <description>传输错误（掩码数据）。当写入掩码数据发生传输错误时，此位由硬件置位。软件向 DMA_IFCRy 寄存器中的 CTEIFx 位写 1 可将其清零。</description>
              <bitOffset>9</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>ASE</name>
              <description>地址/大小错误。当编程地址与数据大小不对齐时，此位由硬件置位。TED 将指示问题在源端还是目的端。软件向 DMA_IFCRy 寄存器中的 CTEIFx 位写 1 可将其清零。</description>
              <bitOffset>10</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>BSE</name>
              <description>块大小错误。当块大小不是源端或目的端数据大小的整数倍时，此位由硬件置位。TED 将指示问题在源端还是目的端。软件向 DMA_IFCRy 寄存器中的 CTEIFx 位写 1 可将其清零。</description>
              <bitOffset>11</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C14CR</name>
          <displayName>MDMA_C14CR</displayName>
          <description>此寄存器用于控制相应通道。</description>
          <addressOffset>0x3CC</addressOffset>
          <size>0x20</size>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>EN</name>
              <description>通道使能</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>TEIE</name>
              <description>传输错误中断使能。此位由软件置位与清零。</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>CTCIE</name>
              <description>通道传输完成中断使能。此位由软件置位与清零。</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>BRTIE</name>
              <description>块重复传输中断使能。此位由软件置位与清零。</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>BTIE</name>
              <description>块传输中断使能。此位由软件置位与清零。</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>TCIE</name>
              <description>缓冲区传输完成中断使能。此位由软件置位与清零。</description>
              <bitOffset>5</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>PL</name>
              <description>优先级。这些位由软件置位与清零。这些位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>6</bitOffset>
              <bitWidth>2</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>BEX</name>
              <description>字节端序交换</description>
              <bitOffset>12</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>HEX</name>
              <description>半字端序交换</description>
              <bitOffset>13</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>WEX</name>
              <description>字端序交换</description>
              <bitOffset>14</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>SWRQ</name>
              <description>软件请求。向此位写 1 将使 MDMA_ISRy 寄存器中的 CRQAx 置位，从而激活通道 x 的请求。注意：可通过整个 CxCR 寄存器或地址偏移为 0x4E + 0x40*通道号的 8 位/16 位寄存器来激活 SWRQ。在软件请求的情况下，不会产生应答信号（无硬件信号，也不进行 CxMAR 写访问）。</description>
              <bitOffset>16</bitOffset>
              <bitWidth>1</bitWidth>
              <access>write-only</access>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C14TCR</name>
          <displayName>MDMA_C14TCR</displayName>
          <description>此寄存器用于配置相应通道。</description>
          <addressOffset>0x3D0</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>SINC</name>
              <description>源地址增量模式。这些位由软件置位与清零。这些位受保护，仅当 EN 为 0 时才可写入。注意：当源端为 AHB 总线时（SBUS=1），禁止 SINC = 00。在链接列表模式下，在一个块（单次或重复块传输模式中的最后一个块）结束时，此寄存器将从存储器（地址由当前 LAR[31:0] + 0x00 给出）重新加载。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>DINC</name>
              <description>目的地址增量模式。这些位由软件置位与清零。这些位受保护，仅当 EN 为 0 时才可写入。注意：当目的端为 AHB 总线时（DBUS=1），禁止 DINC = 00。</description>
              <bitOffset>2</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>SSIZE</name>
              <description>源数据大小。这些位由软件置位与清零。这些位受保护，仅当 EN 为 0 时才可写入。注意：若为 TCM 访问/AHB 端口编程了 11 值，将发生传输错误（TEIF 位置位）。若 SINCOS &lt; SSIZE 且 SINC != 00，结果不可预测。注意：当源端为 TCM/AHB 总线时（SBUS=1），禁止 SSIZE = 11（双字）。</description>
              <bitOffset>4</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>DSIZE</name>
              <description>目的数据大小。这些位由软件置位与清零。这些位受保护，仅当 EN 为 0 时才可写入。注意：若为 TCM 访问/AHB 端口编程了 11 值，将发生传输错误（TEIF 位置位）。若 DINCOS &lt; DSIZE 且 DINC != 00，结果不可预测。注意：当目的端为 TCM/AHB 总线时（DBUS=1），禁止 DSIZE = 11（双字）。</description>
              <bitOffset>6</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>SINCOS</name>
              <description>源地址增量偏移大小</description>
              <bitOffset>8</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>DINCOS</name>
              <description>目的地址增量偏移</description>
              <bitOffset>10</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>SBURST</name>
              <description>源端突发传输配置</description>
              <bitOffset>12</bitOffset>
              <bitWidth>3</bitWidth>
            </field>
            <field>
              <name>DBURST</name>
              <description>目的端突发传输配置</description>
              <bitOffset>15</bitOffset>
              <bitWidth>3</bitWidth>
            </field>
            <field>
              <name>TLEN</name>
              <description>缓冲区传输长度</description>
              <bitOffset>18</bitOffset>
              <bitWidth>7</bitWidth>
            </field>
            <field>
              <name>PKE</name>
              <description>打包使能。此位由软件置位与清零。若源数据大小小于目的数据大小，将按 PAM 值进行填充。若源数据大小大于目的数据大小，将被截断。对齐方式根据 PAM[0] 值确定。此位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>25</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>PAM</name>
              <description>填充/对齐模式。这些位由软件置位与清零。情况 1：源数据大小小于目的数据大小——3 种选项有效。情况 2：源数据大小大于目的数据大小——多余部分被丢弃。当 PKE = 1 或 DSIZE=SSIZE 时，这些位被忽略。这些位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>26</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>TRGM</name>
              <description>触发模式。这些位由软件置位与清零。注意：若当前块的 TRGM 为 11，则通过链接列表机制在当前块结束时加载的所有值必须保持相同的 TRGM=11 值和相同的 SWRM 值，否则结果未定义。这些位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>28</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>SWRM</name>
              <description>软件请求模式。此位由软件置位与清零。若当前有硬件或软件请求处于活跃状态，此位的变更将延迟到当前传输完成之后。若 CxMAR 包含有效地址，CxMDR 的值也将写入 CxMAR 地址。此位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>30</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>BWM</name>
              <description>缓冲写模式。此位由软件置位与清零。此位受保护，仅当 EN 为 0 时才可写入。注意：所有 MDMA 目的端访问均为不可缓存访问。</description>
              <bitOffset>31</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C14BNDTR</name>
          <displayName>MDMA_C14BNDTR</displayName>
          <description>MDMA 通道 x 块数据传输数量寄存器</description>
          <addressOffset>0x3D4</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>BNDT</name>
              <description>待传输数据块数量</description>
              <bitOffset>0</bitOffset>
              <bitWidth>17</bitWidth>
            </field>
            <field>
              <name>BRSUM</name>
              <description>块重复源地址更新模式。这些位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>18</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>BRDUM</name>
              <description>块重复目的地址更新模式。这些位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>19</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>BRC</name>
              <description>块重复计数。此字段包含当前块的重复次数（0 到 4095）。通道使能后，此寄存器为只读，指示剩余块数（不含当前块）。每次完整块传输完成后此寄存器递减。最后一个块传输完成后，此寄存器可保持为零，或自动从存储器重新加载（在链接列表模式下——即链接地址有效时）。这些位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>20</bitOffset>
              <bitWidth>12</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C14SAR</name>
          <displayName>MDMA_C14SAR</displayName>
          <description>MDMA 通道 x 源地址寄存器</description>
          <addressOffset>0x3D8</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>SAR</name>
              <description>源地址基址</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C14DAR</name>
          <displayName>MDMA_C14DAR</displayName>
          <description>MDMA 通道 x 目的地址寄存器</description>
          <addressOffset>0x3DC</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>DAR</name>
              <description>目的地址基址</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C14BRUR</name>
          <displayName>MDMA_C14BRUR</displayName>
          <description>MDMA 通道 x 块重复地址更新寄存器</description>
          <addressOffset>0x3E0</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>SUV</name>
              <description>源地址更新值</description>
              <bitOffset>0</bitOffset>
              <bitWidth>16</bitWidth>
            </field>
            <field>
              <name>DUV</name>
              <description>目的地址更新值</description>
              <bitOffset>16</bitOffset>
              <bitWidth>16</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C14LAR</name>
          <displayName>MDMA_C14LAR</displayName>
          <description>MDMA 通道 x 链接地址寄存器</description>
          <addressOffset>0x3E4</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>LAR</name>
              <description>链接地址寄存器</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C14TBR</name>
          <displayName>MDMA_C14TBR</displayName>
          <description>MDMA 通道 x 触发与总线选择寄存器</description>
          <addressOffset>0x3E8</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>TSEL</name>
              <description>触发选择</description>
              <bitOffset>0</bitOffset>
              <bitWidth>6</bitWidth>
            </field>
            <field>
              <name>SBUS</name>
              <description>源总线选择。此位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>16</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DBUS</name>
              <description>目的总线选择。此位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>17</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C14MAR</name>
          <displayName>MDMA_C14MAR</displayName>
          <description>MDMA 通道 x 掩码地址寄存器</description>
          <addressOffset>0x3F0</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>MAR</name>
              <description>掩码地址</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C14MDR</name>
          <displayName>MDMA_C14MDR</displayName>
          <description>MDMA 通道 x 掩码数据寄存器</description>
          <addressOffset>0x3F4</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>MDR</name>
              <description>掩码数据</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C15ISR</name>
          <displayName>MDMA_C15ISR</displayName>
          <description>MDMA 通道 x 中断/状态寄存器</description>
          <addressOffset>0x400</addressOffset>
          <size>0x20</size>
          <access>read-only</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>TEIF15</name>
              <description>通道 x 传输错误中断标志。此位由硬件置位。软件向 DMA_IFCRy 寄存器的对应位写 1 可将其清零。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CTCIF15</name>
              <description>通道 x 通道传输完成中断标志。此位由硬件置位。软件向 DMA_IFCRy 寄存器的对应位写 1 可将其清零。当最后一个块传输完成且通道已自动禁用时，CTC 置位。当通道因 EN 位写 0 而挂起时，CTC 同样置位。</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>BRTIF15</name>
              <description>通道 x 块重复传输完成中断标志。此位由硬件置位。软件向 DMA_IFCRy 寄存器的对应位写 1 可将其清零。</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>BTIF15</name>
              <description>通道 x 块传输完成中断标志。此位由硬件置位。软件向 DMA_IFCRy 寄存器的对应位写 1 可将其清零。</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>TCIF15</name>
              <description>通道 x 缓冲区传输完成</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CRQA15</name>
              <description>通道 x 请求活跃标志</description>
              <bitOffset>16</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C15IFCR</name>
          <displayName>MDMA_C15IFCR</displayName>
          <description>MDMA 通道 x 中断标志清除寄存器</description>
          <addressOffset>0x404</addressOffset>
          <size>0x20</size>
          <access>write-only</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>CTEIF15</name>
              <description>通道 x 清除传输错误中断标志。向此位写 1 可将 MDMA_ISRy 寄存器中的 TEIFx 清零。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CCTCIF15</name>
              <description>通道 x 清除通道传输完成中断标志。向此位写 1 可将 MDMA_ISRy 寄存器中的 CTCIFx 清零。</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CBRTIF15</name>
              <description>通道 x 清除块重复传输完成中断标志。向此位写 1 可将 MDMA_ISRy 寄存器中的 BRTIFx 清零。</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CBTIF15</name>
              <description>通道 x 清除块传输完成中断标志。向此位写 1 可将 MDMA_ISRy 寄存器中的 BTIFx 清零。</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CLTCIF15</name>
              <description>通道 x 清除缓冲区传输完成中断标志。向此位写 1 可将 MDMA_ISRy 寄存器中的 TCIFx 清零。</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C15ESR</name>
          <displayName>MDMA_C15ESR</displayName>
          <description>MDMA 通道 x 错误状态寄存器</description>
          <addressOffset>0x408</addressOffset>
          <size>0x20</size>
          <access>read-only</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>TEA</name>
              <description>传输错误地址。在 MDMA 数据传输发生错误时，这些位由硬件置位与清零，与 TED 配合使用。该字段指示引发传输/访问错误的地址的低 7 位。软件可将其（截断至缓冲区传输长度大小）与当前 SAR/DAR 值相加来还原故障地址。注意：由于 FIFO 管理机制，SAR/DAR 当前值并不反映该最后地址。SAR/DAR 仅在（缓冲区）传完 TLEN+1 字节后才更新。注意：发生链接数据错误时此字段不会置位。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>7</bitWidth>
            </field>
            <field>
              <name>TED</name>
              <description>传输错误方向。在 MDMA 数据传输发生错误时，此位由硬件置位与清零。</description>
              <bitOffset>7</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>TELD</name>
              <description>传输错误（链接数据）。当读取块链接数据结构发生传输错误时，此位由硬件置位。软件向 DMA_IFCRy 寄存器中的 CTEIFx 位写 1 可将其清零。</description>
              <bitOffset>8</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>TEMD</name>
              <description>传输错误（掩码数据）。当写入掩码数据发生传输错误时，此位由硬件置位。软件向 DMA_IFCRy 寄存器中的 CTEIFx 位写 1 可将其清零。</description>
              <bitOffset>9</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>ASE</name>
              <description>地址/大小错误。当编程地址与数据大小不对齐时，此位由硬件置位。TED 将指示问题在源端还是目的端。软件向 DMA_IFCRy 寄存器中的 CTEIFx 位写 1 可将其清零。</description>
              <bitOffset>10</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>BSE</name>
              <description>块大小错误。当块大小不是源端或目的端数据大小的整数倍时，此位由硬件置位。TED 将指示问题在源端还是目的端。软件向 DMA_IFCRy 寄存器中的 CTEIFx 位写 1 可将其清零。</description>
              <bitOffset>11</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C15CR</name>
          <displayName>MDMA_C15CR</displayName>
          <description>此寄存器用于控制相应通道。</description>
          <addressOffset>0x40C</addressOffset>
          <size>0x20</size>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>EN</name>
              <description>通道使能</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>TEIE</name>
              <description>传输错误中断使能。此位由软件置位与清零。</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>CTCIE</name>
              <description>通道传输完成中断使能。此位由软件置位与清零。</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>BRTIE</name>
              <description>块重复传输中断使能。此位由软件置位与清零。</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>BTIE</name>
              <description>块传输中断使能。此位由软件置位与清零。</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>TCIE</name>
              <description>缓冲区传输完成中断使能。此位由软件置位与清零。</description>
              <bitOffset>5</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>PL</name>
              <description>优先级。这些位由软件置位与清零。这些位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>6</bitOffset>
              <bitWidth>2</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>BEX</name>
              <description>字节端序交换</description>
              <bitOffset>12</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>HEX</name>
              <description>半字端序交换</description>
              <bitOffset>13</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>WEX</name>
              <description>字端序交换</description>
              <bitOffset>14</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>SWRQ</name>
              <description>软件请求。向此位写 1 将使 MDMA_ISRy 寄存器中的 CRQAx 置位，从而激活通道 x 的请求。注意：可通过整个 CxCR 寄存器或地址偏移为 0x4E + 0x40*通道号的 8 位/16 位寄存器来激活 SWRQ。在软件请求的情况下，不会产生应答信号（无硬件信号，也不进行 CxMAR 写访问）。</description>
              <bitOffset>16</bitOffset>
              <bitWidth>1</bitWidth>
              <access>write-only</access>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C15TCR</name>
          <displayName>MDMA_C15TCR</displayName>
          <description>此寄存器用于配置相应通道。</description>
          <addressOffset>0x410</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>SINC</name>
              <description>源地址增量模式。这些位由软件置位与清零。这些位受保护，仅当 EN 为 0 时才可写入。注意：当源端为 AHB 总线时（SBUS=1），禁止 SINC = 00。在链接列表模式下，在一个块（单次或重复块传输模式中的最后一个块）结束时，此寄存器将从存储器（地址由当前 LAR[31:0] + 0x00 给出）重新加载。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>DINC</name>
              <description>目的地址增量模式。这些位由软件置位与清零。这些位受保护，仅当 EN 为 0 时才可写入。注意：当目的端为 AHB 总线时（DBUS=1），禁止 DINC = 00。</description>
              <bitOffset>2</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>SSIZE</name>
              <description>源数据大小。这些位由软件置位与清零。这些位受保护，仅当 EN 为 0 时才可写入。注意：若为 TCM 访问/AHB 端口编程了 11 值，将发生传输错误（TEIF 位置位）。若 SINCOS &lt; SSIZE 且 SINC != 00，结果不可预测。注意：当源端为 TCM/AHB 总线时（SBUS=1），禁止 SSIZE = 11（双字）。</description>
              <bitOffset>4</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>DSIZE</name>
              <description>目的数据大小。这些位由软件置位与清零。这些位受保护，仅当 EN 为 0 时才可写入。注意：若为 TCM 访问/AHB 端口编程了 11 值，将发生传输错误（TEIF 位置位）。若 DINCOS &lt; DSIZE 且 DINC != 00，结果不可预测。注意：当目的端为 TCM/AHB 总线时（DBUS=1），禁止 DSIZE = 11（双字）。</description>
              <bitOffset>6</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>SINCOS</name>
              <description>源地址增量偏移大小</description>
              <bitOffset>8</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>DINCOS</name>
              <description>目的地址增量偏移</description>
              <bitOffset>10</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>SBURST</name>
              <description>源端突发传输配置</description>
              <bitOffset>12</bitOffset>
              <bitWidth>3</bitWidth>
            </field>
            <field>
              <name>DBURST</name>
              <description>目的端突发传输配置</description>
              <bitOffset>15</bitOffset>
              <bitWidth>3</bitWidth>
            </field>
            <field>
              <name>TLEN</name>
              <description>缓冲区传输长度</description>
              <bitOffset>18</bitOffset>
              <bitWidth>7</bitWidth>
            </field>
            <field>
              <name>PKE</name>
              <description>打包使能。此位由软件置位与清零。若源数据大小小于目的数据大小，将按 PAM 值进行填充。若源数据大小大于目的数据大小，将被截断。对齐方式根据 PAM[0] 值确定。此位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>25</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>PAM</name>
              <description>填充/对齐模式。这些位由软件置位与清零。情况 1：源数据大小小于目的数据大小——3 种选项有效。情况 2：源数据大小大于目的数据大小——多余部分被丢弃。当 PKE = 1 或 DSIZE=SSIZE 时，这些位被忽略。这些位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>26</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>TRGM</name>
              <description>触发模式。这些位由软件置位与清零。注意：若当前块的 TRGM 为 11，则通过链接列表机制在当前块结束时加载的所有值必须保持相同的 TRGM=11 值和相同的 SWRM 值，否则结果未定义。这些位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>28</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>SWRM</name>
              <description>软件请求模式。此位由软件置位与清零。若当前有硬件或软件请求处于活跃状态，此位的变更将延迟到当前传输完成之后。若 CxMAR 包含有效地址，CxMDR 的值也将写入 CxMAR 地址。此位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>30</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>BWM</name>
              <description>缓冲写模式。此位由软件置位与清零。此位受保护，仅当 EN 为 0 时才可写入。注意：所有 MDMA 目的端访问均为不可缓存访问。</description>
              <bitOffset>31</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C15BNDTR</name>
          <displayName>MDMA_C15BNDTR</displayName>
          <description>MDMA 通道 x 块数据传输数量寄存器</description>
          <addressOffset>0x414</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>BNDT</name>
              <description>待传输数据块数量</description>
              <bitOffset>0</bitOffset>
              <bitWidth>17</bitWidth>
            </field>
            <field>
              <name>BRSUM</name>
              <description>块重复源地址更新模式。这些位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>18</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>BRDUM</name>
              <description>块重复目的地址更新模式。这些位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>19</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>BRC</name>
              <description>块重复计数。此字段包含当前块的重复次数（0 到 4095）。通道使能后，此寄存器为只读，指示剩余块数（不含当前块）。每次完整块传输完成后此寄存器递减。最后一个块传输完成后，此寄存器可保持为零，或自动从存储器重新加载（在链接列表模式下——即链接地址有效时）。这些位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>20</bitOffset>
              <bitWidth>12</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C15SAR</name>
          <displayName>MDMA_C15SAR</displayName>
          <description>MDMA 通道 x 源地址寄存器</description>
          <addressOffset>0x418</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>SAR</name>
              <description>源地址基址</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C15DAR</name>
          <displayName>MDMA_C15DAR</displayName>
          <description>MDMA 通道 x 目的地址寄存器</description>
          <addressOffset>0x41C</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>DAR</name>
              <description>目的地址基址</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C15BRUR</name>
          <displayName>MDMA_C15BRUR</displayName>
          <description>MDMA 通道 x 块重复地址更新寄存器</description>
          <addressOffset>0x420</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>SUV</name>
              <description>源地址更新值</description>
              <bitOffset>0</bitOffset>
              <bitWidth>16</bitWidth>
            </field>
            <field>
              <name>DUV</name>
              <description>目的地址更新值</description>
              <bitOffset>16</bitOffset>
              <bitWidth>16</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C15LAR</name>
          <displayName>MDMA_C15LAR</displayName>
          <description>MDMA 通道 x 链接地址寄存器</description>
          <addressOffset>0x424</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>LAR</name>
              <description>链接地址寄存器</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C15TBR</name>
          <displayName>MDMA_C15TBR</displayName>
          <description>MDMA 通道 x 触发与总线选择寄存器</description>
          <addressOffset>0x428</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>TSEL</name>
              <description>触发选择</description>
              <bitOffset>0</bitOffset>
              <bitWidth>6</bitWidth>
            </field>
            <field>
              <name>SBUS</name>
              <description>源总线选择。此位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>16</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DBUS</name>
              <description>目的总线选择。此位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>17</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C15MAR</name>
          <displayName>MDMA_C15MAR</displayName>
          <description>MDMA 通道 x 掩码地址寄存器</description>
          <addressOffset>0x430</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>MAR</name>
              <description>掩码地址</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C15MDR</name>
          <displayName>MDMA_C15MDR</displayName>
          <description>MDMA 通道 x 掩码数据寄存器</description>
          <addressOffset>0x434</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>MDR</name>
              <description>掩码数据</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
      </registers>
    </peripheral>
    <peripheral>
      <name>QUADSPI</name>
      <description>QUADSPI</description>
      <groupName>QUADSPI</groupName>
      <baseAddress>0x52005000</baseAddress>
      <addressBlock>
        <offset>0x0</offset>
        <size>0x400</size>
        <usage>registers</usage>
      </addressBlock>
      <interrupt>
        <name>QUADSPI</name>
        <description>QuadSPI 全局中断</description>
        <value>92</value>
      </interrupt>
      <registers>
        <register>
          <name>CR</name>
          <displayName>CR</displayName>
          <description>QUADSPI 控制寄存器</description>
          <addressOffset>0x0</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>EN</name>
              <description>使能 使能 QUADSPI。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>ABORT</name>
              <description>中止请求 该位中止正在进行的命令序列。中止完成后自动复位。该位会停止当前传输。在轮询模式或存储器映射模式下，该位还会复位 APM 位或 DM 位。</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DMAEN</name>
              <description>DMA 使能 在间接模式下，可通过 QUADSPI_DR 寄存器使用 DMA 输入或输出数据。当 FIFO 阈值标志 FTF 置位时，将启动 DMA 传输。</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>TCEN</name>
              <description>超时计数器使能 该位仅在选择了存储器映射模式（FMODE = 11）时有效。激活该位后，如果在指定时间内没有发生访问，片选信号（nCS）将被释放（从而降低功耗），该时间由 TIMEOUT[15:0]（QUADSPI_LPTR）定义。使能超时计数器。默认情况下，QUADSPI 不会停止其预取操作，即使长时间没有对 Flash 存储器的访问，仍会保持上一次读操作有效，nCS 维持低电平。由于 Flash 存储器在 nCS 保持低电平时功耗较高，应用程序可能需要激活超时计数器（TCEN = 1，QUADSPI_CR[3]），以便在 FIFO 被预取数据填满后，若在 TIMEOUT[15:0]（QUADSPI_LPTR）个周期内没有发生访问，则释放 nCS。该位只能在 BUSY = 0 时修改。</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>SSHIFT</name>
              <description>采样偏移 默认情况下，QUADSPI 在 Flash 存储器驱动数据后的 1/2 个 CLK 周期处采样数据。该位允许延迟采样数据，以补偿外部信号延迟。固件必须确保在 DDR 模式下（DDRM = 1）SSHIFT = 0。该字段只能在 BUSY = 0 时修改。</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DFM</name>
              <description>双 Flash 模式 该位激活双 Flash 模式，即同时使用两个外部 Flash 存储器，使吞吐量和容量翻倍。该位只能在 BUSY = 0 时修改。</description>
              <bitOffset>6</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>FSEL</name>
              <description>Flash 存储器选择 该位在单 Flash 模式（DFM = 0）下选择要寻址的 Flash 存储器。该位只能在 BUSY = 0 时修改。当 DFM = 1 时该位被忽略。</description>
              <bitOffset>7</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>FTHRES</name>
              <description>FIFO 阈值级别 在间接模式下，定义 FIFO 中触发 FIFO 阈值标志（FTF，QUADSPI_SR[2]）置位的字节阈值数。在间接写模式（FMODE = 00）下：...... 在间接读模式（FMODE = 01）下：...... 如果 DMAEN = 1，则在更改 FTHRES 值之前必须先禁用相应通道的 DMA 控制器。</description>
              <bitOffset>8</bitOffset>
              <bitWidth>5</bitWidth>
            </field>
            <field>
              <name>TEIE</name>
              <description>传输错误中断使能 该位使能传输错误中断。</description>
              <bitOffset>16</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>TCIE</name>
              <description>传输完成中断使能 该位使能传输完成中断。</description>
              <bitOffset>17</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>FTIE</name>
              <description>FIFO 阈值中断使能 该位使能 FIFO 阈值中断。</description>
              <bitOffset>18</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>SMIE</name>
              <description>状态匹配中断使能 该位使能状态匹配中断。</description>
              <bitOffset>19</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>TOIE</name>
              <description>超时中断使能 该位使能超时中断。</description>
              <bitOffset>20</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>APMS</name>
              <description>自动轮询模式停止 该位决定匹配后是否停止自动轮询。该位只能在 BUSY = 0 时修改。</description>
              <bitOffset>22</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>PMM</name>
              <description>轮询匹配模式 该位指示在自动轮询模式期间用于确定匹配的方法。该位只能在 BUSY = 0 时修改。</description>
              <bitOffset>23</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>PRESCALER</name>
              <description>时钟预分频器</description>
              <bitOffset>24</bitOffset>
              <bitWidth>8</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>DCR</name>
          <displayName>DCR</displayName>
          <description>QUADSPI 器件配置寄存器</description>
          <addressOffset>0x4</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>CKMODE</name>
              <description>指示 CLK 在命令之间所处的电平</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CSHT</name>
              <description>片选高电平时间 CSHT + 1 定义了向 Flash 存储器发出的命令之间，片选信号（nCS）必须保持高电平的最小 CLK 周期数。...... 该字段只能在 BUSY = 0 时修改。</description>
              <bitOffset>8</bitOffset>
              <bitWidth>3</bitWidth>
            </field>
            <field>
              <name>FSIZE</name>
              <description>Flash 存储器容量 该字段使用以下公式定义外部存储器的容量：Flash 存储器的字节数 = 2[FSIZE+1]。FSIZE + 1 实际上是寻址 Flash 存储器所需的地址位数。在间接模式下，Flash 存储器容量最大可达 4GB（使用 32 位寻址），但在存储器映射模式下，可寻址空间限制为 256MB。如果 DFM = 1，FSIZE 表示两个 Flash 存储器的总容量。该字段只能在 BUSY = 0 时修改。</description>
              <bitOffset>16</bitOffset>
              <bitWidth>5</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>SR</name>
          <displayName>SR</displayName>
          <description>QUADSPI 状态寄存器</description>
          <addressOffset>0x8</addressOffset>
          <size>0x20</size>
          <access>read-only</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>TEF</name>
              <description>传输错误标志 在间接模式下，当访问了无效地址时该位置位。向 CTEF 写入 1 可将其清零。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>TCF</name>
              <description>传输完成标志 在间接模式下，当已传输完编程数量的数据时该位置位；或在任何模式下，当传输被中止时该位置位。向 CTCF 写入 1 可将其清零。</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>FTF</name>
              <description>FIFO 阈值标志 在间接模式下，当达到 FIFO 阈值时，或当 Flash 存储器读取完成后 FIFO 中仍有数据时，该位置位。一旦阈值条件不再满足，该位自动清零。在自动轮询模式下，每次读取状态寄存器时该位置位，读取数据寄存器时该位清零。</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>SMF</name>
              <description>状态匹配标志 在自动轮询模式下，当未掩码的接收数据与匹配寄存器（QUADSPI_PSMAR）中的对应位匹配时，该位置位。向 CSMF 写入 1 可将其清零。</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>TOF</name>
              <description>超时标志 发生超时时该位置位。向 CTOF 写入 1 可将其清零。</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>BUSY</name>
              <description>忙标志 当操作正在进行时该位置位。当 Flash 存储器操作完成且 FIFO 为空时，该位自动清零。</description>
              <bitOffset>5</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>FLEVEL</name>
              <description>FIFO 级别 该字段给出 FIFO 中当前保存的有效字节数。FIFO 为空时 FLEVEL = 0，满时为 16。在存储器映射模式和自动状态轮询模式下，FLEVEL 为零。</description>
              <bitOffset>8</bitOffset>
              <bitWidth>6</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>FCR</name>
          <displayName>FCR</displayName>
          <description>QUADSPI 标志清零寄存器</description>
          <addressOffset>0xC</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>CTEF</name>
              <description>清除传输错误标志 写入 1 将清零 QUADSPI_SR 寄存器中的 TEF 标志。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CTCF</name>
              <description>清除传输完成标志 写入 1 将清零 QUADSPI_SR 寄存器中的 TCF 标志。</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CSMF</name>
              <description>清除状态匹配标志 写入 1 将清零 QUADSPI_SR 寄存器中的 SMF 标志。</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CTOF</name>
              <description>清除超时标志 写入 1 将清零 QUADSPI_SR 寄存器中的 TOF 标志。</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>DLR</name>
          <displayName>DLR</displayName>
          <description>QUADSPI 数据长度寄存器</description>
          <addressOffset>0x10</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>DL</name>
              <description>数据长度 在间接模式和状态轮询模式下要获取的数据数量（值 + 1）。状态轮询模式下应使用不大于 3（表示 4 字节）的值。间接模式下的全 1 值表示未定义长度，此时 QUADSPI 将持续传输直到存储器末尾（由 FSIZE 定义）。0x0000_0000：传输 1 字节；0x0000_0001：传输 2 字节；0x0000_0002：传输 3 字节；0x0000_0003：传输 4 字节；......；0xFFFF_FFFD：传输 4,294,967,294（4G-2）字节；0xFFFF_FFFE：传输 4,294,967,295（4G-1）字节；0xFFFF_FFFF：未定义长度——传输所有字节直到 Flash 存储器末尾（由 FSIZE 定义）。如果 FSIZE = 0x1F，则无限继续读取。在双 Flash 模式（DFM = 1）下，即使向 DL[0] 写入 0，该位也会被强制置 1，从而确保每次访问传输偶数个字节。在存储器映射模式（FMODE = 10）下，该字段无效。该字段只能在 BUSY = 0 时写入。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>CCR</name>
          <displayName>CCR</displayName>
          <description>QUADSPI 通信配置寄存器</description>
          <addressOffset>0x14</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>INSTRUCTION</name>
              <description>指令 要发送到外部 SPI 器件的指令。该字段只能在 BUSY = 0 时写入。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>8</bitWidth>
            </field>
            <field>
              <name>IMODE</name>
              <description>指令模式 该字段定义指令阶段的操作模式：该字段只能在 BUSY = 0 时写入。</description>
              <bitOffset>8</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>ADMODE</name>
              <description>地址模式 该字段定义地址阶段的操作模式：该字段只能在 BUSY = 0 时写入。</description>
              <bitOffset>10</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>ADSIZE</name>
              <description>地址大小 该位定义地址大小：该字段只能在 BUSY = 0 时写入。</description>
              <bitOffset>12</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>ABMODE</name>
              <description>交替字节模式 该字段定义交替字节阶段的操作模式：该字段只能在 BUSY = 0 时写入。</description>
              <bitOffset>14</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>ABSIZE</name>
              <description>交替字节大小 该位定义交替字节大小：该字段只能在 BUSY = 0 时写入。</description>
              <bitOffset>16</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>DCYC</name>
              <description>空周期数 该字段定义空周期阶段的持续时间。在 SDR 和 DDR 两种模式下，它指定 CLK 周期数（0-31）。该字段只能在 BUSY = 0 时写入。</description>
              <bitOffset>18</bitOffset>
              <bitWidth>5</bitWidth>
            </field>
            <field>
              <name>DMODE</name>
              <description>数据模式 该字段定义数据阶段的操作模式：该字段同时也决定了空周期阶段的操作模式。该字段只能在 BUSY = 0 时写入。</description>
              <bitOffset>24</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>FMODE</name>
              <description>功能模式 该字段定义 QUADSPI 的功能操作模式。如果 DMAEN 已为 1，则在更改 FMODE 值之前必须先禁用相应通道的 DMA 控制器。该字段只能在 BUSY = 0 时写入。</description>
              <bitOffset>26</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>SIOO</name>
              <description>仅发送指令一次模式 参见第 15.3.11 节：仅发送指令一次（第 13 页）。当 IMODE = 00 时该位无效。该字段只能在 BUSY = 0 时写入。</description>
              <bitOffset>28</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DHHC</name>
              <description>DDR 保持 在 DDR 模式下，将数据输出延迟 QUADSPI 输出时钟周期的 1/4：此功能仅在 DDR 模式下有效。该字段只能在 BUSY = 0 时写入。</description>
              <bitOffset>30</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DDRM</name>
              <description>双倍数据速率模式 该位为地址阶段、交替字节阶段和数据阶段设置 DDR 模式：该字段只能在 BUSY = 0 时写入。</description>
              <bitOffset>31</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>AR</name>
          <displayName>AR</displayName>
          <description>QUADSPI 地址寄存器</description>
          <addressOffset>0x18</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>ADDRESS</name>
              <description>[31:0]：地址 要发送到外部 Flash 存储器的地址。当 BUSY = 0 或 FMODE = 11（存储器映射模式）时，对该字段的写入将被忽略。在双 Flash 模式下，ADDRESS[0] 自动强制为 0，因为地址应始终为偶数。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>ABR</name>
          <displayName>ABR</displayName>
          <description>QUADSPI 交替字节寄存器</description>
          <addressOffset>0x1C</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>ALTERNATE</name>
              <description>交替字节 紧接地址之后发送到外部 SPI 器件的可选数据。该字段只能在 BUSY = 0 时写入。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>DR</name>
          <displayName>DR</displayName>
          <description>QUADSPI 数据寄存器</description>
          <addressOffset>0x20</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>DATA</name>
              <description>数据 要发送到外部 SPI 器件或从外部 SPI 器件接收的数据。在间接写模式下，写入该寄存器的数据先存储在 FIFO 中，然后在数据阶段发送到 Flash 存储器。若 FIFO 过满，写操作将暂停，直到 FIFO 有足够空间容纳正在写入的数据量。在间接读模式下，读取该寄存器将（通过 FIFO）获取从 Flash 存储器接收的数据。若 FIFO 中没有读取操作所请求的字节数且 BUSY = 1，则读操作将暂停，直到有足够的数据或传输完成（以先发生者为准）。在自动轮询模式下，该寄存器包含从 Flash 存储器读取的最后数据（未掩码）。支持对该寄存器进行字、半字和字节访问。在间接写模式下，字节写入向 FIFO 添加 1 个字节，半字写入添加 2 个字节，字写入添加 4 个字节。类似地，在间接读模式下，字节读取从 FIFO 移除 1 个字节，半字读取移除 2 个字节，字读取移除 4 个字节。间接模式下的访问必须与该寄存器的低位对齐：字节读取必须读取 DATA[7:0]，半字读取必须读取 DATA[15:0]。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>PSMKR</name>
          <displayName>PSMKR</displayName>
          <description>QUADSPI 轮询状态掩码寄存器</description>
          <addressOffset>0x24</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>MASK</name>
              <description>状态掩码 在轮询模式下，对接收到的状态字节应用的掩码。对于位 n：该字段只能在 BUSY = 0 时写入。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>PSMAR</name>
          <displayName>PSMAR</displayName>
          <description>QUADSPI 轮询状态匹配寄存器</description>
          <addressOffset>0x28</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>MATCH</name>
              <description>状态匹配值 用于与掩码后的状态寄存器进行比较以获取匹配的值。该字段只能在 BUSY = 0 时写入。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>PIR</name>
          <displayName>PIR</displayName>
          <description>QUADSPI 轮询间隔寄存器</description>
          <addressOffset>0x2C</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>INTERVAL</name>
              <description>轮询间隔 自动轮询阶段期间两次读取之间的 CLK 周期数。该字段只能在 BUSY = 0 时写入。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>16</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>LPTR</name>
          <displayName>LPTR</displayName>
          <description>QUADSPI 低功耗超时寄存器</description>
          <addressOffset>0x30</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>TIMEOUT</name>
              <description>超时周期 在存储器映射模式下，每次访问后，QUADSPI 会预取后续字节并将其保存在 FIFO 中。该字段指示 FIFO 填满后，QUADSPI 等待多少个 CLK 周期才将 nCS 拉高，使 Flash 存储器进入低功耗状态。该字段只能在 BUSY = 0 时写入。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>16</bitWidth>
            </field>
          </fields>
        </register>
      </registers>
    </peripheral>
    <peripheral>
      <name>RNG</name>
      <description>随机数发生器</description>
      <groupName>RNG</groupName>
      <baseAddress>0x48021800</baseAddress>
      <addressBlock>
        <offset>0x0</offset>
        <size>0x400</size>
        <usage>registers</usage>
      </addressBlock>
      <interrupt>
        <name>HASH_RNG</name>
        <description>HASH 或 RNG 中断</description>
        <value>80</value>
      </interrupt>
      <registers>
        <register>
          <name>CR</name>
          <displayName>CR</displayName>
          <description>RNG 控制寄存器</description>
          <addressOffset>0x0</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>RNGEN</name>
              <description>随机数发生器使能</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>IE</name>
              <description>中断使能</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CED</name>
              <description>时钟错误检测 注意：仅在选择了 ck_rc48 或 ck_pll1_q（ck_pll1_q = 48MHz）时钟源时，时钟错误检测才可使用；否则 CED 位必须置为 1。当 RNG 外设已使能时，不能动态启用或禁用时钟错误检测，如需启用或禁用 CED，必须先禁用 RNG。</description>
              <bitOffset>5</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>SR</name>
          <displayName>SR</displayName>
          <description>RNG 状态寄存器</description>
          <addressOffset>0x4</addressOffset>
          <size>0x20</size>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>DRDY</name>
              <description>数据就绪 注意：若 RNG_CR 中 IE=1，则当 DRDY=1 时会产生中断。该位在外设禁用时也可能置位。当输出缓冲区变空（读取 RNG_DR 后），此位恢复为 0，直到生成新的随机值。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>CECS</name>
              <description>时钟错误当前状态 注意：若 RNG_CR 中的 CED（时钟错误检测）位为 1，此位无意义。</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>SECS</name>
              <description>种子错误当前状态 ** 连续 64 位以上为相同值（全 0 或全 1）** 连续 32 次以上 0 和 1 交替（0101010101...01）</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>CEIS</name>
              <description>时钟错误中断状态 此位与 CECS 同时置位，写 0 将其清除。若 RNG_CR 寄存器中 IE = 1，则有中断挂起。注意：若 RNG_CR 中的 CED（时钟错误检测）位为 1，此位无意义。</description>
              <bitOffset>5</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>SEIS</name>
              <description>种子错误中断状态 此位与 SECS 同时置位，写 0 将其清除。** 连续 64 位以上为相同值（全 0 或全 1）** 连续 32 次以上 0 和 1 交替（0101010101...01）若 RNG_CR 寄存器中 IE = 1，则有中断挂起。</description>
              <bitOffset>6</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
          </fields>
        </register>
        <register>
          <name>DR</name>
          <displayName>DR</displayName>
          <description>RNG_DR 寄存器为只读寄存器，读取时返回 32 位随机值。当 DRDY=1 时，该寄存器内容有效，即使 RNGEN=0 也如此。</description>
          <addressOffset>0x8</addressOffset>
          <size>0x20</size>
          <access>read-only</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>RNDATA</name>
              <description>随机数据 32 位随机数据，当 DRDY=1 时有效。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
      </registers>
    </peripheral>
    <peripheral>
      <name>RTC</name>
      <description>RTC</description>
      <groupName>RTC</groupName>
      <baseAddress>0x58004000</baseAddress>
      <addressBlock>
        <offset>0x0</offset>
        <size>0x400</size>
        <usage>registers</usage>
      </addressBlock>
      <interrupt>
        <name>RTC_ALARM</name>
        <description>RTC 闹钟中断（A 和 B）</description>
        <value>41</value>
      </interrupt>
      <interrupt>
        <name>RTC_WKUP</name>
        <description>RTC 唤醒中断</description>
        <value>3</value>
      </interrupt>
      <interrupt>
        <name>RTC_TAMP_STAMP_CSS_LSE</name>
        <description>RTC 入侵检测和时间戳中断</description>
        <value>2</value>
      </interrupt>
      <registers>
        <register>
          <name>RTC_TR</name>
          <displayName>RTC_TR</displayName>
          <description>日历时间影子寄存器</description>
          <addressOffset>0x0</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>SU</name>
              <description>秒个位（BCD 格式）</description>
              <bitOffset>0</bitOffset>
              <bitWidth>4</bitWidth>
            </field>
            <field>
              <name>ST</name>
              <description>秒十位（BCD 格式）</description>
              <bitOffset>4</bitOffset>
              <bitWidth>3</bitWidth>
            </field>
            <field>
              <name>MNU</name>
              <description>分个位（BCD 格式）</description>
              <bitOffset>8</bitOffset>
              <bitWidth>4</bitWidth>
            </field>
            <field>
              <name>MNT</name>
              <description>分十位（BCD 格式）</description>
              <bitOffset>12</bitOffset>
              <bitWidth>3</bitWidth>
            </field>
            <field>
              <name>HU</name>
              <description>时个位（BCD 格式）</description>
              <bitOffset>16</bitOffset>
              <bitWidth>4</bitWidth>
            </field>
            <field>
              <name>HT</name>
              <description>时十位（BCD 格式）</description>
              <bitOffset>20</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>PM</name>
              <description>AM/PM 指示</description>
              <bitOffset>22</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>RTC_DR</name>
          <displayName>RTC_DR</displayName>
