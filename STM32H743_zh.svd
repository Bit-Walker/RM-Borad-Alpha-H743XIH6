<?xml version="1.0" encoding="utf-8"?>
<device xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" schemaVersion="1.1" xsi:noNamespaceSchemaLocation="CMSIS-SVD_Schema_1_1.xsd">
  <name>STM32H743</name>
  <version>2.4</version>
  <description>STM32H743</description>
  <cpu>
    <name>CM7</name>
    <revision>r0p1</revision>
    <endian>little</endian>
    <mpuPresent>true</mpuPresent>
    <fpuPresent>true</fpuPresent>
    <nvicPrioBits>4</nvicPrioBits>
    <vendorSystickConfig>false</vendorSystickConfig>
  </cpu>
  <addressUnitBits>8</addressUnitBits>
  <width>32</width>
  <size>0x20</size>
  <resetValue>0x0</resetValue>
  <resetMask>0xFFFFFFFF</resetMask>
  <peripherals>
    <peripheral>
      <name>COMP1</name>
      <description>比较器 1</description>
      <groupName>COMP1</groupName>
      <baseAddress>0x58003800</baseAddress>
      <addressBlock>
        <offset>0x0</offset>
        <size>0x400</size>
        <usage>registers</usage>
      </addressBlock>
      <interrupt>
        <name>COMP</name>
        <description>比较器 1 和比较器 2</description>
        <value>137</value>
      </interrupt>
      <registers>
        <register>
          <name>SR</name>
          <displayName>SR</displayName>
          <description>比较器状态寄存器</description>
          <addressOffset>0x0</addressOffset>
          <size>0x20</size>
          <access>read-only</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>C1VAL</name>
              <description>比较器通道 1 输出状态位</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>C2VAL</name>
              <description>比较器通道 2 输出状态位</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>C1IF</name>
              <description>比较器通道 1 中断标志</description>
              <bitOffset>16</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>C2IF</name>
              <description>比较器通道 2 中断标志</description>
              <bitOffset>17</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>ICFR</name>
          <displayName>ICFR</displayName>
          <description>比较器中断标志清除寄存器</description>
          <addressOffset>0x4</addressOffset>
          <size>0x20</size>
          <access>write-only</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>CC1IF</name>
              <description>清除比较器通道 1 中断标志</description>
              <bitOffset>16</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CC2IF</name>
              <description>清除比较器通道 2 中断标志</description>
              <bitOffset>17</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>OR</name>
          <displayName>OR</displayName>
          <description>比较器选项寄存器</description>
          <addressOffset>0x8</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>AFOP</name>
              <description>输出端口复用功能源选择</description>
              <bitOffset>0</bitOffset>
              <bitWidth>11</bitWidth>
            </field>
            <field>
              <name>OR</name>
              <description>选项寄存器</description>
              <bitOffset>11</bitOffset>
              <bitWidth>21</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>CFGR1</name>
          <displayName>CFGR1</displayName>
          <description>比较器配置寄存器 1</description>
          <addressOffset>0xC</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>EN</name>
              <description>比较器通道 1 使能位</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>BRGEN</name>
              <description>分压桥使能</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>SCALEN</name>
              <description>电压分压器使能位</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>POLARITY</name>
              <description>比较器通道 1 极性选择位</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>ITEN</name>
              <description>比较器通道 1 中断使能</description>
              <bitOffset>6</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>HYST</name>
              <description>比较器通道 1 迟滞选择位</description>
              <bitOffset>8</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>PWRMODE</name>
              <description>比较器通道 1 功耗模式</description>
              <bitOffset>12</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>INMSEL</name>
              <description>比较器通道 1 反相输入选择</description>
              <bitOffset>16</bitOffset>
              <bitWidth>3</bitWidth>
            </field>
            <field>
              <name>INPSEL</name>
              <description>比较器通道 1 同相输入选择位</description>
              <bitOffset>20</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>BLANKING</name>
              <description>比较器通道 1 消隐源选择位</description>
              <bitOffset>24</bitOffset>
              <bitWidth>4</bitWidth>
            </field>
            <field>
              <name>LOCK</name>
              <description>锁定位</description>
              <bitOffset>31</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>CFGR2</name>
          <displayName>CFGR2</displayName>
          <description>比较器配置寄存器 2</description>
          <addressOffset>0x10</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>EN</name>
              <description>比较器通道 1 使能位</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>BRGEN</name>
              <description>分压桥使能</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>SCALEN</name>
              <description>电压分压器使能位</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>POLARITY</name>
              <description>比较器通道 1 极性选择位</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>WINMODE</name>
              <description>窗口比较器模式选择位</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>ITEN</name>
              <description>比较器通道 1 中断使能</description>
              <bitOffset>6</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>HYST</name>
              <description>比较器通道 1 迟滞选择位</description>
              <bitOffset>8</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>PWRMODE</name>
              <description>比较器通道 1 功耗模式</description>
              <bitOffset>12</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>INMSEL</name>
              <description>比较器通道 1 反相输入选择</description>
              <bitOffset>16</bitOffset>
              <bitWidth>3</bitWidth>
            </field>
            <field>
              <name>INPSEL</name>
              <description>比较器通道 1 同相输入选择位</description>
              <bitOffset>20</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>BLANKING</name>
              <description>比较器通道 1 消隐源选择位</description>
              <bitOffset>24</bitOffset>
              <bitWidth>4</bitWidth>
            </field>
            <field>
              <name>LOCK</name>
              <description>锁定位</description>
              <bitOffset>31</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
      </registers>
    </peripheral>
    <peripheral>
      <name>CRS</name>
      <description>CRS</description>
      <groupName>CRS</groupName>
      <baseAddress>0x40008400</baseAddress>
      <addressBlock>
        <offset>0x0</offset>
        <size>0x400</size>
        <usage>registers</usage>
      </addressBlock>
      <interrupt>
        <name>CRS</name>
        <description>时钟恢复系统全局中断</description>
        <value>144</value>
      </interrupt>
      <registers>
        <register>
          <name>CR</name>
          <displayName>CR</displayName>
          <description>CRS 控制寄存器</description>
          <addressOffset>0x0</addressOffset>
          <size>0x20</size>
          <resetValue>0x00002000</resetValue>
          <fields>
            <field>
              <name>SYNCOKIE</name>
              <description>SYNC 事件成功中断使能</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>SYNCWARNIE</name>
              <description>SYNC 警告中断使能</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>ERRIE</name>
              <description>同步或微调错误中断使能</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>ESYNCIE</name>
              <description>预期 SYNC 中断使能</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>CEN</name>
              <description>频率误差计数器使能 该位使能频率误差计数器的振荡器时钟。当此位置 1 时，CRS_CFGR 寄存器将被写保护，不可修改。</description>
              <bitOffset>5</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>AUTOTRIMEN</name>
              <description>自动微调使能 该位使能根据两次 SYNC 事件之间测得的频率误差对 TRIM 位进行自动硬件调整。若此位置 1，TRIM 位为只读。硬件可根据测得的频率误差值，每次对 TRIM 值调整一步或两步。详见第 7.3.4 节：频率误差评估与自动微调。</description>
              <bitOffset>6</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>SWSYNC</name>
              <description>生成软件 SYNC 事件 此位由软件置 1，用于生成一次软件 SYNC 事件。由硬件自动清零。</description>
              <bitOffset>7</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>TRIM</name>
              <description>HSI48 振荡器平滑微调 这些位为 HSI48 振荡器提供用户可编程的微调值。可对其进行编程，以补偿电压和温度变化对 HSI48 频率的影响。默认值为 32，对应微调区间的中间位置。相邻两个 TRIM 步进对应的微调步长约为 67 kHz。TRIM 值越大，输出频率越高。当 AUTOTRIMEN 位置 1 时，此字段由硬件控制且为只读。</description>
              <bitOffset>8</bitOffset>
              <bitWidth>6</bitWidth>
              <access>read-write</access>
            </field>
          </fields>
        </register>
        <register>
          <name>CFGR</name>
          <displayName>CFGR</displayName>
          <description>此寄存器仅可在频率误差计数器禁用（CRS_CR 寄存器中 CEN 位清零）时写入。计数器使能后，此寄存器将被写保护。</description>
          <addressOffset>0x4</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x2022BB7F</resetValue>
          <fields>
            <field>
              <name>RELOAD</name>
              <description>计数器重载值 RELOAD 为每次 SYNC 事件时加载到频率误差计数器中的值。有关计数器行为的详细信息，请参见第 7.3.3 节：频率误差测量。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>16</bitWidth>
            </field>
            <field>
              <name>FELIM</name>
              <description>频率误差限值 FELIM 包含用于评估 CRS_ISR 寄存器 FECAP[15:0] 位中锁存的频率误差捕获值的值。有关 FECAP 评估的详细信息，请参见第 7.3.4 节：频率误差评估与自动微调。</description>
              <bitOffset>16</bitOffset>
              <bitWidth>8</bitWidth>
            </field>
            <field>
              <name>SYNCDIV</name>
              <description>SYNC 分频器 这些位由软件置 1 或清零，用于控制 SYNC 信号的分频因子。</description>
              <bitOffset>24</bitOffset>
              <bitWidth>3</bitWidth>
            </field>
            <field>
              <name>SYNCSRC</name>
              <description>SYNC 信号源选择 这些位由软件置 1 或清零，用于选择 SYNC 信号源。注意：使用 USB LPM（链路电源管理）且设备处于睡眠模式时，主机将不会产生周期性的 USB SOF。因此，CRS 将无法获得 SYNC 信号来在运行中校准 HSI48。为保证从睡眠模式唤醒后所需的时钟精度，应使用 LSE 或 GPIO 上的参考时钟作为 SYNC 信号。</description>
              <bitOffset>28</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>SYNCPOL</name>
              <description>SYNC 极性选择 此位由软件置 1 或清零，用于选择 SYNC 信号源的输入极性。</description>
              <bitOffset>31</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>ISR</name>
          <displayName>ISR</displayName>
          <description>CRS 中断和状态寄存器</description>
          <addressOffset>0x8</addressOffset>
          <size>0x20</size>
          <access>read-only</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>SYNCOKF</name>
              <description>SYNC 事件成功标志 当测得的频率误差小于 FELIM × 3 时，硬件将此标志置 1。这意味着无需调整 TRIM 值，或只需调整一个微调步长即可补偿频率误差。若 CRS_CR 寄存器中 SYNCOKIE 位置 1，则会产生中断。通过将 CRS_ICR 寄存器中 SYNCOKC 位置 1，由软件清除此标志。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>SYNCWARNF</name>
              <description>SYNC 警告标志 当测得的频率误差大于或等于 FELIM × 3 但小于 FELIM × 128 时，硬件将此标志置 1。这意味着为补偿频率误差，需将 TRIM 值调整两个步长或更多。若 CRS_CR 寄存器中 SYNCWARNIE 位置 1，则会产生中断。通过将 CRS_ICR 寄存器中 SYNCWARNC 位置 1，由软件清除此标志。</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>ERRF</name>
              <description>错误标志 当发生任何同步或微调错误时，硬件将此标志置 1。它是 TRIMOVF、SYNCMISS 和 SYNCERR 位的逻辑或。若 CRS_CR 寄存器中 ERRIE 位置 1，则会产生中断。软件通过将 CRS_ICR 寄存器中 ERRC 位置 1 来清除此标志，该操作同时清除 TRIMOVF、SYNCMISS 和 SYNCERR 位。</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>ESYNCF</name>
              <description>预期 SYNC 标志 当频率误差计数器达到零值时，硬件将此标志置 1。若 CRS_CR 寄存器中 ESYNCIE 位置 1，则会产生中断。通过将 CRS_ICR 寄存器中 ESYNCC 位置 1，由软件清除此标志。</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>SYNCERR</name>
              <description>SYNC 误差 当 SYNC 脉冲在 ESYNC 事件之前到达且测得的频率误差大于或等于 FELIM × 128 时，硬件将此标志置 1。这意味着频率误差过大（内部频率过低），无法通过调整 TRIM 值来补偿，需采取其他措施。若 CRS_CR 寄存器中 ERRIE 位置 1，则会产生中断。通过将 CRS_ICR 寄存器中 ERRC 位置 1，由软件清除此标志。</description>
              <bitOffset>8</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>SYNCMISS</name>
              <description>SYNC 丢失 当频率误差计数器达到 FELIM × 128 且未检测到 SYNC 时，硬件将此标志置 1，这意味着丢失了一个 SYNC 脉冲，或频率误差过大（内部频率过高），无法通过调整 TRIM 值来补偿，需采取其他措施。此时，频率误差计数器停止（等待下一次 SYNC），若 CRS_CR 寄存器中 ERRIE 位置 1，则会产生中断。通过将 CRS_ICR 寄存器中 ERRC 位置 1，由软件清除此标志。</description>
              <bitOffset>9</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>TRIMOVF</name>
              <description>微调上溢或下溢 当自动微调尝试使 TRIM 值上溢或下溢时，硬件将此标志置 1。若 CRS_CR 寄存器中 ERRIE 位置 1，则会产生中断。通过将 CRS_ICR 寄存器中 ERRC 位置 1，由软件清除此标志。</description>
              <bitOffset>10</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>FEDIR</name>
              <description>频率误差方向 FEDIR 为上次 SYNC 事件时锁存的频率误差计数器计数方向。它指示实际频率是低于还是高于目标值。</description>
              <bitOffset>15</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>FECAP</name>
              <description>频率误差捕获 FECAP 为上次 SYNC 事件时锁存的频率误差计数器值。有关 FECAP 使用的详细信息，请参见第 7.3.4 节：频率误差评估与自动微调。</description>
              <bitOffset>16</bitOffset>
              <bitWidth>16</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>ICR</name>
          <displayName>ICR</displayName>
          <description>CRS 中断标志清除寄存器</description>
          <addressOffset>0xC</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>SYNCOKC</name>
              <description>SYNC 事件成功清除标志 向此位写 1 可清除 CRS_ISR 寄存器中的 SYNCOKF 标志。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>SYNCWARNC</name>
              <description>SYNC 警告清除标志 向此位写 1 可清除 CRS_ISR 寄存器中的 SYNCWARNF 标志。</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>ERRC</name>
              <description>错误清除标志 向此位写 1 可清除 TRIMOVF、SYNCMISS 和 SYNCERR 位，从而同时清除 CRS_ISR 寄存器中的 ERRF 标志。</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>ESYNCC</name>
              <description>预期 SYNC 清除标志 向此位写 1 可清除 CRS_ISR 寄存器中的 ESYNCF 标志。</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
      </registers>
    </peripheral>
    <peripheral>
      <name>DAC</name>
      <description>数模转换器（DAC）</description>
      <groupName>DAC</groupName>
      <baseAddress>0x40007400</baseAddress>
      <addressBlock>
        <offset>0x0</offset>
        <size>0x400</size>
        <usage>registers</usage>
      </addressBlock>
      <registers>
        <register>
          <name>CR</name>
          <displayName>CR</displayName>
          <description>DAC 控制寄存器</description>
          <addressOffset>0x0</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>EN1</name>
              <description>DAC 通道 1 使能位。此位由软件置位或清零，用于使能或禁用 DAC 通道 1。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>TEN1</name>
              <description>DAC 通道 1 触发使能位。</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>TSEL1</name>
              <description>DAC 通道 1 触发源选择位。这些位用于选择触发 DAC 通道 1 的外部事件。注意：仅当 TEN1 位 = 1（DAC 通道 1 触发使能）时有效。</description>
              <bitOffset>2</bitOffset>
              <bitWidth>3</bitWidth>
            </field>
            <field>
              <name>WAVE1</name>
              <description>DAC 通道 1 噪声/三角波生成使能位。这些位由软件置位或清零。注意：仅当 TEN1 位 = 1（DAC 通道 1 触发使能）时有效。</description>
              <bitOffset>6</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>MAMP1</name>
              <description>DAC 通道 1 屏蔽/幅值选择位。这些位由软件写入，用于在波形生成模式下选择 LFSR 屏蔽位，或在三角波生成模式下选择幅值。= 1011：不屏蔽 LFSR 的位[11:0] / 三角波幅值等于 4095。</description>
              <bitOffset>8</bitOffset>
              <bitWidth>4</bitWidth>
            </field>
            <field>
              <name>DMAEN1</name>
              <description>DAC 通道 1 DMA 使能位。此位由软件置位或清零。</description>
              <bitOffset>12</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DMAUDRIE1</name>
              <description>DAC 通道 1 DMA 欠载中断使能位。此位由软件置位或清零。</description>
              <bitOffset>13</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CEN1</name>
              <description>DAC 通道 1 校准使能位。此位由软件置位或清零，用于使能或禁用 DAC 通道 1 校准。仅当 DAC_CR 寄存器中 EN1 位 = 0 时才能写入（仅当 DAC 通道禁用时方可进入或退出校准模式）。否则，写操作将被忽略。</description>
              <bitOffset>14</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>EN2</name>
              <description>DAC 通道 2 使能位。此位由软件置位或清零，用于使能或禁用 DAC 通道 2。</description>
              <bitOffset>16</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>TEN2</name>
              <description>DAC 通道 2 触发使能位。</description>
              <bitOffset>17</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>TSEL2</name>
              <description>DAC 通道 2 触发源选择位。这些位用于选择触发 DAC 通道 2 的外部事件。注意：仅当 TEN2 位 = 1（DAC 通道 2 触发使能）时有效。</description>
              <bitOffset>18</bitOffset>
              <bitWidth>3</bitWidth>
            </field>
            <field>
              <name>WAVE2</name>
              <description>DAC 通道 2 噪声/三角波生成使能位。这些位由软件置位或复位。1x：使能三角波生成。注意：仅当 TEN2 位 = 1（DAC 通道 2 触发使能）时有效。</description>
              <bitOffset>22</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>MAMP2</name>
              <description>DAC 通道 2 屏蔽/幅值选择位。这些位由软件写入，用于在波形生成模式下选择 LFSR 屏蔽位，或在三角波生成模式下选择幅值。= 1011：不屏蔽 LFSR 的位[11:0] / 三角波幅值等于 4095。</description>
              <bitOffset>24</bitOffset>
              <bitWidth>4</bitWidth>
            </field>
            <field>
              <name>DMAEN2</name>
              <description>DAC 通道 2 DMA 使能位。此位由软件置位或清零。</description>
              <bitOffset>28</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DMAUDRIE2</name>
              <description>DAC 通道 2 DMA 欠载中断使能位。此位由软件置位或清零。</description>
              <bitOffset>29</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CEN2</name>
              <description>DAC 通道 2 校准使能位。此位由软件置位或清零，用于使能或禁用 DAC 通道 2 校准。仅当 DAC_CR 寄存器中 EN2 位 = 0 时才能写入（仅当 DAC 通道禁用时方可进入或退出校准模式）。否则，写操作将被忽略。</description>
              <bitOffset>30</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>SWTRGR</name>
          <displayName>SWTRGR</displayName>
          <description>DAC 软件触发寄存器</description>
          <addressOffset>0x4</addressOffset>
          <size>0x20</size>
          <access>write-only</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>SWTRIG1</name>
              <description>DAC 通道 1 软件触发位。此位由软件置位，用于在软件触发模式下触发 DAC。注意：一旦 DAC_DHR1 寄存器的值加载到 DAC_DOR1 寄存器之后，此位由硬件清零（一个 APB1 时钟周期后）。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>SWTRIG2</name>
              <description>DAC 通道 2 软件触发位。此位由软件置位，用于在软件触发模式下触发 DAC。注意：一旦 DAC_DHR2 寄存器的值加载到 DAC_DOR2 寄存器之后，此位由硬件清零（一个 APB1 时钟周期后）。</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>DHR12R1</name>
          <displayName>DHR12R1</displayName>
