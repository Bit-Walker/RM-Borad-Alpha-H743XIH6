          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>DACC1DHR</name>
              <description>DAC 通道 1 8 位右对齐数据。这些位由软件写入，指定 DAC 通道 1 的 8 位数据。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>8</bitWidth>
            </field>
            <field>
              <name>DACC2DHR</name>
              <description>DAC 通道 2 8 位右对齐数据。这些位由软件写入，指定 DAC 通道 2 的 8 位数据。</description>
