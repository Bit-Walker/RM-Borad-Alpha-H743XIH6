                  <description>禁止</description>
                  <value>0x0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>B_0x1</name>
                  <description>使能</description>
                  <value>0x1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>DIR</name>
              <description>数据传输方向。此位仅在存储器到外设和外设到存储器模式下才应置位。源端属性由 PSIZE 和 PINC 以及 BDMA_CPARx 寄存器定义，这在存储器到存储器模式下同样有效。目标端属性由 MSIZE 和 MINC 以及 BDMA_CM0/1ARx 寄存器定义，这在外设到外设模式下同样有效。目标端属性由 PSIZE 和 PINC 以及 BDMA_CPARx 寄存器定义，这在存储器到存储器模式下同样有效。源端属性由 MSIZE 和 MINC 以及 BDMA_CM0/1ARx 寄存器定义，这在外设到外设模式下同样有效。注意：此位由软件置位和清零。通道使能（EN = 1）时不得写入此位。通道使能（EN = 1）时此位为只读。</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>B_0x0</name>
                  <description>从外设读取</description>
                  <value>0x0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>B_0x1</name>
                  <description>从存储器读取</description>
                  <value>0x1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>CIRC</name>
              <description>循环模式。注意：此位由软件置位和清零。通道使能（EN = 1）时不得写入此位。通道使能（EN = 1）时此位并非只读。</description>
              <bitOffset>5</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>B_0x0</name>
                  <description>禁止</description>
                  <value>0x0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>B_0x1</name>
                  <description>使能</description>
                  <value>0x1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>PINC</name>
