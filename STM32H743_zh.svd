              <description>备份寄存器</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>RTC_BKP29R</name>
          <displayName>RTC_BKP29R</displayName>
          <description>RTC backup registers</description>
          <addressOffset>0xC4</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>BKP</name>
              <description>备份寄存器</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>RTC_BKP30R</name>
          <displayName>RTC_BKP30R</displayName>
          <description>RTC backup registers</description>
          <addressOffset>0xC8</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>BKP</name>
              <description>备份寄存器</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>RTC_BKP31R</name>
          <displayName>RTC_BKP31R</displayName>
          <description>RTC backup registers</description>
          <addressOffset>0xCC</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>BKP</name>
              <description>备份寄存器</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
      </registers>
    </peripheral>
    <peripheral>
      <name>SAI4</name>
      <description>串行音频接口</description>
      <groupName>SAI</groupName>
      <baseAddress>0x58005400</baseAddress>
      <addressBlock>
        <offset>0x0</offset>
        <size>0x400</size>
        <usage>registers</usage>
      </addressBlock>
      <interrupt>
        <name>SAI4</name>
        <description>SAI4 全局中断</description>
        <value>146</value>
      </interrupt>
      <registers>
        <register>
          <name>SAI_GCR</name>
          <displayName>SAI_GCR</displayName>
          <description>全局配置寄存器</description>
          <addressOffset>0x0</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>SYNCOUT</name>
              <description>同步输出。这些位由软件置位或清零。</description>
              <bitOffset>4</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>SYNCIN</name>
              <description>同步输入</description>
              <bitOffset>0</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>SAI_ACR1</name>
          <displayName>SAI_ACR1</displayName>
          <description>配置寄存器 1</description>
          <addressOffset>0x4</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000040</resetValue>
          <fields>
            <field>
              <name>MODE</name>
              <description>SAIx 音频模块模式</description>
              <bitOffset>0</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>PRTCFG</name>
              <description>协议配置。这些位由软件置位或清零。须在音频模块禁用时进行配置。</description>
              <bitOffset>2</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>DS</name>
              <description>数据位宽。这些位由软件置位或清零。当选择 SPDIF 协议时（PRTCFG[1:0] 位），由于帧长和数据位宽在此模式下是固定的，这些位将被忽略。当通过 COMP[1:0] 位选择压扩模式时，DS[1:0] 也将被忽略，因为算法已将数据位宽固定为 8 位。须在音频模块禁用时进行配置。</description>
              <bitOffset>5</bitOffset>
              <bitWidth>3</bitWidth>
            </field>
            <field>
              <name>LSBFIRST</name>
              <description>最低有效位优先。该位由软件置位或清零。须在音频模块禁用时进行配置。该位在 AC97 音频协议中无意义，因为 AC97 数据始终以 MSB 优先传输。该位在 SPDIF 音频协议中也无意义，因为 SPDIF 数据始终以 LSB 优先传输。</description>
              <bitOffset>8</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CKSTR</name>
              <description>时钟选通边沿。该位由软件置位或清零。须在音频模块禁用时进行配置。该位在 SPDIF 音频协议中无意义。</description>
              <bitOffset>9</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>SYNCEN</name>
              <description>同步使能。这些位由软件置位或清零。须在音频子模块禁用时进行配置。注意：当 SPDIF 模式使能时，音频子模块应配置为异步模式。</description>
              <bitOffset>10</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>MONO</name>
              <description>单声道模式。该位由软件置位或清零。仅当时隙数量等于 2 时有效。当选择单声道模式时，若音频模块作为发送器工作，时隙 0 的数据将复制到时隙 1。在接收模式下，时隙 1 被丢弃，仅存储从时隙 0 接收到的数据。更多细节请参考章节：单声道/立体声模式。</description>
              <bitOffset>12</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>OUTDRIV</name>
              <description>输出驱动。该位由软件置位或清零。注意：该位须在使能音频模块之前、完成音频模块配置之后置位。</description>
              <bitOffset>13</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>SAIXEN</name>
              <description>音频模块使能（x 为 A 或 B）。该位由软件置位。若要关闭音频模块，应用软件须将此位写为 0 并轮询该位直至回读为 0，表示模块已完全禁用。在将此位置 1 之前，请确认其为 0，否则使能命令不会被响应。该位用于控制 SAIx 音频模块的状态。若在音频帧传输进行中将其禁用，则正在进行的传输将完成，并在该音频帧传输结束后完全禁用该单元。注意：当 SAIx 模块配置为主模式时，须在 SAIXEN 位置位之前确保 SAIx 输入端已有时钟信号。</description>
              <bitOffset>16</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DMAEN</name>
              <description>DMA 使能。该位由软件置位或清零。注意：由于复位后音频模块默认作为发送器工作，因此在置位 DMAEN 之前须先配置 MODE[1:0] 位，以避免在接收模式下产生 DMA 请求。</description>
              <bitOffset>17</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>NOMCK</name>
              <description>无分频器</description>
              <bitOffset>19</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>MCKDIV</name>
              <description>主时钟分频器。这些位由软件置位或清零。当音频模块工作在从模式时，这些位无意义。须在音频模块禁用时进行配置。其他：主时钟频率按以下公式计算：</description>
              <bitOffset>20</bitOffset>
              <bitWidth>4</bitWidth>
            </field>
            <field>
              <name>OSR</name>
              <description>主时钟过采样比</description>
              <bitOffset>26</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>SAI_ACR2</name>
          <displayName>SAI_ACR2</displayName>
          <description>配置寄存器 2</description>
          <addressOffset>0x8</addressOffset>
          <size>0x20</size>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>FTH</name>
              <description>FIFO 阈值。该位由软件置位或清零。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>3</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>FFLUSH</name>
              <description>FIFO 刷新。该位由软件置位。读取时始终返回 0。该位应在 SAI 禁用时配置。</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
              <access>write-only</access>
            </field>
            <field>
              <name>TRIS</name>
              <description>数据线三态管理。该位由软件置位或清零。仅当音频模块配置为发送器时有效。当音频模块配置为 SPDIF 模式时不使用该位。应在 SAI 禁用时配置。更多细节请参考章节：非活跃时隙的输出数据线管理。</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>MUTE</name>
              <description>静音。该位由软件置位或清零。仅当音频模块作为发送器工作时有效。若时隙数量小于或等于 2，MUTE 的值与 MUTEVAL 的值关联；若时隙数量大于 2，则等于 0。更多细节请参考章节：静音模式。注意：该位对 SPDIF 音频模块无意义，不应使用。</description>
              <bitOffset>5</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>MUTEVAL</name>
              <description>静音值。该位由软件置位或清零。须在使能音频模块（SAIXEN）之前写入。仅当音频模块作为发送器工作、时隙数量小于或等于 2 且 MUTE 位置位时有效。若声明了更多时隙，在静音模式下发送的位值始终为 0，无论 MUTEVAL 的值如何。若时隙数量小于或等于 2 且 MUTEVAL = 1，则每个时隙发送的静音值为前一帧中对应时隙的值。更多细节请参考章节：静音模式。注意：该位对 SPDIF 音频模块无意义，不应使用。</description>
              <bitOffset>6</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>MUTECNT</name>
              <description>静音计数器。这些位由软件置位或清零。仅在接收模式下使用。这些位中设置的值用于与接收中检测到的连续静音帧数量进行比较。当静音帧数量等于此值时，标志位 MUTEDET 将置位，若 MUTEDETIE 位已使能则会产生中断。更多细节请参考章节：静音模式。</description>
              <bitOffset>7</bitOffset>
              <bitWidth>6</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>CPL</name>
              <description>补码位。该位由软件置位或清零。用于定义压扩模式中所使用的补码类型。注意：该位仅在压扩模式为 μ-Law 算法或 A-Law 算法时有效。</description>
              <bitOffset>13</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>COMP</name>
              <description>压扩模式。这些位由软件置位或清零。μ-Law 和 A-Law 对数压扩是 CCITT G.711 建议的一部分，所使用的补码类型取决于 CPL 位。数据扩展或数据压缩由 MODE[0] 位的状态决定。若音频模块配置为发送器，则进行数据压缩。若音频模块配置为接收器，则自动进行数据扩展。更多细节请参考章节：压扩模式。注意：压扩模式仅在选择 TDM 时适用。</description>
              <bitOffset>14</bitOffset>
              <bitWidth>2</bitWidth>
              <access>read-write</access>
            </field>
          </fields>
        </register>
        <register>
          <name>SAI_AFRCR</name>
          <displayName>SAI_AFRCR</displayName>
          <description>该寄存器在 AC97 和 SPDIF 音频协议中无意义</description>
          <addressOffset>0xC</addressOffset>
          <size>0x20</size>
          <resetValue>0x00000007</resetValue>
          <fields>
            <field>
              <name>FRL</name>
              <description>帧长。这些位由软件置位或清零。用于定义以 SCK 时钟周期数表示的音频帧长度：帧中的位数等于 FRL[7:0] + 1。音频帧中传输的最小位数必须为 8，否则音频模块将出现异常行为。例如，当数据位宽为 8 位且在 SAI_xSLOTR 寄存器中仅定义了一个时隙 0（NBSLOT[3:0] = 0000）时，就属于最小位数不足的情况。在主模式下，若使用了主时钟（可通过 MCLK_x 引脚获取），帧长应对齐到一个 2 的幂次数，范围为 8 到 256。当不使用主时钟时（NODIV = 1），建议将帧长配置为 8 到 256 之间的值。这些位在 AC97 或 SPDIF 音频模块配置中无意义且不被使用。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>8</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>FSALL</name>
              <description>帧同步有效电平长度。这些位由软件置位或清零。用于指定 FS 信号在音频帧中有效电平的位时钟（SCK）周期数 + 1（FSALL[6:0] + 1）。这些位在 AC97 或 SPDIF 音频模块配置中无意义且不被使用。须在音频模块禁用时进行配置。</description>
              <bitOffset>8</bitOffset>
              <bitWidth>7</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>FSDEF</name>
              <description>帧同步定义。该位由软件置位或清零。当该位置位时，SAI_xSLOTR 寄存器中定义的时隙数量必须为偶数。这意味着其中一半时隙将分配给左声道，另一半分配给右声道（例如：对于 I2S 或 MSB/LSB 对齐协议，此位须置位）。该位在 AC97 或 SPDIF 音频模块配置中无意义且不被使用。须在音频模块禁用时进行配置。</description>
              <bitOffset>16</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>FSPOL</name>
              <description>帧同步极性。该位由软件置位或清零。用于配置 FS 信号上帧起始的电平。该位在 AC97 或 SPDIF 音频模块配置中无意义且不被使用。须在音频模块禁用时进行配置。</description>
              <bitOffset>17</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>FSOFF</name>
              <description>帧同步偏移。该位由软件置位或清零。该位在 AC97 或 SPDIF 音频模块配置中无意义且不被使用。须在音频模块禁用时进行配置。</description>
              <bitOffset>18</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
          </fields>
        </register>
        <register>
          <name>SAI_ASLOTR</name>
          <displayName>SAI_ASLOTR</displayName>
          <description>该寄存器在 AC97 和 SPDIF 音频协议中无意义</description>
          <addressOffset>0x10</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>FBOFF</name>
              <description>首比特偏移。这些位由软件置位或清零。该位域的值定义了时隙中第一个数据传输位的位置，表示一个偏移量。在发送模式下，数据字段之外的位被强制置为 0。在接收模式下，多余的接收位将被丢弃。须在音频模块禁用时设置这些位。在 AC97 或 SPDIF 模式下将被忽略。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>5</bitWidth>
            </field>
            <field>
              <name>SLOTSZ</name>
              <description>时隙大小。这些位由软件置位或清零。时隙大小必须大于或等于数据位宽。若不满足此条件，SAI 的行为将是不确定的。有关如何驱动 SD 线的信息，请参考章节：非活跃时隙的输出数据线管理。须在音频模块禁用时设置这些位。在 AC97 或 SPDIF 模式下将被忽略。</description>
              <bitOffset>6</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>NBSLOT</name>
              <description>音频帧中的时隙数。这些位由软件置位或清零。该位域的值表示音频帧中的时隙数 + 1（包括非活跃时隙）。最大时隙数为 16。若 SAI_xFRCR 寄存器中的 FSDEF 位置位，时隙数应为偶数。须在音频模块禁用时配置时隙数。在 AC97 或 SPDIF 模式下将被忽略。</description>
              <bitOffset>8</bitOffset>
              <bitWidth>4</bitWidth>
            </field>
            <field>
              <name>SLOTEN</name>
              <description>时隙使能。这些位由软件置位或清零。每个 SLOTEN 位对应一个时隙位置，从 0 到 15（最多 16 个时隙）。须在音频模块禁用时使能时隙。在 AC97 或 SPDIF 模式下将被忽略。</description>
              <bitOffset>16</bitOffset>
              <bitWidth>16</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>SAI_AIM</name>
          <displayName>SAI_AIM</displayName>
          <description>中断屏蔽寄存器 2</description>
          <addressOffset>0x14</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>OVRUDRIE</name>
              <description>溢出/欠载中断使能。该位由软件置位或清零。当该位置位时，若 SAI_xSR 寄存器中的 OVRUDR 位置位，则产生中断。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>MUTEDETIE</name>
              <description>静音检测中断使能。该位由软件置位或清零。当该位置位时，若 SAI_xSR 寄存器中的 MUTEDET 位置位，则产生中断。该位仅在音频模块配置为接收模式时有效。</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>WCKCFGIE</name>
              <description>时钟配置错误中断使能。该位由软件置位或清零。仅在音频模块配置为主模式（MODE[1] = 0）且 NODIV = 0 时才被响应。若 SAI_xSR 寄存器中的 WCKCFG 标志位置位，则产生中断。注意：该位仅在 TDM 模式下使用，在其他模式下无意义。</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>FREQIE</name>
              <description>FIFO 请求中断使能。该位由软件置位或清零。当该位置位时，若 SAI_xSR 寄存器中的 FREQ 位置位，则产生中断。由于复位后音频模块默认作为发送器工作，因此在置位 FREQIE 之前须先配置 MODE 位，以避免在接收模式下产生误中断。</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CNRDYIE</name>
              <description>编解码器未就绪中断使能（AC97）。该位由软件置位或清零。当中断使能时，音频模块在 AC97 帧的时隙 0（tag0）中检测连接到该线路的编解码器是否就绪。若未就绪，SAI_xSR 寄存器中的 CNRDY 标志位将置位并产生中断。该位仅当通过 PRTCFG[1:0] 位选择 AC97 模式且音频模块作为接收器工作时有效。</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>AFSDETIE</name>
              <description>帧同步提前检测中断使能。该位由软件置位或清零。当该位置位时，若 SAI_xSR 寄存器中的 AFSDET 位置位，则产生中断。该位在 AC97、SPDIF 模式或音频模块作为主模式工作时无意义。</description>
              <bitOffset>5</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>LFSDETIE</name>
              <description>帧同步滞后检测中断使能。该位由软件置位或清零。当该位置位时，若 SAI_xSR 寄存器中的 LFSDET 位置位，则产生中断。该位在 AC97、SPDIF 模式或音频模块作为主模式工作时无意义。</description>
              <bitOffset>6</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>SAI_ASR</name>
          <displayName>SAI_ASR</displayName>
          <description>状态寄存器</description>
          <addressOffset>0x18</addressOffset>
          <size>0x20</size>
          <access>read-only</access>
          <resetValue>0x00000008</resetValue>
          <fields>
            <field>
              <name>OVRUDR</name>
              <description>溢出/欠载。该位为只读。溢出和欠载状态分别仅在音频模块配置为接收器和发送器时才会发生。若 SAI_xIM 寄存器中的 OVRUDRIE 位置位，可产生中断。当软件将 SAI_xCLRFR 寄存器中的 COVRUDR 位置位时，该标志位被清除。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>MUTEDET</name>
              <description>静音检测。该位为只读。若在给定音频帧的每个时隙中连续接收到 0 值，且持续了连续的音频帧数（由 SAI_xCR2 寄存器中的 MUTECNT 位设置），则该标志位置位。若 SAI_xIM 寄存器中的 MUTEDETIE 位置位，可产生中断。当软件将 SAI_xCLRFR 寄存器中的 CMUTEDET 位置位时，该标志位被清除。</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>WCKCFG</name>
              <description>时钟配置错误标志位。该位为只读。仅在音频模块工作于主模式（MODE[1] = 0）且 NODIV = 0 时使用。若 SAI_xIM 寄存器中的 WCKCFGIE 位置位，可产生中断。当软件将 SAI_xCLRFR 寄存器中的 CWCKCFG 位置位时，该标志位被清除。</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>FREQ</name>
              <description>FIFO 请求。该位为只读。请求取决于音频模块的配置：若模块配置为发送模式，FIFO 请求关联到对 SAI_xDR 的写请求操作。若模块配置为接收模式，FIFO 请求关联到从 SAI_xDR 的读请求操作。若 SAI_xIM 寄存器中的 FREQIE 位置位，该标志位可产生中断。</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CNRDY</name>
              <description>编解码器未就绪。该位为只读。仅在 SAI_xCR1 寄存器中选择了 AC97 音频协议且配置为接收模式时使用。若 SAI_xIM 寄存器中的 CNRDYIE 位置位，可产生中断。当软件将 SAI_xCLRFR 寄存器中的 CCNRDY 位置位时，该标志位被清除。</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>AFSDET</name>
              <description>帧同步提前检测。该位为只读。仅在音频模块配置为从模式时该标志位才可置位。在 AC97 或 SPDIF 模式下不使用。若 SAI_xIM 寄存器中的 AFSDETIE 位置位，可产生中断。当软件将 SAI_xCLRFR 寄存器中的 CAFSDET 位置位时，该标志位被清除。</description>
              <bitOffset>5</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>LFSDET</name>
              <description>帧同步滞后检测。该位为只读。仅在音频模块配置为从模式时该标志位才可置位。在 AC97 或 SPDIF 模式下不使用。若 SAI_xIM 寄存器中的 LFSDETIE 位置位，可产生中断。当软件将 SAI_xCLRFR 寄存器中的 CLFSDET 位置位时，该标志位被清除。</description>
              <bitOffset>6</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>FLVL</name>
              <description>FIFO 电平阈值。该位为只读。FIFO 电平阈值标志位仅由硬件管理，其设置取决于 SAI 模块的配置（发送或接收模式）。若 SAI 模块配置为发送器：若 SAI 模块配置为接收器：</description>
              <bitOffset>16</bitOffset>
              <bitWidth>3</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>SAI_ACLRFR</name>
          <displayName>SAI_ACLRFR</displayName>
          <description>清除标志寄存器</description>
          <addressOffset>0x1C</addressOffset>
          <size>0x20</size>
          <access>write-only</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>COVRUDR</name>
              <description>清除溢出/欠载标志。该位为只写。将此位写 1 可清除 SAI_xSR 寄存器中的 OVRUDR 标志位。读取该位始终返回 0。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CMUTEDET</name>
              <description>清除静音检测标志。该位为只写。将此位写 1 可清除 SAI_xSR 寄存器中的 MUTEDET 标志位。读取该位始终返回 0。</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CWCKCFG</name>
              <description>清除时钟配置错误标志。该位为只写。将此位写 1 可清除 SAI_xSR 寄存器中的 WCKCFG 标志位。仅在音频模块设置为主模式（MODE[1] = 0）且 SAI_xCR1 寄存器中 NODIV = 0 时使用。读取该位始终返回 0。</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CCNRDY</name>
              <description>清除编解码器未就绪标志。该位为只写。将此位写 1 可清除 SAI_xSR 寄存器中的 CNRDY 标志位。仅在 SAI_xCR1 寄存器中选择了 AC97 音频协议时使用。读取该位始终返回 0。</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CAFSDET</name>
              <description>清除帧同步提前检测标志。该位为只写。将此位写 1 可清除 SAI_xSR 寄存器中的 AFSDET 标志位。在 AC97 或 SPDIF 模式下不使用。读取该位始终返回 0。</description>
              <bitOffset>5</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CLFSDET</name>
              <description>清除帧同步滞后检测标志。该位为只写。将此位写 1 可清除 SAI_xSR 寄存器中的 LFSDET 标志位。在 AC97 或 SPDIF 模式下不使用。读取该位始终返回 0。</description>
              <bitOffset>6</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>SAI_ADR</name>
          <displayName>SAI_ADR</displayName>
          <description>数据寄存器</description>
          <addressOffset>0x20</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>DATA</name>
              <description>数据。向该寄存器写入数据时，若 FIFO 未满，则将数据加载到 FIFO 中。从该寄存器读取数据时，若 FIFO 非空，则清空 FIFO 中的一项。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>SAI_BCR1</name>
          <displayName>SAI_BCR1</displayName>
          <description>配置寄存器 1</description>
          <addressOffset>0x24</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000040</resetValue>
          <fields>
            <field>
              <name>MODE</name>
              <description>SAIx 音频模块模式</description>
              <bitOffset>0</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>PRTCFG</name>
              <description>协议配置。这些位由软件置位或清零。须在音频模块禁用时进行配置。</description>
              <bitOffset>2</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>DS</name>
              <description>数据位宽。这些位由软件置位或清零。当选择 SPDIF 协议时（PRTCFG[1:0] 位），由于帧长和数据位宽在此模式下是固定的，这些位将被忽略。当通过 COMP[1:0] 位选择压扩模式时，DS[1:0] 也将被忽略，因为算法已将数据位宽固定为 8 位。须在音频模块禁用时进行配置。</description>
              <bitOffset>5</bitOffset>
              <bitWidth>3</bitWidth>
            </field>
            <field>
              <name>LSBFIRST</name>
              <description>最低有效位优先。该位由软件置位或清零。须在音频模块禁用时进行配置。该位在 AC97 音频协议中无意义，因为 AC97 数据始终以 MSB 优先传输。该位在 SPDIF 音频协议中也无意义，因为 SPDIF 数据始终以 LSB 优先传输。</description>
              <bitOffset>8</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CKSTR</name>
              <description>时钟选通边沿。该位由软件置位或清零。须在音频模块禁用时进行配置。该位在 SPDIF 音频协议中无意义。</description>
              <bitOffset>9</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>SYNCEN</name>
              <description>同步使能。这些位由软件置位或清零。须在音频子模块禁用时进行配置。注意：当 SPDIF 模式使能时，音频子模块应配置为异步模式。</description>
              <bitOffset>10</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>MONO</name>
              <description>单声道模式。该位由软件置位或清零。仅当时隙数量等于 2 时有效。当选择单声道模式时，若音频模块作为发送器工作，时隙 0 的数据将复制到时隙 1。在接收模式下，时隙 1 被丢弃，仅存储从时隙 0 接收到的数据。更多细节请参考章节：单声道/立体声模式。</description>
              <bitOffset>12</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>OUTDRIV</name>
              <description>输出驱动。该位由软件置位或清零。注意：该位须在使能音频模块之前、完成音频模块配置之后置位。</description>
              <bitOffset>13</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>SAIXEN</name>
              <description>音频模块使能（x 为 A 或 B）。该位由软件置位。若要关闭音频模块，应用软件须将此位写为 0 并轮询该位直至回读为 0，表示模块已完全禁用。在将此位置 1 之前，请确认其为 0，否则使能命令不会被响应。该位用于控制 SAIx 音频模块的状态。若在音频帧传输进行中将其禁用，则正在进行的传输将完成，并在该音频帧传输结束后完全禁用该单元。注意：当 SAIx 模块配置为主模式时，须在 SAIXEN 位置位之前确保 SAIx 输入端已有时钟信号。</description>
              <bitOffset>16</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DMAEN</name>
              <description>DMA 使能。该位由软件置位或清零。注意：由于复位后音频模块默认作为发送器工作，因此在置位 DMAEN 之前须先配置 MODE[1:0] 位，以避免在接收模式下产生 DMA 请求。</description>
              <bitOffset>17</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>NOMCK</name>
              <description>无分频器</description>
              <bitOffset>19</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>MCKDIV</name>
              <description>主时钟分频器。这些位由软件置位或清零。当音频模块工作在从模式时，这些位无意义。须在音频模块禁用时进行配置。其他：主时钟频率按以下公式计算：</description>
              <bitOffset>20</bitOffset>
              <bitWidth>4</bitWidth>
            </field>
            <field>
              <name>OSR</name>
              <description>主时钟过采样比</description>
              <bitOffset>26</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>SAI_BCR2</name>
          <displayName>SAI_BCR2</displayName>
          <description>配置寄存器 2</description>
          <addressOffset>0x28</addressOffset>
          <size>0x20</size>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>FTH</name>
              <description>FIFO 阈值。该位由软件置位或清零。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>3</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>FFLUSH</name>
              <description>FIFO 刷新。该位由软件置位。读取时始终返回 0。该位应在 SAI 禁用时配置。</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
              <access>write-only</access>
            </field>
            <field>
              <name>TRIS</name>
              <description>数据线三态管理。该位由软件置位或清零。仅当音频模块配置为发送器时有效。当音频模块配置为 SPDIF 模式时不使用该位。应在 SAI 禁用时配置。更多细节请参考章节：非活跃时隙的输出数据线管理。</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>MUTE</name>
              <description>静音。该位由软件置位或清零。仅当音频模块作为发送器工作时有效。若时隙数量小于或等于 2，MUTE 的值与 MUTEVAL 的值关联；若时隙数量大于 2，则等于 0。更多细节请参考章节：静音模式。注意：该位对 SPDIF 音频模块无意义，不应使用。</description>
              <bitOffset>5</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>MUTEVAL</name>
              <description>静音值。该位由软件置位或清零。须在使能音频模块（SAIXEN）之前写入。仅当音频模块作为发送器工作、时隙数量小于或等于 2 且 MUTE 位置位时有效。若声明了更多时隙，在静音模式下发送的位值始终为 0，无论 MUTEVAL 的值如何。若时隙数量小于或等于 2 且 MUTEVAL = 1，则每个时隙发送的静音值为前一帧中对应时隙的值。更多细节请参考章节：静音模式。注意：该位对 SPDIF 音频模块无意义，不应使用。</description>
              <bitOffset>6</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>MUTECNT</name>
              <description>静音计数器。这些位由软件置位或清零。仅在接收模式下使用。这些位中设置的值用于与接收中检测到的连续静音帧数量进行比较。当静音帧数量等于此值时，标志位 MUTEDET 将置位，若 MUTEDETIE 位已使能则会产生中断。更多细节请参考章节：静音模式。</description>
              <bitOffset>7</bitOffset>
              <bitWidth>6</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>CPL</name>
              <description>补码位。该位由软件置位或清零。用于定义压扩模式中所使用的补码类型。注意：该位仅在压扩模式为 μ-Law 算法或 A-Law 算法时有效。</description>
              <bitOffset>13</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>COMP</name>
              <description>压扩模式。这些位由软件置位或清零。μ-Law 和 A-Law 对数压扩是 CCITT G.711 建议的一部分，所使用的补码类型取决于 CPL 位。数据扩展或数据压缩由 MODE[0] 位的状态决定。若音频模块配置为发送器，则进行数据压缩。若音频模块配置为接收器，则自动进行数据扩展。更多细节请参考章节：压扩模式。注意：压扩模式仅在选择 TDM 时适用。</description>
              <bitOffset>14</bitOffset>
              <bitWidth>2</bitWidth>
              <access>read-write</access>
            </field>
          </fields>
        </register>
        <register>
          <name>SAI_BFRCR</name>
          <displayName>SAI_BFRCR</displayName>
          <description>该寄存器在 AC97 和 SPDIF 音频协议中无意义</description>
          <addressOffset>0x2C</addressOffset>
          <size>0x20</size>
          <resetValue>0x00000007</resetValue>
          <fields>
            <field>
              <name>FRL</name>
              <description>帧长。这些位由软件置位或清零。用于定义以 SCK 时钟周期数表示的音频帧长度：帧中的位数等于 FRL[7:0] + 1。音频帧中传输的最小位数必须为 8，否则音频模块将出现异常行为。例如，当数据位宽为 8 位且在 SAI_xSLOTR 寄存器中仅定义了一个时隙 0（NBSLOT[3:0] = 0000）时，就属于最小位数不足的情况。在主模式下，若使用了主时钟（可通过 MCLK_x 引脚获取），帧长应对齐到一个 2 的幂次数，范围为 8 到 256。当不使用主时钟时（NODIV = 1），建议将帧长配置为 8 到 256 之间的值。这些位在 AC97 或 SPDIF 音频模块配置中无意义且不被使用。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>8</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>FSALL</name>
              <description>帧同步有效电平长度。这些位由软件置位或清零。用于指定 FS 信号在音频帧中有效电平的位时钟（SCK）周期数 + 1（FSALL[6:0] + 1）。这些位在 AC97 或 SPDIF 音频模块配置中无意义且不被使用。须在音频模块禁用时进行配置。</description>
              <bitOffset>8</bitOffset>
              <bitWidth>7</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>FSDEF</name>
              <description>帧同步定义。该位由软件置位或清零。当该位置位时，SAI_xSLOTR 寄存器中定义的时隙数量必须为偶数。这意味着其中一半时隙将分配给左声道，另一半分配给右声道（例如：对于 I2S 或 MSB/LSB 对齐协议，此位须置位）。该位在 AC97 或 SPDIF 音频模块配置中无意义且不被使用。须在音频模块禁用时进行配置。</description>
              <bitOffset>16</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>FSPOL</name>
              <description>帧同步极性。该位由软件置位或清零。用于配置 FS 信号上帧起始的电平。该位在 AC97 或 SPDIF 音频模块配置中无意义且不被使用。须在音频模块禁用时进行配置。</description>
              <bitOffset>17</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>FSOFF</name>
              <description>帧同步偏移。该位由软件置位或清零。该位在 AC97 或 SPDIF 音频模块配置中无意义且不被使用。须在音频模块禁用时进行配置。</description>
              <bitOffset>18</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
          </fields>
        </register>
        <register>
          <name>SAI_BSLOTR</name>
          <displayName>SAI_BSLOTR</displayName>
          <description>该寄存器在 AC97 和 SPDIF 音频协议中无意义</description>
          <addressOffset>0x30</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>FBOFF</name>
              <description>首比特偏移。这些位由软件置位或清零。该位域的值定义了时隙中第一个数据传输位的位置，表示一个偏移量。在发送模式下，数据字段之外的位被强制置为 0。在接收模式下，多余的接收位将被丢弃。须在音频模块禁用时设置这些位。在 AC97 或 SPDIF 模式下将被忽略。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>5</bitWidth>
            </field>
            <field>
              <name>SLOTSZ</name>
              <description>时隙大小。这些位由软件置位或清零。时隙大小必须大于或等于数据位宽。若不满足此条件，SAI 的行为将是不确定的。有关如何驱动 SD 线的信息，请参考章节：非活跃时隙的输出数据线管理。须在音频模块禁用时设置这些位。在 AC97 或 SPDIF 模式下将被忽略。</description>
              <bitOffset>6</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>NBSLOT</name>
              <description>音频帧中的时隙数。这些位由软件置位或清零。该位域的值表示音频帧中的时隙数 + 1（包括非活跃时隙）。最大时隙数为 16。若 SAI_xFRCR 寄存器中的 FSDEF 位置位，时隙数应为偶数。须在音频模块禁用时配置时隙数。在 AC97 或 SPDIF 模式下将被忽略。</description>
              <bitOffset>8</bitOffset>
              <bitWidth>4</bitWidth>
            </field>
            <field>
              <name>SLOTEN</name>
              <description>时隙使能。这些位由软件置位或清零。每个 SLOTEN 位对应一个时隙位置，从 0 到 15（最多 16 个时隙）。须在音频模块禁用时使能时隙。在 AC97 或 SPDIF 模式下将被忽略。</description>
              <bitOffset>16</bitOffset>
              <bitWidth>16</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>SAI_BIM</name>
          <displayName>SAI_BIM</displayName>
          <description>中断屏蔽寄存器 2</description>
          <addressOffset>0x34</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>OVRUDRIE</name>
              <description>溢出/欠载中断使能。该位由软件置位或清零。当该位置位时，若 SAI_xSR 寄存器中的 OVRUDR 位置位，则产生中断。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>MUTEDETIE</name>
              <description>静音检测中断使能。该位由软件置位或清零。当该位置位时，若 SAI_xSR 寄存器中的 MUTEDET 位置位，则产生中断。该位仅在音频模块配置为接收模式时有效。</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>WCKCFGIE</name>
              <description>时钟配置错误中断使能。该位由软件置位或清零。仅在音频模块配置为主模式（MODE[1] = 0）且 NODIV = 0 时才被响应。若 SAI_xSR 寄存器中的 WCKCFG 标志位置位，则产生中断。注意：该位仅在 TDM 模式下使用，在其他模式下无意义。</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>FREQIE</name>
              <description>FIFO 请求中断使能。该位由软件置位或清零。当该位置位时，若 SAI_xSR 寄存器中的 FREQ 位置位，则产生中断。由于复位后音频模块默认作为发送器工作，因此在置位 FREQIE 之前须先配置 MODE 位，以避免在接收模式下产生误中断。</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CNRDYIE</name>
              <description>编解码器未就绪中断使能（AC97）。该位由软件置位或清零。当中断使能时，音频模块在 AC97 帧的时隙 0（tag0）中检测连接到该线路的编解码器是否就绪。若未就绪，SAI_xSR 寄存器中的 CNRDY 标志位将置位并产生中断。该位仅当通过 PRTCFG[1:0] 位选择 AC97 模式且音频模块作为接收器工作时有效。</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>AFSDETIE</name>
              <description>帧同步提前检测中断使能。该位由软件置位或清零。当该位置位时，若 SAI_xSR 寄存器中的 AFSDET 位置位，则产生中断。该位在 AC97、SPDIF 模式或音频模块作为主模式工作时无意义。</description>
              <bitOffset>5</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>LFSDETIE</name>
              <description>帧同步滞后检测中断使能。该位由软件置位或清零。当该位置位时，若 SAI_xSR 寄存器中的 LFSDET 位置位，则产生中断。该位在 AC97、SPDIF 模式或音频模块作为主模式工作时无意义。</description>
              <bitOffset>6</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>SAI_BSR</name>
          <displayName>SAI_BSR</displayName>
          <description>状态寄存器</description>
          <addressOffset>0x38</addressOffset>
          <size>0x20</size>
          <access>read-only</access>
          <resetValue>0x00000008</resetValue>
          <fields>
            <field>
              <name>OVRUDR</name>
              <description>溢出/欠载。该位为只读。溢出和欠载状态分别仅在音频模块配置为接收器和发送器时才会发生。若 SAI_xIM 寄存器中的 OVRUDRIE 位置位，可产生中断。当软件将 SAI_xCLRFR 寄存器中的 COVRUDR 位置位时，该标志位被清除。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>MUTEDET</name>
              <description>静音检测。该位为只读。若在给定音频帧的每个时隙中连续接收到 0 值，且持续了连续的音频帧数（由 SAI_xCR2 寄存器中的 MUTECNT 位设置），则该标志位置位。若 SAI_xIM 寄存器中的 MUTEDETIE 位置位，可产生中断。当软件将 SAI_xCLRFR 寄存器中的 CMUTEDET 位置位时，该标志位被清除。</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>WCKCFG</name>
              <description>时钟配置错误标志位。该位为只读。仅在音频模块工作于主模式（MODE[1] = 0）且 NODIV = 0 时使用。若 SAI_xIM 寄存器中的 WCKCFGIE 位置位，可产生中断。当软件将 SAI_xCLRFR 寄存器中的 CWCKCFG 位置位时，该标志位被清除。</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>FREQ</name>
              <description>FIFO 请求。该位为只读。请求取决于音频模块的配置：若模块配置为发送模式，FIFO 请求关联到对 SAI_xDR 的写请求操作。若模块配置为接收模式，FIFO 请求关联到从 SAI_xDR 的读请求操作。若 SAI_xIM 寄存器中的 FREQIE 位置位，该标志位可产生中断。</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CNRDY</name>
              <description>编解码器未就绪。该位为只读。仅在 SAI_xCR1 寄存器中选择了 AC97 音频协议且配置为接收模式时使用。若 SAI_xIM 寄存器中的 CNRDYIE 位置位，可产生中断。当软件将 SAI_xCLRFR 寄存器中的 CCNRDY 位置位时，该标志位被清除。</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>AFSDET</name>
              <description>帧同步提前检测。该位为只读。仅在音频模块配置为从模式时该标志位才可置位。在 AC97 或 SPDIF 模式下不使用。若 SAI_xIM 寄存器中的 AFSDETIE 位置位，可产生中断。当软件将 SAI_xCLRFR 寄存器中的 CAFSDET 位置位时，该标志位被清除。</description>
              <bitOffset>5</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>LFSDET</name>
              <description>帧同步滞后检测。该位为只读。仅在音频模块配置为从模式时该标志位才可置位。在 AC97 或 SPDIF 模式下不使用。若 SAI_xIM 寄存器中的 LFSDETIE 位置位，可产生中断。当软件将 SAI_xCLRFR 寄存器中的 CLFSDET 位置位时，该标志位被清除。</description>
              <bitOffset>6</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>FLVL</name>
              <description>FIFO 电平阈值。该位为只读。FIFO 电平阈值标志位仅由硬件管理，其设置取决于 SAI 模块的配置（发送或接收模式）。若 SAI 模块配置为发送器：若 SAI 模块配置为接收器：</description>
              <bitOffset>16</bitOffset>
              <bitWidth>3</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>SAI_BCLRFR</name>
          <displayName>SAI_BCLRFR</displayName>
          <description>清除标志寄存器</description>
          <addressOffset>0x3C</addressOffset>
          <size>0x20</size>
          <access>write-only</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>COVRUDR</name>
              <description>清除溢出/欠载标志。该位为只写。将此位写 1 可清除 SAI_xSR 寄存器中的 OVRUDR 标志位。读取该位始终返回 0。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CMUTEDET</name>
              <description>清除静音检测标志。该位为只写。将此位写 1 可清除 SAI_xSR 寄存器中的 MUTEDET 标志位。读取该位始终返回 0。</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CWCKCFG</name>
              <description>清除时钟配置错误标志。该位为只写。将此位写 1 可清除 SAI_xSR 寄存器中的 WCKCFG 标志位。仅在音频模块设置为主模式（MODE[1] = 0）且 SAI_xCR1 寄存器中 NODIV = 0 时使用。读取该位始终返回 0。</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CCNRDY</name>
              <description>清除编解码器未就绪标志。该位为只写。将此位写 1 可清除 SAI_xSR 寄存器中的 CNRDY 标志位。仅在 SAI_xCR1 寄存器中选择了 AC97 音频协议时使用。读取该位始终返回 0。</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CAFSDET</name>
              <description>清除帧同步提前检测标志。该位为只写。将此位写 1 可清除 SAI_xSR 寄存器中的 AFSDET 标志位。在 AC97 或 SPDIF 模式下不使用。读取该位始终返回 0。</description>
              <bitOffset>5</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CLFSDET</name>
              <description>清除帧同步滞后检测标志。该位为只写。将此位写 1 可清除 SAI_xSR 寄存器中的 LFSDET 标志位。在 AC97 或 SPDIF 模式下不使用。读取该位始终返回 0。</description>
              <bitOffset>6</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>SAI_BDR</name>
          <displayName>SAI_BDR</displayName>
          <description>数据寄存器</description>
          <addressOffset>0x40</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>DATA</name>
              <description>数据。向该寄存器写入数据时，若 FIFO 未满，则将数据加载到 FIFO 中。从该寄存器读取数据时，若 FIFO 非空，则清空 FIFO 中的一项。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>SAI_PDMCR</name>
          <displayName>SAI_PDMCR</displayName>
          <description>PDM 控制寄存器</description>
          <addressOffset>0x44</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>PDMEN</name>
              <description>PDM 使能</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>MICNBR</name>
              <description>麦克风数量</description>
              <bitOffset>4</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>CKEN1</name>
              <description>位流时钟 1 的时钟使能</description>
              <bitOffset>8</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CKEN2</name>
              <description>位流时钟 2 的时钟使能</description>
              <bitOffset>9</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CKEN3</name>
              <description>位流时钟 3 的时钟使能</description>
              <bitOffset>10</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CKEN4</name>
              <description>位流时钟 4 的时钟使能</description>
              <bitOffset>11</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>SAI_PDMDLY</name>
          <displayName>SAI_PDMDLY</displayName>
          <description>PDM 延迟寄存器</description>
          <addressOffset>0x48</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>DLYM1L</name>
              <description>第 1 对麦克风中第一个麦克风的延迟线调整</description>
              <bitOffset>0</bitOffset>
              <bitWidth>3</bitWidth>
            </field>
            <field>
              <name>DLYM1R</name>
              <description>第 1 对麦克风中第二个麦克风的延迟线调整</description>
              <bitOffset>4</bitOffset>
              <bitWidth>3</bitWidth>
            </field>
            <field>
              <name>DLYM2L</name>
              <description>第 2 对麦克风中第一个麦克风的延迟线</description>
              <bitOffset>8</bitOffset>
              <bitWidth>3</bitWidth>
            </field>
            <field>
              <name>DLYM2R</name>
              <description>第 2 对麦克风中第二个麦克风的延迟线</description>
              <bitOffset>12</bitOffset>
              <bitWidth>3</bitWidth>
            </field>
            <field>
              <name>DLYM3L</name>
              <description>第 3 对麦克风中第一个麦克风的延迟线</description>
              <bitOffset>16</bitOffset>
              <bitWidth>3</bitWidth>
            </field>
            <field>
              <name>DLYM3R</name>
              <description>第 3 对麦克风中第二个麦克风的延迟线</description>
              <bitOffset>20</bitOffset>
              <bitWidth>3</bitWidth>
            </field>
            <field>
              <name>DLYM4L</name>
              <description>第 4 对麦克风中第一个麦克风的延迟线</description>
              <bitOffset>24</bitOffset>
              <bitWidth>3</bitWidth>
            </field>
            <field>
              <name>DLYM4R</name>
              <description>第 4 对麦克风中第二个麦克风的延迟线</description>
              <bitOffset>28</bitOffset>
              <bitWidth>3</bitWidth>
            </field>
          </fields>
        </register>
      </registers>
    </peripheral>
    <peripheral derivedFrom="SAI4">
      <name>SAI1</name>
      <baseAddress>0x40015800</baseAddress>
      <interrupt>
        <name>SAI1</name>
        <description>SAI1 global interrupt</description>
        <value>87</value>
      </interrupt>
    </peripheral>
    <peripheral derivedFrom="SAI4">
      <name>SAI2</name>
      <baseAddress>0x40015C00</baseAddress>
      <interrupt>
        <name>SAI2</name>
        <description>SAI2 global interrupt</description>
        <value>91</value>
      </interrupt>
    </peripheral>
    <peripheral derivedFrom="SAI4">
      <name>SAI3</name>
      <baseAddress>0x40016000</baseAddress>
      <interrupt>
        <name>SAI3</name>
        <description>SAI3 global interrupt</description>
        <value>114</value>
      </interrupt>
    </peripheral>
    <peripheral>
      <name>SDMMC1</name>
      <description>SDMMC1</description>
      <groupName>SDMMC</groupName>
      <baseAddress>0x52007000</baseAddress>
      <addressBlock>
        <offset>0x0</offset>
        <size>0x3FD</size>
        <usage>registers</usage>
      </addressBlock>
      <interrupt>
        <name>SDMMC</name>
        <description>SDMMC 全局中断</description>
        <value>124</value>
      </interrupt>
      <interrupt>
        <name>SDMMC1</name>
        <description>SDMMC 全局中断</description>
        <value>49</value>
      </interrupt>
      <registers>
        <register>
          <name>POWER</name>
          <displayName>POWER</displayName>
          <description>SDMMC 电源控制寄存器</description>
          <addressOffset>0x0</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>PWRCTRL</name>
              <description>SDMMC 状态控制位。这些位仅可在 SDMMC 未处于上电状态（PWRCTRL ≠ 11）时写入。用于定义 SDMMC 信号的功能状态：任何后续写入将被忽略，PWRCTRL 值将保持 11。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>VSWITCH</name>
              <description>电压切换序列启动。此位用于启动电压切换序列中的时序关键段：</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>VSWITCHEN</name>
              <description>电压切换过程使能。此位仅可在 CPSM 禁用（CPSMEN = 0）时由固件写入。用于在电压切换命令响应后停止 SDMMC_CK：</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DIRPOL</name>
              <description>数据和命令方向信号极性选择。此位仅可在 SDMMC 处于断电状态（PWRCTRL = 00）时写入。</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>CLKCR</name>
          <displayName>CLKCR</displayName>
          <description>SDMMC_CLKCR 寄存器控制 SDMMC_CK 输出时钟、SDMMC_RX_CLK 接收时钟和总线宽度。</description>
          <addressOffset>0x4</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>CLKDIV</name>
              <description>时钟分频因子。此位仅可在 CPSM 和 DPSM 均未激活（CPSMACT = 0 且 DPSMACT = 0）时写入。此字段定义输入时钟（SDMMCCLK）与输出时钟（SDMMC_CK）之间的分频比：SDMMC_CK 频率 = SDMMCCLK / [2 × CLKDIV]。0xx：等等.. xxx：等等..</description>
              <bitOffset>0</bitOffset>
              <bitWidth>10</bitWidth>
            </field>
            <field>
              <name>PWRSAV</name>
              <description>省电配置位。此位仅可在 CPSM 和 DPSM 均未激活（CPSMACT = 0 且 DPSMACT = 0）时写入。为节省功耗，可通过设置 PWRSAV 在总线空闲时禁用 SDMMC_CK 时钟输出：</description>
              <bitOffset>12</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>WIDBUS</name>
              <description>宽总线模式使能位。此位仅可在 CPSM 和 DPSM 均未激活（CPSMACT = 0 且 DPSMACT = 0）时写入。</description>
              <bitOffset>14</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>NEGEDGE</name>
              <description>SDMMC_CK 数据和命令去相位选择位。此位仅可在 CPSM 和 DPSM 均未激活（CPSMACT = 0 且 DPSMACT = 0）时写入。当时钟分频 = 1（CLKDIV = 0）时，此位无效。数据和命令在 SDMMC_CK 下降沿变化。当时钟分频 &gt; 1（CLKDIV &gt; 0）且 DDR = 0 时：- SDMMC_CK 边沿出现在 SDMMCCLK 上升沿。当时钟分频 &gt; 1（CLKDIV &gt; 0）且 DDR = 1 时：- 数据在 SDMMC_CK 边沿之后的 SDMMCCLK 下降沿变化。- SDMMC_CK 边沿出现在 SDMMCCLK 上升沿。- 数据在 SDMMC_CK 边沿之后的 SDMMC_CK 下降沿变化。- SDMMC_CK 边沿出现在 SDMMCCLK 上升沿。</description>
              <bitOffset>16</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>HWFC_EN</name>
              <description>硬件流控使能。此位仅可在 CPSM 和 DPSM 均未激活（CPSMACT = 0 且 DPSMACT = 0）时写入。当硬件流控使能后，TXFIFOE 和 RXFIFOF 标志的含义将发生改变，请参阅第 56.8.11 节中的 SDMMC 状态寄存器定义。</description>
              <bitOffset>17</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DDR</name>
              <description>数据速率信令选择。此位仅可在 CPSM 和 DPSM 均未激活（CPSMACT = 0 且 DPSMACT = 0）时写入。DDR 速率仅可在 4 位或 8 位宽总线模式（WIDBUS &gt; 00）下选择。当 WIDBUS = 00（1 位宽总线）时，DDR = 1 无效。DDR 速率仅可在时钟分频 &gt; 1（CLKDIV &gt; 0）时选择。</description>
              <bitOffset>18</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>BUSSPEED</name>
              <description>总线速度模式选择，可选 DS、HS、SDR12、SDR25、SDR50、DDR50、SDR104。此位仅可在 CPSM 和 DPSM 均未激活（CPSMACT = 0 且 DPSMACT = 0）时写入。</description>
              <bitOffset>19</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>SELCLKRX</name>
              <description>接收时钟选择。这些位仅可在 CPSM 和 DPSM 均未激活（CPSMACT = 0 且 DPSMACT = 0）时写入。</description>
              <bitOffset>20</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>ARGR</name>
          <displayName>ARGR</displayName>
          <description>SDMMC_ARGR 寄存器包含一个 32 位命令参数，作为命令消息的一部分发送给卡。</description>
          <addressOffset>0x8</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>CMDARG</name>
              <description>命令参数。这些位仅可在 CPSM 禁用（CPSMEN = 0）时由固件写入。作为命令消息的一部分发送给卡的命令参数。如果命令包含参数，则必须在向命令寄存器写入命令之前将其加载到此寄存器中。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>CMDR</name>
          <displayName>CMDR</displayName>
          <description>SDMMC_CMDR 寄存器包含命令索引和命令类型位。命令索引作为命令消息的一部分发送给卡。命令类型位控制命令路径状态机（CPSM）。</description>
          <addressOffset>0xC</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>CMDINDEX</name>
              <description>命令索引。此位仅可在 CPSM 禁用（CPSMEN = 0）时由固件写入。命令索引作为命令消息的一部分发送给卡。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>6</bitWidth>
            </field>
            <field>
              <name>CMDTRANS</name>
              <description>CPSM 将该命令视为数据传输命令，停止中断周期，并向 DPSM 发送 DataEnable 信号。此位仅可在 CPSM 禁用（CPSMEN = 0）时由固件写入。如果此位置位，则 CPSM 在发送命令时发出中断周期结束信号，并向 DPSM 发出 DataEnable 信号。</description>
              <bitOffset>6</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CMDSTOP</name>
              <description>CPSM 将该命令视为停止传输命令，并向 DPSM 发送 Abort 信号。此位仅可在 CPSM 禁用（CPSMEN = 0）时由固件写入。如果此位置位，则 CPSM 在发送命令时向 DPSM 发出 Abort 信号。</description>
              <bitOffset>7</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>WAITRESP</name>
              <description>等待响应位。此位仅可在 CPSM 禁用（CPSMEN = 0）时由固件写入。用于配置 CPSM 是否等待响应，以及如需等待，等待何种类型的响应。</description>
              <bitOffset>8</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>WAITINT</name>
              <description>CPSM 等待中断请求。如果此位置位，则 CPSM 禁用命令超时并等待卡中断请求（响应）。如果在 CPSM 等待状态下清除此位，将导致中断模式中止。</description>
              <bitOffset>10</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>WAITPEND</name>
              <description>CPSM 等待来自 DPSM 的数据传输结束信号（CmdPend 内部信号）。此位置位时，CPSM 在开始发送命令之前等待数据传输结束触发。WAITPEND 仅在 DTMODE = MMC 流数据传输、WIDBUS = 1 位宽总线模式、DPSMACT = 1 且 DTDIR = 主机到卡时生效。</description>
              <bitOffset>11</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CPSMEN</name>
              <description>命令路径状态机（CPSM）使能位。此位由固件写 1，当 CPSM 进入空闲状态时由硬件清零。如果此位置位，则 CPSM 使能。当 DTEN = 1 时，不会传输任何命令，也不会启动引导过程，CPSMEN 被清零为 0。</description>
              <bitOffset>12</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DTHOLD</name>
              <description>在 DPSM 中暂停新数据块的发送和接收。如果此位置位，DPSM 将不会从 Wait_S 状态转移到 Send 状态，也不会从 Wait_R 状态转移到 Receive 状态。</description>
              <bitOffset>13</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>BOOTMODE</name>
              <description>选择要使用的引导模式过程。此位仅可在 CPSM 禁用（CPSMEN = 0）时由固件写入。</description>
              <bitOffset>14</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>BOOTEN</name>
              <description>使能引导模式过程。</description>
              <bitOffset>15</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CMDSUSPEND</name>
              <description>CPSM 将该命令视为挂起或恢复命令，并发出中断周期开始/结束信号。此位仅可在 CPSM 禁用（CPSMEN = 0）时由固件写入。CMDSUSPEND = 1 且 CMDTRANS = 0：挂起命令，当响应位 BS = 0 时启动中断周期。CMDSUSPEND = 1 且 CMDTRANS = 1：带数据的恢复命令，当响应位 DF = 1 时结束中断周期。</description>
              <bitOffset>16</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>RESP1R</name>
          <displayName>RESP1R</displayName>
          <description>SDMMC_RESP1/2/3/4R 寄存器包含卡的状态信息，该状态是接收到的响应的一部分。</description>
          <addressOffset>0x14</addressOffset>
          <size>0x20</size>
          <access>read-only</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>CARDSTATUS1</name>
              <description>参见表 432。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>RESP2R</name>
          <displayName>RESP2R</displayName>
          <description>SDMMC_RESP1/2/3/4R 寄存器包含卡的状态信息，该状态是接收到的响应的一部分。</description>
          <addressOffset>0x18</addressOffset>
          <size>0x20</size>
          <access>read-only</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>CARDSTATUS2</name>
              <description>参见表 404。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>RESP3R</name>
          <displayName>RESP3R</displayName>
          <description>SDMMC_RESP1/2/3/4R 寄存器包含卡的状态信息，该状态是接收到的响应的一部分。</description>
          <addressOffset>0x1C</addressOffset>
          <size>0x20</size>
          <access>read-only</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>CARDSTATUS3</name>
              <description>参见表 404。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>RESP4R</name>
          <displayName>RESP4R</displayName>
          <description>SDMMC_RESP1/2/3/4R 寄存器包含卡的状态信息，该状态是接收到的响应的一部分。</description>
          <addressOffset>0x20</addressOffset>
          <size>0x20</size>
          <access>read-only</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>CARDSTATUS4</name>
              <description>参见表 404。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>DTIMER</name>
          <displayName>DTIMER</displayName>
          <description>SDMMC_DTIMER 寄存器包含数据超时周期，以卡总线时钟周期为单位。一个计数器从 SDMMC_DTIMER 寄存器加载值，并在数据路径状态机（DPSM）进入 Wait_R 或 Busy 状态时开始递减。如果在 DPSM 处于上述任一状态时定时器计到 0，则超时状态标志置位。</description>
          <addressOffset>0x24</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>DATATIME</name>
              <description>数据和 R1b 忙超时周期。此位仅可在 CPSM 和 DPSM 均未激活（CPSMACT = 0 且 DPSMACT = 0）时写入。以卡总线时钟周期为单位表示的数据和 R1b 忙超时周期。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>DLENR</name>
          <displayName>DLENR</displayName>
          <description>SDMMC_DLENR 寄存器包含要传输的数据字节数。该值在数据传输开始时加载到数据计数器中。</description>
          <addressOffset>0x28</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>DATALENGTH</name>
              <description>数据长度值。此寄存器仅可在 DPSM 未激活（DPSMACT = 0）时由固件写入。要传输的数据字节数。当 DDR = 1 时，DATALENGTH 被截断为 2 的倍数（最后一个奇数字节不被传输）。当 DATALENGTH = 0 时，不传输任何数据；当 CPSMEN 和 CMDTRANS = 1 请求时，也不传输任何命令，DTEN 和 CPSMEN 被清零为 0。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>25</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>DCTRL</name>
          <displayName>DCTRL</displayName>
          <description>SDMMC_DCTRL 寄存器控制数据路径状态机（DPSM）。</description>
          <addressOffset>0x2C</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>DTEN</name>
              <description>数据传输使能位。此位仅可在 DPSM 未激活（DPSMACT = 0）时由固件写入。数据传输完成时由硬件清零。此位仅应在不使用关联数据传输命令时用于传输数据，即不应与 SD 或 eMMC 卡一起使用。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DTDIR</name>
              <description>数据传输方向选择。此位仅可在 DPSM 未激活（DPSMACT = 0）时由固件写入。</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DTMODE</name>
              <description>数据传输模式选择。此位仅可在 DPSM 未激活（DPSMACT = 0）时由固件写入。</description>
              <bitOffset>2</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>DBLOCKSIZE</name>
              <description>数据块大小。此位仅可在 DPSM 未激活（DPSMACT = 0）时由固件写入。定义选择块数据传输模式时的数据块长度：当 DATALENGTH 不是 DBLOCKSIZE 的倍数时，传输的数据在 DBLOCKSIZE 的倍数处截断（任何剩余数据将不被传输）。当 DDR = 1 时，不得使用 DBLOCKSIZE = 0000（不会传输任何数据）。</description>
              <bitOffset>4</bitOffset>
              <bitWidth>4</bitWidth>
            </field>
            <field>
              <name>RWSTART</name>
              <description>读等待启动。如果此位置位，读等待操作启动。</description>
              <bitOffset>8</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>RWSTOP</name>
              <description>读等待停止。此位由固件写入，当 DPSM 从 READ_WAIT 状态转移到 WAIT_R 或 IDLE 状态时由硬件自动清零。</description>
              <bitOffset>9</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>RWMOD</name>
              <description>读等待模式。此位仅可在 DPSM 未激活（DPSMACT = 0）时由固件写入。</description>
              <bitOffset>10</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>SDIOEN</name>
              <description>SD I/O 中断使能功能。此位仅可在 DPSM 未激活（DPSMACT = 0）时由固件写入。如果此位置位，则 DPSM 使能 SD I/O 卡特定的中断操作。</description>
              <bitOffset>11</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>BOOTACKEN</name>
              <description>使能引导确认的接收。此位仅可在 DPSM 未激活（DPSMACT = 0）时由固件写入。</description>
              <bitOffset>12</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>FIFORST</name>
              <description>FIFO 复位，将清空所有剩余数据。此位仅可在 IDMAEN = 0 且 DPSM 激活（DPSMACT = 1）时由固件写入。此位仅在发生传输错误或传输暂停时生效。</description>
              <bitOffset>13</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>DCNTR</name>
          <displayName>DCNTR</displayName>
          <description>当 DPSM 从空闲状态转移到 Wait_R 或 Wait_S 状态时，SDMMC_DCNTR 寄存器从数据长度寄存器（参见 SDMMC_DLENR）加载值。随着数据传输，计数器递减该值直到达到 0。然后 DPSM 转移到空闲状态，当没有错误发生时，数据状态结束标志（DATAEND）置位。</description>
          <addressOffset>0x30</addressOffset>
          <size>0x20</size>
          <access>read-only</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>DATACOUNT</name>
              <description>数据计数值。读取时，返回剩余待传输的数据字节数。写入无效。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>25</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>STAR</name>
          <displayName>STAR</displayName>
          <description>SDMMC_STAR 寄存器为只读寄存器。包含两种类型的标志：静态标志（位 [29, 21, 11:0]）：这些位保持有效状态，直到通过写入 SDMMC 中断清零寄存器（参见 SDMMC_ICR）将其清零。动态标志（位 [20:12]）：这些位根据底层逻辑的状态改变状态（例如，FIFO 满和空标志在数据写入 FIFO 时置位和清零）。</description>
          <addressOffset>0x34</addressOffset>
          <size>0x20</size>
          <access>read-only</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>CCRCFAIL</name>
              <description>收到命令响应（CRC 校验失败）。通过写入 SDMMC_ICR 中对应的中断清零位来清除此中断标志。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DCRCFAIL</name>
              <description>数据块已发送/接收（CRC 校验失败）。通过写入 SDMMC_ICR 中对应的中断清零位来清除此中断标志。</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CTIMEOUT</name>
              <description>命令响应超时。通过写入 SDMMC_ICR 中对应的中断清零位来清除此中断标志。命令超时周期固定为 64 个 SDMMC_CK 时钟周期。</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DTIMEOUT</name>
              <description>数据超时。通过写入 SDMMC_ICR 中对应的中断清零位来清除此中断标志。</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>TXUNDERR</name>
              <description>发送 FIFO 欠载错误或 IDMA 读传输错误。通过写入 SDMMC_ICR 中对应的中断清零位来清除此中断标志。</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>RXOVERR</name>
              <description>接收 FIFO 溢出错误或 IDMA 写传输错误。通过写入 SDMMC_ICR 中对应的中断清零位来清除此中断标志。</description>
              <bitOffset>5</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CMDREND</name>
              <description>收到命令响应（CRC 校验通过或无 CRC）。通过写入 SDMMC_ICR 中对应的中断清零位来清除此中断标志。</description>
              <bitOffset>6</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CMDSENT</name>
              <description>命令已发送（无需响应）。通过写入 SDMMC_ICR 中对应的中断清零位来清除此中断标志。</description>
              <bitOffset>7</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DATAEND</name>
              <description>数据传输正确结束（数据计数器 DATACOUNT 为零且未发生错误）。通过写入 SDMMC_ICR 中对应的中断清零位来清除此中断标志。</description>
              <bitOffset>8</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DHOLD</name>
              <description>数据传输暂停。通过写入 SDMMC_ICR 中对应的中断清零位来清除此中断标志。</description>
              <bitOffset>9</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DBCKEND</name>
              <description>数据块已发送/接收（CRC 校验通过），且 DPSM 转移到 READWAIT 状态。通过写入 SDMMC_ICR 中对应的中断清零位来清除此中断标志。</description>
              <bitOffset>10</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DABORT</name>
              <description>数据传输被 CMD12 中止。通过写入 SDMMC_ICR 中对应的中断清零位来清除此中断标志。</description>
              <bitOffset>11</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DPSMACT</name>
              <description>数据路径状态机激活，即不在空闲状态。此标志仅为硬件状态标志，不产生中断。</description>
              <bitOffset>12</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CPSMACT</name>
              <description>命令路径状态机激活，即不在空闲状态。此标志仅为硬件状态标志，不产生中断。</description>
              <bitOffset>13</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>TXFIFOHE</name>
              <description>发送 FIFO 半空。至少有一半容量的字可写入 FIFO。当 FIFO 变为半满 + 1 时，此位清零。</description>
              <bitOffset>14</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>RXFIFOHF</name>
              <description>接收 FIFO 半满。FIFO 中至少有总容量一半的字数。当 FIFO 变为半空 + 1 时，此位清零。</description>
              <bitOffset>15</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>TXFIFOF</name>
              <description>发送 FIFO 满。此标志仅为硬件状态标志，不产生中断。当 FIFO 有一个位置变为空时，此位清零。</description>
              <bitOffset>16</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>RXFIFOF</name>
              <description>接收 FIFO 满。当 FIFO 有一个位置变为空时，此位清零。</description>
              <bitOffset>17</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>TXFIFOE</name>
              <description>发送 FIFO 空。当 FIFO 有一个位置变为满时，此位清零。</description>
              <bitOffset>18</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>RXFIFOE</name>
              <description>接收 FIFO 空。此标志仅为硬件状态标志，不产生中断。当 FIFO 有一个位置变为满时，此位清零。</description>
              <bitOffset>19</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>BUSYD0</name>
              <description>SDMMC_D0 线（Busy）的反相值，在 CMD 响应结束时采样一次，并在 CMD 响应后 2 个 SDMMC_CK 周期再次采样。当 SDMMC_D0 线从忙变为不忙时，此位复位为不忙。此位不指示由数据传输引起的忙状态。此标志仅为硬件状态标志，不产生中断。</description>
              <bitOffset>20</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>BUSYD0END</name>
              <description>检测到 CMD 响应后的 SDMMC_D0 忙结束。这仅指示 CMD 响应后的忙结束。此位不指示由数据传输引起的忙状态。通过写入 SDMMC_ICR 中对应的中断清零位来清除此中断标志。</description>
              <bitOffset>21</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>SDIOIT</name>
              <description>收到 SDIO 中断。通过写入 SDMMC_ICR 中对应的中断清零位来清除此中断标志。</description>
              <bitOffset>22</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>ACKFAIL</name>
              <description>收到引导确认（引导确认校验失败）。通过写入 SDMMC_ICR 中对应的中断清零位来清除此中断标志。</description>
              <bitOffset>23</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>ACKTIMEOUT</name>
              <description>引导确认超时。通过写入 SDMMC_ICR 中对应的中断清零位来清除此中断标志。</description>
              <bitOffset>24</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>VSWEND</name>
              <description>电压切换时序关键段完成。通过写入 SDMMC_ICR 中对应的中断清零位来清除此中断标志。</description>
              <bitOffset>25</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CKSTOP</name>
              <description>SDMMC_CK 在电压切换过程中停止。通过写入 SDMMC_ICR 中对应的中断清零位来清除此中断标志。</description>
              <bitOffset>26</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>IDMATE</name>
              <description>IDMA 传输错误。通过写入 SDMMC_ICR 中对应的中断清零位来清除此中断标志。</description>
              <bitOffset>27</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>IDMABTC</name>
              <description>IDMA 缓冲区传输完成。通过写入 SDMMC_ICR 中对应的中断清零位来清除此中断标志。</description>
              <bitOffset>28</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>ICR</name>
          <displayName>ICR</displayName>
          <description>SDMMC_ICR 寄存器为只写寄存器。将某位写 1 可清零 SDMMC_STAR 状态寄存器中对应的位。</description>
          <addressOffset>0x38</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>CCRCFAILC</name>
              <description>CCRCFAIL 标志清零位。由软件置位以清零 CCRCFAIL 标志。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DCRCFAILC</name>
              <description>DCRCFAIL 标志清零位。由软件置位以清零 DCRCFAIL 标志。</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CTIMEOUTC</name>
              <description>CTIMEOUT 标志清零位。由软件置位以清零 CTIMEOUT 标志。</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DTIMEOUTC</name>
              <description>DTIMEOUT 标志清零位。由软件置位以清零 DTIMEOUT 标志。</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>TXUNDERRC</name>
              <description>TXUNDERR 标志清零位。由软件置位以清零 TXUNDERR 标志。</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>RXOVERRC</name>
              <description>RXOVERR 标志清零位。由软件置位以清零 RXOVERR 标志。</description>
              <bitOffset>5</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CMDRENDC</name>
              <description>CMDREND 标志清零位。由软件置位以清零 CMDREND 标志。</description>
              <bitOffset>6</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CMDSENTC</name>
              <description>CMDSENT 标志清零位。由软件置位以清零 CMDSENT 标志。</description>
              <bitOffset>7</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DATAENDC</name>
              <description>DATAEND 标志清零位。由软件置位以清零 DATAEND 标志。</description>
              <bitOffset>8</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DHOLDC</name>
              <description>DHOLD 标志清零位。由软件置位以清零 DHOLD 标志。</description>
              <bitOffset>9</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DBCKENDC</name>
              <description>DBCKEND 标志清零位。由软件置位以清零 DBCKEND 标志。</description>
              <bitOffset>10</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DABORTC</name>
              <description>DABORT 标志清零位。由软件置位以清零 DABORT 标志。</description>
              <bitOffset>11</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>BUSYD0ENDC</name>
              <description>BUSYD0END 标志清零位。由软件置位以清零 BUSYD0END 标志。</description>
              <bitOffset>21</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>SDIOITC</name>
              <description>SDIOIT 标志清零位。由软件置位以清零 SDIOIT 标志。</description>
              <bitOffset>22</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>ACKFAILC</name>
              <description>ACKFAIL 标志清零位。由软件置位以清零 ACKFAIL 标志。</description>
              <bitOffset>23</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>ACKTIMEOUTC</name>
              <description>ACKTIMEOUT 标志清零位。由软件置位以清零 ACKTIMEOUT 标志。</description>
              <bitOffset>24</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>VSWENDC</name>
              <description>VSWEND 标志清零位。由软件置位以清零 VSWEND 标志。</description>
              <bitOffset>25</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CKSTOPC</name>
              <description>CKSTOP 标志清零位。由软件置位以清零 CKSTOP 标志。</description>
              <bitOffset>26</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>IDMATEC</name>
              <description>IDMA 传输错误清零位。由软件置位以清零 IDMATE 标志。</description>
              <bitOffset>27</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>IDMABTCC</name>
              <description>IDMA 缓冲区传输完成清零位。由软件置位以清零 IDMABTC 标志。</description>
              <bitOffset>28</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MASKR</name>
          <displayName>MASKR</displayName>
          <description>中断屏蔽寄存器通过将对应位置 1 来确定哪些状态标志产生中断请求。</description>
          <addressOffset>0x3C</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>CCRCFAILIE</name>
              <description>命令 CRC 校验失败中断使能。由软件置位/清零以使能/禁用由命令 CRC 校验失败引起的中断。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DCRCFAILIE</name>
              <description>数据 CRC 校验失败中断使能。由软件置位/清零以使能/禁用由数据 CRC 校验失败引起的中断。</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CTIMEOUTIE</name>
              <description>命令超时中断使能。由软件置位/清零以使能/禁用由命令超时引起的中断。</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DTIMEOUTIE</name>
              <description>数据超时中断使能。由软件置位/清零以使能/禁用由数据超时引起的中断。</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>TXUNDERRIE</name>
              <description>发送 FIFO 欠载错误中断使能。由软件置位/清零以使能/禁用由发送 FIFO 欠载错误引起的中断。</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>RXOVERRIE</name>
              <description>接收 FIFO 溢出错误中断使能。由软件置位/清零以使能/禁用由接收 FIFO 溢出错误引起的中断。</description>
              <bitOffset>5</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CMDRENDIE</name>
              <description>命令响应接收中断使能。由软件置位/清零以使能/禁用由收到命令响应引起的中断。</description>
              <bitOffset>6</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CMDSENTIE</name>
              <description>命令发送中断使能。由软件置位/清零以使能/禁用由命令发送引起的中断。</description>
              <bitOffset>7</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DATAENDIE</name>
              <description>数据结束中断使能。由软件置位/清零以使能/禁用由数据结束引起的中断。</description>
              <bitOffset>8</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DHOLDIE</name>
              <description>数据暂停中断使能。由软件置位/清零以使能/禁用在 DPSM Wait_S 状态下暂停发送新数据时产生的中断。</description>
              <bitOffset>9</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DBCKENDIE</name>
              <description>数据块结束中断使能。由软件置位/清零以使能/禁用由数据块结束引起的中断。</description>
              <bitOffset>10</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DABORTIE</name>
              <description>数据传输中止中断使能。由软件置位/清零以使能/禁用由数据传输被中止引起的中断。</description>
              <bitOffset>11</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>TXFIFOHEIE</name>
              <description>发送 FIFO 半空中断使能。由软件置位/清零以使能/禁用由发送 FIFO 半空引起的中断。</description>
              <bitOffset>14</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>RXFIFOHFIE</name>
              <description>接收 FIFO 半满中断使能。由软件置位/清零以使能/禁用由接收 FIFO 半满引起的中断。</description>
              <bitOffset>15</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>RXFIFOFIE</name>
              <description>接收 FIFO 满中断使能。由软件置位/清零以使能/禁用由接收 FIFO 满引起的中断。</description>
              <bitOffset>17</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>TXFIFOEIE</name>
              <description>发送 FIFO 空中断使能。由软件置位/清零以使能/禁用由发送 FIFO 空引起的中断。</description>
              <bitOffset>18</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>BUSYD0ENDIE</name>
              <description>BUSYD0END 中断使能。由软件置位/清零以使能/禁用在 CMD 响应后 SDMMC_D0 信号从忙变为不忙时产生的中断。</description>
              <bitOffset>21</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>SDIOITIE</name>
              <description>SDIO 模式中断接收中断使能。由软件置位/清零以使能/禁用接收到 SDIO 模式中断时产生的中断。</description>
              <bitOffset>22</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>ACKFAILIE</name>
              <description>确认失败中断使能。由软件置位/清零以使能/禁用由确认失败引起的中断。</description>
              <bitOffset>23</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>ACKTIMEOUTIE</name>
              <description>确认超时中断使能。由软件置位/清零以使能/禁用由确认超时引起的中断。</description>
              <bitOffset>24</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>VSWENDIE</name>
              <description>电压切换时序关键段完成中断使能。由软件置位/清零以使能/禁用电压切换时序关键段完成时产生的中断。</description>
              <bitOffset>25</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CKSTOPIE</name>
              <description>电压切换时钟停止中断使能。由软件置位/清零以使能/禁用由电压切换时钟停止引起的中断。</description>
              <bitOffset>26</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>IDMABTCIE</name>
              <description>IDMA 缓冲区传输完成中断使能。由软件置位/清零以使能/禁用 IDMA 完成传输某个内存缓冲区的全部数据时产生的中断。</description>
              <bitOffset>28</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>ACKTIMER</name>
          <displayName>ACKTIMER</displayName>
          <description>SDMMC_ACKTIMER 寄存器包含确认超时周期，以 SDMMC_CK 总线时钟周期为单位。一个计数器从 SDMMC_ACKTIMER 寄存器加载值，并在数据路径状态机（DPSM）进入 Wait_Ack 状态时开始递减。如果在 DPSM 处于此状态时定时器计到 0，则确认超时状态标志置位。</description>
          <addressOffset>0x40</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>ACKTIME</name>
              <description>引导确认超时周期。此位仅可在 CPSM 禁用（CPSMEN = 0）时由固件写入。以卡总线时钟周期为单位表示的引导确认超时周期。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>25</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>IDMACTRLR</name>
          <displayName>IDMACTRLR</displayName>
          <description>接收和发送 FIFO 可作为 32 位宽寄存器进行读写。FIFO 在 32 个连续地址上包含 32 个条目。这允许 CPU 使用其加载和存储多条指令来读写 FIFO。</description>
          <addressOffset>0x50</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>IDMAEN</name>
              <description>IDMA 使能。此位仅可在 DPSM 未激活（DPSMACT = 0）时由固件写入。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>IDMABMODE</name>
              <description>缓冲区模式选择。此位仅可在 DPSM 未激活（DPSMACT = 0）时由固件写入。</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>IDMABACT</name>
              <description>双缓冲区模式激活缓冲区指示。此位仅可在 DPSM 未激活（DPSMACT = 0）时由固件写入。当 IDMA 使能时，此位由硬件翻转。</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>IDMABSIZER</name>
          <displayName>IDMABSIZER</displayName>
          <description>SDMMC_IDMABSIZER 寄存器包含双缓冲区配置下的缓冲区大小。</description>
          <addressOffset>0x54</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>IDMABNDT</name>
              <description>每缓冲区传输次数。此 8 位值乘以 8 可得到以 32 位字为单位的缓冲区大小，乘以 32 可得到以字节为单位的缓冲区大小。示例：IDMABNDT = 0x01：缓冲区大小 = 8 字 = 32 字节。这些位仅可在 DPSM 未激活（DPSMACT = 0）时由固件写入。</description>
              <bitOffset>5</bitOffset>
              <bitWidth>8</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>IDMABASE0R</name>
          <displayName>IDMABASE0R</displayName>
          <description>SDMMC_IDMABASE0R 寄存器包含单缓冲区配置下的内存缓冲区基地址，以及双缓冲区配置下的缓冲区 0 基地址。</description>
          <addressOffset>0x58</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>IDMABASE0</name>
              <description>缓冲区 0 内存基地址位 [31:2]，应按字对齐（位 [1:0] 始终为 0 且只读）。此寄存器可在 DPSM 未激活（DPSMACT = 0）时由固件写入，也可在 DPSM 激活（DPSMACT = 1）且内存缓冲区 0 未激活（IDMABACT = 1）时由固件动态写入。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>IDMABASE1R</name>
          <displayName>IDMABASE1R</displayName>
          <description>SDMMC_IDMABASE1R 寄存器包含双缓冲区配置下第二个缓冲区的内存基地址。</description>
          <addressOffset>0x5C</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>IDMABASE1</name>
              <description>缓冲区 1 内存基地址，应按字对齐（位 [1:0] 始终为 0 且只读）。此寄存器可在 DPSM 未激活（DPSMACT = 0）时由固件写入，也可在 DPSM 激活（DPSMACT = 1）且内存缓冲区 1 未激活（IDMABACT = 0）时由固件动态写入。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>FIFOR</name>
          <displayName>FIFOR</displayName>
          <description>接收和发送 FIFO 只能作为字（32 位）宽寄存器进行读写。FIFO 在连续地址上包含 16 个条目。这允许 CPU 使用其加载和存储多条指令来读写 FIFO。当以半字或字节方式访问 SDMMC_FIFOR 时，会产生 AHB 总线故障。</description>
          <addressOffset>0x80</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>FIFODATA</name>
              <description>接收和发送 FIFO 数据。此寄存器仅可在 DPSM 激活（DPSMACT = 1）时由固件读写。FIFO 数据占用 16 个 32 位字条目。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>VER</name>
          <displayName>VER</displayName>
          <description>SDMMC IP 版本寄存器</description>
          <addressOffset>0x3F4</addressOffset>
          <size>0x20</size>
          <access>read-only</access>
          <resetValue>0x00000010</resetValue>
          <fields>
            <field>
              <name>MINREV</name>
              <description>IP 次版本号。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>4</bitWidth>
            </field>
            <field>
              <name>MAJREV</name>
              <description>IP 主版本号。</description>
              <bitOffset>4</bitOffset>
              <bitWidth>4</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>ID</name>
          <displayName>ID</displayName>
          <description>SDMMC IP 标识寄存器</description>
          <addressOffset>0x3F8</addressOffset>
          <size>0x20</size>
          <access>read-only</access>
          <resetValue>0x00140022</resetValue>
          <fields>
            <field>
              <name>IP_ID</name>
              <description>SDMMC IP 标识。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>RESPCMDR</name>
          <displayName>RESPCMDR</displayName>
          <description>SDMMC 命令响应寄存器</description>
          <addressOffset>0x10</addressOffset>
          <size>0x20</size>
          <access>read-only</access>
          <resetValue>0xA3C5DD01</resetValue>
          <fields>
            <field>
              <name>RESPCMD</name>
              <description>响应命令索引</description>
              <bitOffset>0</bitOffset>
              <bitWidth>6</bitWidth>
            </field>
          </fields>
        </register>
      </registers>
    </peripheral>
    <peripheral derivedFrom="SDMMC1">
      <name>SDMMC2</name>
      <baseAddress>0x48022400</baseAddress>
    </peripheral>
    <peripheral>
      <name>VREFBUF</name>
      <description>VREFBUF</description>
      <groupName>VREFBUF</groupName>
      <baseAddress>0x58003C00</baseAddress>
      <addressBlock>
        <offset>0x0</offset>
        <size>0x400</size>
        <usage>registers</usage>
      </addressBlock>
      <registers>
        <register>
          <name>CSR</name>
          <displayName>CSR</displayName>
          <description>VREFBUF 控制与状态寄存器</description>
          <addressOffset>0x0</addressOffset>
          <size>0x20</size>
          <resetValue>0x00000002</resetValue>
          <fields>
            <field>
              <name>ENVR</name>
              <description>电压参考缓冲器模式使能。此位用于使能电压参考缓冲器模式。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>HIZ</name>
              <description>高阻抗模式。此位控制模拟开关与 VREF+ 引脚的连接或断开。有关基于 ENVR 位配置的模式说明，请参见表 196：VREF 缓冲器模式。</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>VRR</name>
              <description>电压参考缓冲器就绪</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>VRS</name>
              <description>电压参考量程。这些位用于选择电压参考缓冲器产生的电压值。其他值：保留。</description>
              <bitOffset>4</bitOffset>
              <bitWidth>3</bitWidth>
              <access>read-write</access>
            </field>
          </fields>
        </register>
        <register>
          <name>CCR</name>
          <displayName>CCR</displayName>
          <description>VREFBUF 校准控制寄存器</description>
          <addressOffset>0x4</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>TRIM</name>
              <description>微调代码。这些位在复位后会自动加载生产测试期间存入 Flash 的微调值。向这些位写入数据可微调内部参考缓冲器电压。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>6</bitWidth>
            </field>
          </fields>
        </register>
      </registers>
    </peripheral>
    <peripheral>
      <name>IWDG</name>
      <description>独立看门狗</description>
      <groupName>IWDG</groupName>
      <baseAddress>0x58004800</baseAddress>
      <addressBlock>
        <offset>0x0</offset>
        <size>0x400</size>
        <usage>registers</usage>
      </addressBlock>
      <registers>
        <register>
          <name>KR</name>
          <displayName>KR</displayName>
          <description>键寄存器</description>
          <addressOffset>0x0</addressOffset>
          <size>0x20</size>
          <access>write-only</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>KEY</name>
              <description>键值（只写，读取返回 0x0000）。软件必须定期向这些位写入键值 0xAAAA，否则当计数器递减到 0 时，看门狗将产生复位。写入键值 0x5555 可使能对 IWDG_PR、IWDG_RLR 和 IWDG_WINR 寄存器的访问（参见第 23.3.6 节：寄存器访问保护）。写入键值 0xCCCC 启动看门狗（选择了硬件看门狗选项时除外）。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>16</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>PR</name>
          <displayName>PR</displayName>
          <description>预分频器寄存器</description>
          <addressOffset>0x4</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>PR</name>
              <description>预分频器分频系数。这些位受写访问保护，参见第 23.3.6 节：寄存器访问保护。由软件写入，用于选择为计数器提供时钟的预分频器分频系数。要修改预分频器分频系数，必须先将 IWDG_SR 寄存器的 PVU 位复位。注意：读取本寄存器返回的是 VDD 电压域中的预分频器值。若对该寄存器的写操作正在进行中，该值可能不是最新的或无效。因此，仅当 IWDG_SR 寄存器中的 PVU 位复位时，从本寄存器读取的值才有效。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>3</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>RLR</name>
          <displayName>RLR</displayName>
          <description>重装载寄存器</description>
          <addressOffset>0x8</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000FFF</resetValue>
          <fields>
            <field>
              <name>RL</name>
              <description>看门狗计数器重装载值。这些位受写访问保护，参见第 23.3.6 节。由软件写入，用于定义每次向 IWDG_KR 寄存器写入 0xAAAA 时要装载到看门狗计数器中的值。看门狗计数器从此值开始递减计数。超时周期由该值和时钟预分频器共同决定。有关超时信息，请参阅数据手册。要修改重装载值，必须先将 IWDG_SR 寄存器中的 RVU 位复位。注意：读取本寄存器返回的是 VDD 电压域中的重装载值。若对该寄存器的写操作正在进行中，该值可能不是最新的或无效。因此，仅当 IWDG_SR 寄存器中的 RVU 位复位时，从本寄存器读取的值才有效。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>12</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>SR</name>
          <displayName>SR</displayName>
          <description>状态寄存器</description>
          <addressOffset>0xC</addressOffset>
          <size>0x20</size>
          <access>read-only</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>PVU</name>
              <description>看门狗预分频器值更新。此位由硬件置 1，表示预分频器值更新正在进行中。当预分频器更新操作在 VDD 电压域中完成时（最多需要 5 个 RC 40 kHz 时钟周期），由硬件复位。仅当 PVU 位复位时，才能更新预分频器值。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>RVU</name>
              <description>看门狗计数器重装载值更新。此位由硬件置 1，表示重装载值更新正在进行中。当重装载值更新操作在 VDD 电压域中完成时（最多需要 5 个 RC 40 kHz 时钟周期），由硬件复位。仅当 RVU 位复位时，才能更新重装载值。</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>WVU</name>
              <description>看门狗计数器窗口值更新。此位由硬件置 1，表示窗口值更新正在进行中。当重装载值更新操作在 VDD 电压域中完成时（最多需要 5 个 RC 40 kHz 时钟周期），由硬件复位。仅当 WVU 位复位时，才能更新窗口值。仅当 generic window = 1 时才会生成此位。</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>WINR</name>
          <displayName>WINR</displayName>
          <description>窗口寄存器</description>
          <addressOffset>0x10</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000FFF</resetValue>
          <fields>
            <field>
              <name>WIN</name>
              <description>看门狗计数器窗口值。这些位受写访问保护，参见第 23.3.6 节。这些位包含窗口值的高限，用于与递减计数器进行比较。为防止复位，必须在递减计数器的值小于窗口寄存器值且大于 0x0 时对其进行重装载。要修改重装载值，必须先将 IWDG_SR 寄存器中的 WVU 位复位。注意：读取本寄存器返回的是 VDD 电压域中的重装载值。若对该寄存器的写操作正在进行中，该值可能无效。因此，仅当 IWDG_SR 寄存器中的 WVU 位复位时，从本寄存器读取的值才有效。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>12</bitWidth>
            </field>
          </fields>
        </register>
      </registers>
    </peripheral>
    <peripheral>
      <name>WWDG</name>
      <description>WWDG</description>
      <groupName>WWDG</groupName>
      <baseAddress>0x50003000</baseAddress>
      <addressBlock>
        <offset>0x0</offset>
        <size>0x400</size>
        <usage>registers</usage>
      </addressBlock>
      <interrupt>
        <name>WWDG1_RST</name>
        <description>窗口看门狗中断</description>
        <value>143</value>
      </interrupt>
      <interrupt>
        <name>WWDG1</name>
        <description>窗口看门狗中断</description>
        <value>0</value>
      </interrupt>
      <registers>
        <register>
          <name>CR</name>
          <displayName>CR</displayName>
          <description>控制寄存器</description>
          <addressOffset>0x0</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x0000007F</resetValue>
          <fields>
            <field>
              <name>T</name>
              <description>7 位计数器（MSB 至 LSB）。这些位存储看门狗计数器的值。计数器每 (4096 x 2^WDGTB[1:0]) 个 PCLK 周期递减一次。当计数器从 0x40 递减至 0x3F（T6 被清零）时，将产生复位。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>7</bitWidth>
            </field>
            <field>
              <name>WDGA</name>
              <description>激活位。此位由软件置 1，仅能在复位后由硬件清零。当 WDGA=1 时，看门狗可产生复位。</description>
              <bitOffset>7</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>CFR</name>
          <displayName>CFR</displayName>
          <description>配置寄存器</description>
          <addressOffset>0x4</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x0000007F</resetValue>
          <fields>
            <field>
              <name>W</name>
              <description>7 位窗口值。这些位存储与递减计数器进行比较的窗口值。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>7</bitWidth>
            </field>
            <field>
              <name>WDGTB</name>
              <description>定时器时基。预分频器的时基可如下修改：</description>
              <bitOffset>11</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>EWI</name>
              <description>提前唤醒中断。此位置 1 后，每当计数器到达 0x40 时即产生中断。此中断仅能在复位后由硬件清零。</description>
              <bitOffset>9</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>SR</name>
          <displayName>SR</displayName>
          <description>状态寄存器</description>
          <addressOffset>0x8</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>EWIF</name>
              <description>提前唤醒中断标志。当计数器到达 0x40 时，此位由硬件置 1。必须由软件写入 0 来清零，写入 1 无效。即使中断未使能，此位也会被置 1。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
      </registers>
    </peripheral>
    <peripheral>
      <name>PWR</name>
      <description>PWR</description>
      <groupName>PWR</groupName>
      <baseAddress>0x58024800</baseAddress>
      <addressBlock>
        <offset>0x0</offset>
        <size>0x400</size>
        <usage>registers</usage>
      </addressBlock>
      <registers>
        <register>
          <name>CR1</name>
          <displayName>CR1</displayName>
          <description>PWR 控制寄存器 1</description>
          <addressOffset>0x0</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0xF000C000</resetValue>
          <fields>
            <field>
              <name>LPDS</name>
              <description>低功耗深度睡眠，配合 SVOS3 使用（SVOS4 和 SVOS5 始终使用低功耗模式，不受此位设置影响）</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>PVDE</name>
              <description>可编程电压检测器使能</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>PLS</name>
              <description>可编程电压检测器阈值选择 这些位用于选择 PVD 检测的电压阈值。注意：更多详细信息请参阅产品数据手册的电气特性章节。</description>
              <bitOffset>5</bitOffset>
              <bitWidth>3</bitWidth>
            </field>
            <field>
              <name>DBP</name>
              <description>禁用备份域写保护 在复位状态下，RCC_BDCR 寄存器、RTC 寄存器（包括备份寄存器）、PWR_CR2 寄存器中的 BREN 和 MOEN 位均受到保护，防止寄生写入。必须将此位置 1 才能使能对这些寄存器的写访问。</description>
              <bitOffset>8</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>FLPS</name>
              <description>DStop 模式下 Flash 低功耗模式 此位用于在退出 DStop 模式时，在低功耗与重启时间之间取得最佳平衡。置位后，当 D1 域进入 DStop 模式时，Flash 存储器将进入低功耗模式。</description>
              <bitOffset>9</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>SVOS</name>
              <description>系统停止模式电压调节选择 这些位控制系统 Stop 模式下的 VCORE 电压等级，以在功耗与性能之间取得最佳平衡。</description>
              <bitOffset>14</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>AVDEN</name>
              <description>VDDA 外设电压监控器使能</description>
              <bitOffset>16</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>ALS</name>
              <description>模拟电压检测器阈值选择 这些位用于选择 AVD 检测的电压阈值。</description>
              <bitOffset>17</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>CSR1</name>
          <displayName>CSR1</displayName>
          <description>PWR 控制状态寄存器 1</description>
          <addressOffset>0x4</addressOffset>
          <size>0x20</size>
          <access>read-only</access>
          <resetValue>0x00004000</resetValue>
          <fields>
            <field>
              <name>PVDO</name>
              <description>可编程电压检测输出 此位由硬件置位和清零。仅当 PVD 已通过 PVDE 位使能时才有效。注意：由于 PVD 在待机模式下被禁用，因此在待机或复位后，此位保持为 0，直到 PVDE 位置位。</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>ACTVOSRDY</name>
              <description>当前使用的 VOS 和 SDLEVEL 电压等级就绪位 当电压调节器和 SD 转换器均被禁用，且在 PWR 控制寄存器 3（PWR_CR3）中选择了旁路模式时，此位由硬件置 1。</description>
              <bitOffset>13</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>ACTVOS</name>
              <description>当前应用于 VCORE 电压调节选择的 VOS。这些位反映最近一次写入 PMU 的 VOS 值。</description>
              <bitOffset>14</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>AVDO</name>
              <description>VDDA 模拟电压检测器输出 此位由硬件置位和清零。仅当 VDDA 上的 AVD 已通过 AVDEN 位使能时才有效。注意：由于 AVD 在待机模式下被禁用，因此在待机或复位后，此位保持为 0，直到 AVDEN 位置位。</description>
              <bitOffset>16</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>CR2</name>
          <displayName>CR2</displayName>
          <description>此寄存器不受待机模式唤醒、RESET 信号和 VDD 上电复位的影响。仅由 VSW 上电复位和 VSWRST 复位来复位。当 RCC_BDCR 寄存器中的 VSWRST 位复位 VSW 域时，不得访问此寄存器。复位后，PWR_CR2 寄存器处于写保护状态。修改其内容之前，必须先将 PWR_CR1 寄存器中的 DBP 位置位以解除写保护。</description>
          <addressOffset>0x8</addressOffset>
          <size>0x20</size>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>BREN</name>
              <description>备份调压器使能 置位后，备份调压器（用于在待机和 VBAT 模式下保持备份 RAM 内容）被使能。若 BREN 清零，则备份调压器关闭。备份 RAM 在运行和停止模式下仍可使用，但其内容将在待机和 VBAT 模式下丢失。若 BREN 置位，应用程序必须等待备份调压器就绪标志（BRRDY）置位，以表明写入 SRAM 的数据将在待机和 VBAT 模式下得到保持。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>MONEN</name>
              <description>VBAT 和温度监控使能 置位后，VBAT 电源和温度监控被使能。</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>BRRDY</name>
              <description>备份调压器就绪 此位由硬件置位，用于指示备份调压器已就绪。</description>
              <bitOffset>16</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>VBATL</name>
              <description>VBAT 电平低于低阈值监控</description>
              <bitOffset>20</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>VBATH</name>
              <description>VBAT 电平高于高阈值监控</description>
              <bitOffset>21</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>TEMPL</name>
              <description>温度低于低阈值监控</description>
              <bitOffset>22</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>TEMPH</name>
              <description>温度高于高阈值监控</description>
              <bitOffset>23</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
          </fields>
        </register>
        <register>
          <name>CR3</name>
          <displayName>CR3</displayName>
          <description>仅由上电复位（POR）复位，不受待机模式唤醒和 RESET 引脚的复位影响。此寄存器的低字节在 POR 后仅可写入一次，且应在更改 VOS 等级或 ck_sys 时钟频率之前写入。高字节无此限制。写入与 SDLEVEL、SDEXTHP、SDEN、LDOEN 和 BYPASS 位的无效组合（见表 9）对应的数据将被忽略：数据不会被写入，一次性写入机制将锁定该寄存器，任何后续写访问都将被忽略。默认电源配置将保持不变，PWR 控制状态寄存器 1（PWR_CSR1）中的 ACTVOSRDY 位将继续指示无效的电压等级。在写入新值之前，需要对系统进行下电再上电。</description>
          <addressOffset>0xC</addressOffset>
          <size>0x20</size>
          <resetValue>0x00000006</resetValue>
          <fields>
            <field>
              <name>BYPASS</name>
              <description>电源管理单元旁路</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>LDOEN</name>
              <description>低压差调压器使能</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>SCUEN</name>
              <description>SD 转换器使能</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>VBE</name>
              <description>VBAT 充电使能</description>
              <bitOffset>8</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>VBRS</name>
              <description>VBAT 充电电阻选择</description>
              <bitOffset>9</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>USB33DEN</name>
              <description>VDD33USB 电压电平检测器使能</description>
              <bitOffset>24</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>USBREGEN</name>
              <description>USB 调压器使能</description>
              <bitOffset>25</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>USB33RDY</name>
              <description>USB 电源就绪</description>
              <bitOffset>26</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
          </fields>
        </register>
        <register>
          <name>CPUCR</name>
          <displayName>CPUCR</displayName>
          <description>此寄存器用于控制 CPU1 的电源。</description>
          <addressOffset>0x10</addressOffset>
          <size>0x20</size>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>PDDS_D1</name>
              <description>D1 域断电深度睡眠选择。此位允许 CPU1 定义 D1 域的深度睡眠模式。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>PDDS_D2</name>
              <description>D2 域断电深度睡眠。此位允许 CPU1 定义 D2 域的深度睡眠模式。</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>PDDS_D3</name>
              <description>系统 D3 域断电深度睡眠。此位允许 CPU1 定义系统 D3 域的深度睡眠模式。</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>STOPF</name>
              <description>STOP 标志 此位由硬件置位，仅可通过任意复位或将 CPU1 CSSF 位置位来清零。</description>
              <bitOffset>5</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>SBF</name>
              <description>系统待机标志 此位由硬件置位，仅可通过上电复位（POR）或将 CPU1 CSSF 位置位来清零。</description>
              <bitOffset>6</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>SBF_D1</name>
              <description>D1 域 DStandby 标志 此位由硬件置位，可通过任意系统复位或将 CPU1 CSSF 位置位来清零。一旦置位，仅当 D1 域不再处于 DStandby 模式时才能清除此位。</description>
              <bitOffset>7</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>SBF_D2</name>
              <description>D2 域 DStandby 标志 此位由硬件置位，可通过任意系统复位或将 CPU1 CSSF 位置位来清零。一旦置位，仅当 D2 域不再处于 DStandby 模式时才能清除此位。</description>
              <bitOffset>8</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>CSSF</name>
              <description>清除 D1 域 CPU1 的 Standby、Stop 和 HOLD 标志（读取时始终为 0）此位由硬件清零为 0。</description>
              <bitOffset>9</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>RUN_D3</name>
              <description>无论 CPU 子系统处于何种模式，保持系统 D3 域处于运行模式</description>
              <bitOffset>11</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
          </fields>
        </register>
        <register>
          <name>D3CR</name>
          <displayName>D3CR</displayName>
          <description>此寄存器用于控制 D3 域的电源。复位后，软件读取 VOSRDY 将为 1。</description>
          <addressOffset>0x18</addressOffset>
          <size>0x20</size>
          <resetValue>0x00004000</resetValue>
          <fields>
            <field>
              <name>VOSRDY</name>
              <description>VCORE 电压调节输出选择的 VOS 就绪位。当在 PWR 控制寄存器 3（PWR_CR3）中选择旁路模式时，此位由硬件置 1。</description>
              <bitOffset>13</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>VOS</name>
              <description>根据性能选择电压调节 这些位控制 VCORE 电压等级，用于在功耗与性能之间取得最佳平衡：提高性能时，应在提升系统频率之前先更改电压调节等级。降低性能时，应先降低系统频率，再更改电压调节等级。</description>
              <bitOffset>14</bitOffset>
              <bitWidth>2</bitWidth>
              <access>read-write</access>
            </field>
          </fields>
        </register>
        <register>
          <name>WKUPCR</name>
          <displayName>WKUPCR</displayName>
          <description>仅由系统复位复位，不受待机模式唤醒影响。写入此寄存器需要 5 个等待状态（清除 PWR_WKUPFR 中的 WKUPF 位时，AHB 写访问将在 WKUPF 被清除后完成）。</description>
          <addressOffset>0x20</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>WKUPC</name>
              <description>清除 WKUP 唤醒引脚标志。这些位读取时始终为 0。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>6</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>WKUPFR</name>
          <displayName>WKUPFR</displayName>
          <description>仅由系统复位复位，不受待机模式唤醒影响</description>
          <addressOffset>0x24</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>WKUPF1</name>
              <description>唤醒引脚 WKUPF 标志。此位由硬件置位，仅可通过复位引脚或将 PWR 唤醒清除寄存器（PWR_WKUPCR）中的 WKUPCn+1 位置位来清零。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>WKUPF2</name>
              <description>唤醒引脚 WKUPF 标志。此位由硬件置位，仅可通过复位引脚或将 PWR 唤醒清除寄存器（PWR_WKUPCR）中的 WKUPCn+1 位置位来清零。</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>WKUPF3</name>
              <description>唤醒引脚 WKUPF 标志。此位由硬件置位，仅可通过复位引脚或将 PWR 唤醒清除寄存器（PWR_WKUPCR）中的 WKUPCn+1 位置位来清零。</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>WKUPF4</name>
              <description>唤醒引脚 WKUPF 标志。此位由硬件置位，仅可通过复位引脚或将 PWR 唤醒清除寄存器（PWR_WKUPCR）中的 WKUPCn+1 位置位来清零。</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>WKUPF5</name>
              <description>唤醒引脚 WKUPF 标志。此位由硬件置位，仅可通过复位引脚或将 PWR 唤醒清除寄存器（PWR_WKUPCR）中的 WKUPCn+1 位置位来清零。</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>WKUPF6</name>
              <description>唤醒引脚 WKUPF 标志。此位由硬件置位，仅可通过复位引脚或将 PWR 唤醒清除寄存器（PWR_WKUPCR）中的 WKUPCn+1 位置位来清零。</description>
              <bitOffset>5</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>WKUPEPR</name>
          <displayName>WKUPEPR</displayName>
          <description>仅由系统复位复位，不受待机模式唤醒影响</description>
          <addressOffset>0x28</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>WKUPEN1</name>
              <description>使能唤醒引脚 WKUPn+1 每个位由软件置位和清零。注意：若在 WKUPn+1 引脚电平已为高（且 WKUPPn+1 选择上升沿）或已为低（且 WKUPPn+1 选择下降沿）时，使能 WKUPn+1 引脚（通过置位 WKUPENn+1 位），则会检测到一个额外的唤醒事件。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>WKUPEN2</name>
              <description>使能唤醒引脚 WKUPn+1 每个位由软件置位和清零。注意：若在 WKUPn+1 引脚电平已为高（且 WKUPPn+1 选择上升沿）或已为低（且 WKUPPn+1 选择下降沿）时，使能 WKUPn+1 引脚（通过置位 WKUPENn+1 位），则会检测到一个额外的唤醒事件。</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>WKUPEN3</name>
              <description>使能唤醒引脚 WKUPn+1 每个位由软件置位和清零。注意：若在 WKUPn+1 引脚电平已为高（且 WKUPPn+1 选择上升沿）或已为低（且 WKUPPn+1 选择下降沿）时，使能 WKUPn+1 引脚（通过置位 WKUPENn+1 位），则会检测到一个额外的唤醒事件。</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>WKUPEN4</name>
              <description>使能唤醒引脚 WKUPn+1 每个位由软件置位和清零。注意：若在 WKUPn+1 引脚电平已为高（且 WKUPPn+1 选择上升沿）或已为低（且 WKUPPn+1 选择下降沿）时，使能 WKUPn+1 引脚（通过置位 WKUPENn+1 位），则会检测到一个额外的唤醒事件。</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>WKUPEN5</name>
              <description>使能唤醒引脚 WKUPn+1 每个位由软件置位和清零。注意：若在 WKUPn+1 引脚电平已为高（且 WKUPPn+1 选择上升沿）或已为低（且 WKUPPn+1 选择下降沿）时，使能 WKUPn+1 引脚（通过置位 WKUPENn+1 位），则会检测到一个额外的唤醒事件。</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>WKUPEN6</name>
              <description>使能唤醒引脚 WKUPn+1 每个位由软件置位和清零。注意：若在 WKUPn+1 引脚电平已为高（且 WKUPPn+1 选择上升沿）或已为低（且 WKUPPn+1 选择下降沿）时，使能 WKUPn+1 引脚（通过置位 WKUPENn+1 位），则会检测到一个额外的唤醒事件。</description>
              <bitOffset>5</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>WKUPP1</name>
              <description>WKUPn-7 唤醒引脚极性位 这些位定义 WKUPn-7 外部唤醒引脚用于事件检测的极性。</description>
              <bitOffset>8</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>WKUPP2</name>
              <description>WKUPn-7 唤醒引脚极性位 这些位定义 WKUPn-7 外部唤醒引脚用于事件检测的极性。</description>
              <bitOffset>9</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>WKUPP3</name>
              <description>WKUPn-7 唤醒引脚极性位 这些位定义 WKUPn-7 外部唤醒引脚用于事件检测的极性。</description>
              <bitOffset>10</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>WKUPP4</name>
              <description>WKUPn-7 唤醒引脚极性位 这些位定义 WKUPn-7 外部唤醒引脚用于事件检测的极性。</description>
              <bitOffset>11</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>WKUPP5</name>
              <description>WKUPn-7 唤醒引脚极性位 这些位定义 WKUPn-7 外部唤醒引脚用于事件检测的极性。</description>
              <bitOffset>12</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>WKUPP6</name>
              <description>WKUPn-7 唤醒引脚极性位 这些位定义 WKUPn-7 外部唤醒引脚用于事件检测的极性。</description>
              <bitOffset>13</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>WKUPPUPD1</name>
              <description>唤醒引脚上下拉配置</description>
              <bitOffset>16</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>WKUPPUPD2</name>
              <description>唤醒引脚上下拉配置</description>
              <bitOffset>18</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>WKUPPUPD3</name>
              <description>唤醒引脚上下拉配置</description>
              <bitOffset>20</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>WKUPPUPD4</name>
              <description>唤醒引脚上下拉配置</description>
              <bitOffset>22</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>WKUPPUPD5</name>
              <description>唤醒引脚上下拉配置</description>
              <bitOffset>24</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>WKUPPUPD6</name>
              <description>WKUP(truncate(n/2)-7) 唤醒引脚上下拉配置 这些位定义当 WKUPEN(truncate(n/2)-7) = 1 时使用的 I/O 焊盘上下拉配置。相关 GPIO 端口的上下拉配置应设为相同的值或设为 00。唤醒引脚的上下拉配置在待机模式下保持不变。</description>
              <bitOffset>26</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
          </fields>
        </register>
      </registers>
    </peripheral>
    <peripheral>
      <name>SPI1</name>
      <description>串行外设接口</description>
      <groupName>SPI</groupName>
      <baseAddress>0x40013000</baseAddress>
      <addressBlock>
        <offset>0x0</offset>
        <size>0x400</size>
        <usage>registers</usage>
      </addressBlock>
      <interrupt>
        <name>SPI1</name>
        <description>SPI1 全局中断</description>
        <value>35</value>
      </interrupt>
      <registers>
        <register>
          <name>CR1</name>
          <displayName>CR1</displayName>
          <description>控制寄存器 1</description>
          <addressOffset>0x0</addressOffset>
          <size>0x20</size>
          <resetValue>0x00000000</resetValue>
          <fields>
