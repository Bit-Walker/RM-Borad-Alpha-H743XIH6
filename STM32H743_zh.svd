              <bitOffset>17</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>NBREQ</name>
              <description>DMA 请求转发数量。定义在产生输出事件之前转发的 DMA 请求数量。在同步模式下，该字段还定义了同步事件到来之后需要转发的 DMA 请求数量，达到该数量后停止转发。实际转发的 DMA 请求数量为 NBREQ+1。注意：仅当 SE 和 EGE 位均复位时才能写入此字段。</description>
              <bitOffset>19</bitOffset>
              <bitWidth>5</bitWidth>
            </field>
            <field>
              <name>SYNC_ID</name>
              <description>同步输入选择</description>
              <bitOffset>24</bitOffset>
              <bitWidth>5</bitWidth>
            </field>
          </fields>
