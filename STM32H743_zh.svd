        </register>
        <register>
          <name>MDMA_C0ISR</name>
          <displayName>MDMA_C0ISR</displayName>
          <description>MDMA 通道 x 中断/状态寄存器</description>
          <addressOffset>0x40</addressOffset>
          <size>0x20</size>
          <access>read-only</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>TEIF0</name>
              <description>通道 x 传输错误中断标志。此位由硬件置位。软件向 DMA_IFCRy 寄存器的对应位写 1 可将其清零。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CTCIF0</name>
              <description>通道 x 通道传输完成中断标志。此位由硬件置位。软件向 DMA_IFCRy 寄存器的对应位写 1 可将其清零。当最后一个块传输完成且通道已自动禁用时，CTC 置位。当通道因 EN 位写 0 而挂起时，CTC 同样置位。</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>BRTIF0</name>
              <description>通道 x 块重复传输完成中断标志。此位由硬件置位。软件向 DMA_IFCRy 寄存器的对应位写 1 可将其清零。</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>BTIF0</name>
              <description>通道 x 块传输完成中断标志。此位由硬件置位。软件向 DMA_IFCRy 寄存器的对应位写 1 可将其清零。</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>TCIF0</name>
              <description>通道 x 缓冲区传输完成</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CRQA0</name>
              <description>通道 x 请求活跃标志</description>
              <bitOffset>16</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C0IFCR</name>
          <displayName>MDMA_C0IFCR</displayName>
          <description>MDMA 通道 x 中断标志清除寄存器</description>
          <addressOffset>0x44</addressOffset>
          <size>0x20</size>
          <access>write-only</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>CTEIF0</name>
              <description>通道 x 清除传输错误中断标志。向此位写 1 可将 MDMA_ISRy 寄存器中的 TEIFx 清零。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CCTCIF0</name>
              <description>通道 x 清除通道传输完成中断标志。向此位写 1 可将 MDMA_ISRy 寄存器中的 CTCIFx 清零。</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CBRTIF0</name>
              <description>通道 x 清除块重复传输完成中断标志。向此位写 1 可将 MDMA_ISRy 寄存器中的 BRTIFx 清零。</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CBTIF0</name>
              <description>通道 x 清除块传输完成中断标志。向此位写 1 可将 MDMA_ISRy 寄存器中的 BTIFx 清零。</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CLTCIF0</name>
              <description>通道 x 清除缓冲区传输完成中断标志。向此位写 1 可将 MDMA_ISRy 寄存器中的 TCIFx 清零。</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C0ESR</name>
          <displayName>MDMA_C0ESR</displayName>
          <description>MDMA 通道 x 错误状态寄存器</description>
          <addressOffset>0x48</addressOffset>
          <size>0x20</size>
          <access>read-only</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>TEA</name>
              <description>传输错误地址。在 MDMA 数据传输发生错误时，这些位由硬件置位与清零，与 TED 配合使用。该字段指示引发传输/访问错误的地址的低 7 位。软件可将其（截断至缓冲区传输长度大小）与当前 SAR/DAR 值相加来还原故障地址。注意：由于 FIFO 管理机制，SAR/DAR 当前值并不反映该最后地址。SAR/DAR 仅在（缓冲区）传完 TLEN+1 字节后才更新。注意：发生链接数据错误时此字段不会置位。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>7</bitWidth>
            </field>
            <field>
              <name>TED</name>
              <description>传输错误方向。在 MDMA 数据传输发生错误时，此位由硬件置位与清零。</description>
              <bitOffset>7</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>TELD</name>
              <description>传输错误（链接数据）。当读取块链接数据结构发生传输错误时，此位由硬件置位。软件向 DMA_IFCRy 寄存器中的 CTEIFx 位写 1 可将其清零。</description>
              <bitOffset>8</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>TEMD</name>
              <description>传输错误（掩码数据）。当写入掩码数据发生传输错误时，此位由硬件置位。软件向 DMA_IFCRy 寄存器中的 CTEIFx 位写 1 可将其清零。</description>
              <bitOffset>9</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>ASE</name>
              <description>地址/大小错误。当编程地址与数据大小不对齐时，此位由硬件置位。TED 将指示问题在源端还是目的端。软件向 DMA_IFCRy 寄存器中的 CTEIFx 位写 1 可将其清零。</description>
              <bitOffset>10</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>BSE</name>
              <description>块大小错误。当块大小不是源端或目的端数据大小的整数倍时，此位由硬件置位。TED 将指示问题在源端还是目的端。软件向 DMA_IFCRy 寄存器中的 CTEIFx 位写 1 可将其清零。</description>
              <bitOffset>11</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C0CR</name>
          <displayName>MDMA_C0CR</displayName>
          <description>此寄存器用于控制相应通道。</description>
          <addressOffset>0x4C</addressOffset>
          <size>0x20</size>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>EN</name>
              <description>通道使能</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>TEIE</name>
              <description>传输错误中断使能。此位由软件置位与清零。</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>CTCIE</name>
              <description>通道传输完成中断使能。此位由软件置位与清零。</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>BRTIE</name>
              <description>块重复传输中断使能。此位由软件置位与清零。</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>BTIE</name>
              <description>块传输中断使能。此位由软件置位与清零。</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>TCIE</name>
              <description>缓冲区传输完成中断使能。此位由软件置位与清零。</description>
              <bitOffset>5</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>PL</name>
              <description>优先级。这些位由软件置位与清零。这些位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>6</bitOffset>
              <bitWidth>2</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>BEX</name>
              <description>字节端序交换</description>
              <bitOffset>12</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>HEX</name>
              <description>半字端序交换</description>
              <bitOffset>13</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>WEX</name>
              <description>字端序交换</description>
              <bitOffset>14</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>SWRQ</name>
              <description>软件请求。向此位写 1 将使 MDMA_ISRy 寄存器中的 CRQAx 置位，从而激活通道 x 的请求。注意：可通过整个 CxCR 寄存器或地址偏移为 0x4E + 0x40*通道号的 8 位/16 位寄存器来激活 SWRQ。在软件请求的情况下，不会产生应答信号（无硬件信号，也不进行 CxMAR 写访问）。</description>
              <bitOffset>16</bitOffset>
              <bitWidth>1</bitWidth>
              <access>write-only</access>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C0TCR</name>
          <displayName>MDMA_C0TCR</displayName>
          <description>此寄存器用于配置相应通道。</description>
          <addressOffset>0x50</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>SINC</name>
              <description>源地址增量模式。这些位由软件置位与清零。这些位受保护，仅当 EN 为 0 时才可写入。注意：当源端为 AHB 总线时（SBUS=1），禁止 SINC = 00。在链接列表模式下，在一个块（单次或重复块传输模式中的最后一个块）结束时，此寄存器将从存储器（地址由当前 LAR[31:0] + 0x00 给出）重新加载。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>DINC</name>
              <description>目的地址增量模式。这些位由软件置位与清零。这些位受保护，仅当 EN 为 0 时才可写入。注意：当目的端为 AHB 总线时（DBUS=1），禁止 DINC = 00。</description>
              <bitOffset>2</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>SSIZE</name>
              <description>源数据大小。这些位由软件置位与清零。这些位受保护，仅当 EN 为 0 时才可写入。注意：若为 TCM 访问/AHB 端口编程了 11 值，将发生传输错误（TEIF 位置位）。若 SINCOS &lt; SSIZE 且 SINC != 00，结果不可预测。注意：当源端为 TCM/AHB 总线时（SBUS=1），禁止 SSIZE = 11（双字）。</description>
              <bitOffset>4</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>DSIZE</name>
              <description>目的数据大小。这些位由软件置位与清零。这些位受保护，仅当 EN 为 0 时才可写入。注意：若为 TCM 访问/AHB 端口编程了 11 值，将发生传输错误（TEIF 位置位）。若 DINCOS &lt; DSIZE 且 DINC != 00，结果不可预测。注意：当目的端为 TCM/AHB 总线时（DBUS=1），禁止 DSIZE = 11（双字）。</description>
              <bitOffset>6</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>SINCOS</name>
              <description>源地址增量偏移大小</description>
              <bitOffset>8</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>DINCOS</name>
              <description>目的地址增量偏移</description>
              <bitOffset>10</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>SBURST</name>
              <description>源端突发传输配置</description>
              <bitOffset>12</bitOffset>
              <bitWidth>3</bitWidth>
            </field>
            <field>
              <name>DBURST</name>
              <description>目的端突发传输配置</description>
              <bitOffset>15</bitOffset>
              <bitWidth>3</bitWidth>
            </field>
            <field>
              <name>TLEN</name>
              <description>缓冲区传输长度</description>
              <bitOffset>18</bitOffset>
              <bitWidth>7</bitWidth>
            </field>
            <field>
              <name>PKE</name>
              <description>打包使能。此位由软件置位与清零。若源数据大小小于目的数据大小，将按 PAM 值进行填充。若源数据大小大于目的数据大小，将被截断。对齐方式根据 PAM[0] 值确定。此位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>25</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>PAM</name>
              <description>填充/对齐模式。这些位由软件置位与清零。情况 1：源数据大小小于目的数据大小——3 种选项有效。情况 2：源数据大小大于目的数据大小——多余部分被丢弃。当 PKE = 1 或 DSIZE=SSIZE 时，这些位被忽略。这些位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>26</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>TRGM</name>
              <description>触发模式。这些位由软件置位与清零。注意：若当前块的 TRGM 为 11，则通过链接列表机制在当前块结束时加载的所有值必须保持相同的 TRGM=11 值和相同的 SWRM 值，否则结果未定义。这些位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>28</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>SWRM</name>
              <description>软件请求模式。此位由软件置位与清零。若当前有硬件或软件请求处于活跃状态，此位的变更将延迟到当前传输完成之后。若 CxMAR 包含有效地址，CxMDR 的值也将写入 CxMAR 地址。此位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>30</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>BWM</name>
              <description>缓冲写模式。此位由软件置位与清零。此位受保护，仅当 EN 为 0 时才可写入。注意：所有 MDMA 目的端访问均为不可缓存访问。</description>
              <bitOffset>31</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C0BNDTR</name>
          <displayName>MDMA_C0BNDTR</displayName>
          <description>MDMA 通道 x 块数据传输数量寄存器</description>
          <addressOffset>0x54</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>BNDT</name>
              <description>待传输数据块数量</description>
              <bitOffset>0</bitOffset>
              <bitWidth>17</bitWidth>
            </field>
            <field>
              <name>BRSUM</name>
              <description>块重复源地址更新模式。这些位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>18</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>BRDUM</name>
              <description>块重复目的地址更新模式。这些位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>19</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>BRC</name>
              <description>块重复计数。此字段包含当前块的重复次数（0 到 4095）。通道使能后，此寄存器为只读，指示剩余块数（不含当前块）。每次完整块传输完成后此寄存器递减。最后一个块传输完成后，此寄存器可保持为零，或自动从存储器重新加载（在链接列表模式下——即链接地址有效时）。这些位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>20</bitOffset>
              <bitWidth>12</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C0SAR</name>
          <displayName>MDMA_C0SAR</displayName>
          <description>MDMA 通道 x 源地址寄存器</description>
          <addressOffset>0x58</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>SAR</name>
              <description>源地址基址</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C0DAR</name>
          <displayName>MDMA_C0DAR</displayName>
          <description>MDMA 通道 x 目的地址寄存器</description>
          <addressOffset>0x5C</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>DAR</name>
              <description>目的地址基址</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C0BRUR</name>
          <displayName>MDMA_C0BRUR</displayName>
          <description>MDMA 通道 x 块重复地址更新寄存器</description>
          <addressOffset>0x60</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>SUV</name>
              <description>源地址更新值</description>
              <bitOffset>0</bitOffset>
              <bitWidth>16</bitWidth>
            </field>
            <field>
              <name>DUV</name>
              <description>目的地址更新值</description>
              <bitOffset>16</bitOffset>
              <bitWidth>16</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C0LAR</name>
          <displayName>MDMA_C0LAR</displayName>
          <description>MDMA 通道 x 链接地址寄存器</description>
          <addressOffset>0x64</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>LAR</name>
              <description>链接地址寄存器</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C0TBR</name>
          <displayName>MDMA_C0TBR</displayName>
          <description>MDMA 通道 x 触发与总线选择寄存器</description>
          <addressOffset>0x68</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>TSEL</name>
              <description>触发选择</description>
              <bitOffset>0</bitOffset>
              <bitWidth>6</bitWidth>
            </field>
            <field>
              <name>SBUS</name>
              <description>源总线选择。此位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>16</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DBUS</name>
              <description>目的总线选择。此位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>17</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C0MAR</name>
          <displayName>MDMA_C0MAR</displayName>
          <description>MDMA 通道 x 掩码地址寄存器</description>
          <addressOffset>0x70</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>MAR</name>
              <description>掩码地址</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C0MDR</name>
          <displayName>MDMA_C0MDR</displayName>
          <description>MDMA 通道 x 掩码数据寄存器</description>
          <addressOffset>0x74</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>MDR</name>
              <description>掩码数据</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C1ISR</name>
          <displayName>MDMA_C1ISR</displayName>
          <description>MDMA 通道 x 中断/状态寄存器</description>
          <addressOffset>0x80</addressOffset>
          <size>0x20</size>
          <access>read-only</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>TEIF1</name>
              <description>通道 x 传输错误中断标志。此位由硬件置位。软件向 DMA_IFCRy 寄存器的对应位写 1 可将其清零。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CTCIF1</name>
              <description>通道 x 通道传输完成中断标志。此位由硬件置位。软件向 DMA_IFCRy 寄存器的对应位写 1 可将其清零。当最后一个块传输完成且通道已自动禁用时，CTC 置位。当通道因 EN 位写 0 而挂起时，CTC 同样置位。</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>BRTIF1</name>
              <description>通道 x 块重复传输完成中断标志。此位由硬件置位。软件向 DMA_IFCRy 寄存器的对应位写 1 可将其清零。</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>BTIF1</name>
              <description>通道 x 块传输完成中断标志。此位由硬件置位。软件向 DMA_IFCRy 寄存器的对应位写 1 可将其清零。</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>TCIF1</name>
              <description>通道 x 缓冲区传输完成</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CRQA1</name>
              <description>通道 x 请求活跃标志</description>
              <bitOffset>16</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C1IFCR</name>
          <displayName>MDMA_C1IFCR</displayName>
          <description>MDMA 通道 x 中断标志清除寄存器</description>
          <addressOffset>0x84</addressOffset>
          <size>0x20</size>
          <access>write-only</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>CTEIF1</name>
              <description>通道 x 清除传输错误中断标志。向此位写 1 可将 MDMA_ISRy 寄存器中的 TEIFx 清零。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CCTCIF1</name>
              <description>通道 x 清除通道传输完成中断标志。向此位写 1 可将 MDMA_ISRy 寄存器中的 CTCIFx 清零。</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CBRTIF1</name>
              <description>通道 x 清除块重复传输完成中断标志。向此位写 1 可将 MDMA_ISRy 寄存器中的 BRTIFx 清零。</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CBTIF1</name>
              <description>通道 x 清除块传输完成中断标志。向此位写 1 可将 MDMA_ISRy 寄存器中的 BTIFx 清零。</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CLTCIF1</name>
              <description>通道 x 清除缓冲区传输完成中断标志。向此位写 1 可将 MDMA_ISRy 寄存器中的 TCIFx 清零。</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C1ESR</name>
          <displayName>MDMA_C1ESR</displayName>
          <description>MDMA 通道 x 错误状态寄存器</description>
          <addressOffset>0x88</addressOffset>
          <size>0x20</size>
          <access>read-only</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>TEA</name>
              <description>传输错误地址。在 MDMA 数据传输发生错误时，这些位由硬件置位与清零，与 TED 配合使用。该字段指示引发传输/访问错误的地址的低 7 位。软件可将其（截断至缓冲区传输长度大小）与当前 SAR/DAR 值相加来还原故障地址。注意：由于 FIFO 管理机制，SAR/DAR 当前值并不反映该最后地址。SAR/DAR 仅在（缓冲区）传完 TLEN+1 字节后才更新。注意：发生链接数据错误时此字段不会置位。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>7</bitWidth>
            </field>
            <field>
              <name>TED</name>
              <description>传输错误方向。在 MDMA 数据传输发生错误时，此位由硬件置位与清零。</description>
              <bitOffset>7</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>TELD</name>
              <description>传输错误（链接数据）。当读取块链接数据结构发生传输错误时，此位由硬件置位。软件向 DMA_IFCRy 寄存器中的 CTEIFx 位写 1 可将其清零。</description>
              <bitOffset>8</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>TEMD</name>
              <description>传输错误（掩码数据）。当写入掩码数据发生传输错误时，此位由硬件置位。软件向 DMA_IFCRy 寄存器中的 CTEIFx 位写 1 可将其清零。</description>
              <bitOffset>9</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>ASE</name>
              <description>地址/大小错误。当编程地址与数据大小不对齐时，此位由硬件置位。TED 将指示问题在源端还是目的端。软件向 DMA_IFCRy 寄存器中的 CTEIFx 位写 1 可将其清零。</description>
              <bitOffset>10</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>BSE</name>
              <description>块大小错误。当块大小不是源端或目的端数据大小的整数倍时，此位由硬件置位。TED 将指示问题在源端还是目的端。软件向 DMA_IFCRy 寄存器中的 CTEIFx 位写 1 可将其清零。</description>
              <bitOffset>11</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C1CR</name>
          <displayName>MDMA_C1CR</displayName>
          <description>此寄存器用于控制相应通道。</description>
          <addressOffset>0x8C</addressOffset>
          <size>0x20</size>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>EN</name>
              <description>通道使能</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>TEIE</name>
              <description>传输错误中断使能。此位由软件置位与清零。</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>CTCIE</name>
              <description>通道传输完成中断使能。此位由软件置位与清零。</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>BRTIE</name>
              <description>块重复传输中断使能。此位由软件置位与清零。</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>BTIE</name>
              <description>块传输中断使能。此位由软件置位与清零。</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>TCIE</name>
              <description>缓冲区传输完成中断使能。此位由软件置位与清零。</description>
              <bitOffset>5</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>PL</name>
              <description>优先级。这些位由软件置位与清零。这些位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>6</bitOffset>
              <bitWidth>2</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>BEX</name>
              <description>字节端序交换</description>
              <bitOffset>12</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>HEX</name>
              <description>半字端序交换</description>
              <bitOffset>13</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>WEX</name>
              <description>字端序交换</description>
              <bitOffset>14</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>SWRQ</name>
              <description>软件请求。向此位写 1 将使 MDMA_ISRy 寄存器中的 CRQAx 置位，从而激活通道 x 的请求。注意：可通过整个 CxCR 寄存器或地址偏移为 0x4E + 0x40*通道号的 8 位/16 位寄存器来激活 SWRQ。在软件请求的情况下，不会产生应答信号（无硬件信号，也不进行 CxMAR 写访问）。</description>
              <bitOffset>16</bitOffset>
              <bitWidth>1</bitWidth>
              <access>write-only</access>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C1TCR</name>
          <displayName>MDMA_C1TCR</displayName>
          <description>此寄存器用于配置相应通道。</description>
          <addressOffset>0x90</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>SINC</name>
              <description>源地址增量模式。这些位由软件置位与清零。这些位受保护，仅当 EN 为 0 时才可写入。注意：当源端为 AHB 总线时（SBUS=1），禁止 SINC = 00。在链接列表模式下，在一个块（单次或重复块传输模式中的最后一个块）结束时，此寄存器将从存储器（地址由当前 LAR[31:0] + 0x00 给出）重新加载。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>DINC</name>
              <description>目的地址增量模式。这些位由软件置位与清零。这些位受保护，仅当 EN 为 0 时才可写入。注意：当目的端为 AHB 总线时（DBUS=1），禁止 DINC = 00。</description>
              <bitOffset>2</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>SSIZE</name>
              <description>源数据大小。这些位由软件置位与清零。这些位受保护，仅当 EN 为 0 时才可写入。注意：若为 TCM 访问/AHB 端口编程了 11 值，将发生传输错误（TEIF 位置位）。若 SINCOS &lt; SSIZE 且 SINC != 00，结果不可预测。注意：当源端为 TCM/AHB 总线时（SBUS=1），禁止 SSIZE = 11（双字）。</description>
              <bitOffset>4</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>DSIZE</name>
              <description>目的数据大小。这些位由软件置位与清零。这些位受保护，仅当 EN 为 0 时才可写入。注意：若为 TCM 访问/AHB 端口编程了 11 值，将发生传输错误（TEIF 位置位）。若 DINCOS &lt; DSIZE 且 DINC != 00，结果不可预测。注意：当目的端为 TCM/AHB 总线时（DBUS=1），禁止 DSIZE = 11（双字）。</description>
              <bitOffset>6</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>SINCOS</name>
              <description>源地址增量偏移大小</description>
              <bitOffset>8</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>DINCOS</name>
              <description>目的地址增量偏移</description>
              <bitOffset>10</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>SBURST</name>
              <description>源端突发传输配置</description>
              <bitOffset>12</bitOffset>
              <bitWidth>3</bitWidth>
            </field>
            <field>
              <name>DBURST</name>
              <description>目的端突发传输配置</description>
              <bitOffset>15</bitOffset>
              <bitWidth>3</bitWidth>
            </field>
            <field>
              <name>TLEN</name>
              <description>缓冲区传输长度</description>
              <bitOffset>18</bitOffset>
              <bitWidth>7</bitWidth>
            </field>
            <field>
              <name>PKE</name>
              <description>打包使能。此位由软件置位与清零。若源数据大小小于目的数据大小，将按 PAM 值进行填充。若源数据大小大于目的数据大小，将被截断。对齐方式根据 PAM[0] 值确定。此位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>25</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>PAM</name>
              <description>填充/对齐模式。这些位由软件置位与清零。情况 1：源数据大小小于目的数据大小——3 种选项有效。情况 2：源数据大小大于目的数据大小——多余部分被丢弃。当 PKE = 1 或 DSIZE=SSIZE 时，这些位被忽略。这些位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>26</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>TRGM</name>
              <description>触发模式。这些位由软件置位与清零。注意：若当前块的 TRGM 为 11，则通过链接列表机制在当前块结束时加载的所有值必须保持相同的 TRGM=11 值和相同的 SWRM 值，否则结果未定义。这些位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>28</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>SWRM</name>
              <description>软件请求模式。此位由软件置位与清零。若当前有硬件或软件请求处于活跃状态，此位的变更将延迟到当前传输完成之后。若 CxMAR 包含有效地址，CxMDR 的值也将写入 CxMAR 地址。此位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>30</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>BWM</name>
              <description>缓冲写模式。此位由软件置位与清零。此位受保护，仅当 EN 为 0 时才可写入。注意：所有 MDMA 目的端访问均为不可缓存访问。</description>
              <bitOffset>31</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C1BNDTR</name>
          <displayName>MDMA_C1BNDTR</displayName>
          <description>MDMA 通道 x 块数据传输数量寄存器</description>
          <addressOffset>0x94</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>BNDT</name>
              <description>待传输数据块数量</description>
              <bitOffset>0</bitOffset>
              <bitWidth>17</bitWidth>
            </field>
            <field>
              <name>BRSUM</name>
              <description>块重复源地址更新模式。这些位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>18</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>BRDUM</name>
              <description>块重复目的地址更新模式。这些位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>19</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>BRC</name>
              <description>块重复计数。此字段包含当前块的重复次数（0 到 4095）。通道使能后，此寄存器为只读，指示剩余块数（不含当前块）。每次完整块传输完成后此寄存器递减。最后一个块传输完成后，此寄存器可保持为零，或自动从存储器重新加载（在链接列表模式下——即链接地址有效时）。这些位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>20</bitOffset>
              <bitWidth>12</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C1SAR</name>
          <displayName>MDMA_C1SAR</displayName>
          <description>MDMA 通道 x 源地址寄存器</description>
          <addressOffset>0x98</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>SAR</name>
              <description>源地址基址</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C1DAR</name>
          <displayName>MDMA_C1DAR</displayName>
          <description>MDMA 通道 x 目的地址寄存器</description>
          <addressOffset>0x9C</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>DAR</name>
              <description>目的地址基址</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C1BRUR</name>
          <displayName>MDMA_C1BRUR</displayName>
          <description>MDMA 通道 x 块重复地址更新寄存器</description>
          <addressOffset>0xA0</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>SUV</name>
              <description>源地址更新值</description>
              <bitOffset>0</bitOffset>
              <bitWidth>16</bitWidth>
            </field>
            <field>
              <name>DUV</name>
              <description>目的地址更新值</description>
              <bitOffset>16</bitOffset>
              <bitWidth>16</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C1LAR</name>
          <displayName>MDMA_C1LAR</displayName>
          <description>MDMA 通道 x 链接地址寄存器</description>
          <addressOffset>0xA4</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>LAR</name>
              <description>链接地址寄存器</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C1TBR</name>
          <displayName>MDMA_C1TBR</displayName>
          <description>MDMA 通道 x 触发与总线选择寄存器</description>
          <addressOffset>0xA8</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>TSEL</name>
              <description>触发选择</description>
              <bitOffset>0</bitOffset>
              <bitWidth>6</bitWidth>
            </field>
            <field>
              <name>SBUS</name>
              <description>源总线选择。此位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>16</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DBUS</name>
              <description>目的总线选择。此位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>17</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C1MAR</name>
          <displayName>MDMA_C1MAR</displayName>
          <description>MDMA 通道 x 掩码地址寄存器</description>
          <addressOffset>0xB0</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>MAR</name>
              <description>掩码地址</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C1MDR</name>
          <displayName>MDMA_C1MDR</displayName>
          <description>MDMA 通道 x 掩码数据寄存器</description>
          <addressOffset>0xB4</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>MDR</name>
              <description>掩码数据</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C2ISR</name>
          <displayName>MDMA_C2ISR</displayName>
          <description>MDMA 通道 x 中断/状态寄存器</description>
          <addressOffset>0xC0</addressOffset>
          <size>0x20</size>
          <access>read-only</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>TEIF2</name>
              <description>通道 x 传输错误中断标志。此位由硬件置位。软件向 DMA_IFCRy 寄存器的对应位写 1 可将其清零。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CTCIF2</name>
              <description>通道 x 通道传输完成中断标志。此位由硬件置位。软件向 DMA_IFCRy 寄存器的对应位写 1 可将其清零。当最后一个块传输完成且通道已自动禁用时，CTC 置位。当通道因 EN 位写 0 而挂起时，CTC 同样置位。</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>BRTIF2</name>
              <description>通道 x 块重复传输完成中断标志。此位由硬件置位。软件向 DMA_IFCRy 寄存器的对应位写 1 可将其清零。</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>BTIF2</name>
              <description>通道 x 块传输完成中断标志。此位由硬件置位。软件向 DMA_IFCRy 寄存器的对应位写 1 可将其清零。</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>TCIF2</name>
              <description>通道 x 缓冲区传输完成</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CRQA2</name>
              <description>通道 x 请求活跃标志</description>
              <bitOffset>16</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C2IFCR</name>
          <displayName>MDMA_C2IFCR</displayName>
          <description>MDMA 通道 x 中断标志清除寄存器</description>
          <addressOffset>0xC4</addressOffset>
          <size>0x20</size>
          <access>write-only</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>CTEIF2</name>
              <description>通道 x 清除传输错误中断标志。向此位写 1 可将 MDMA_ISRy 寄存器中的 TEIFx 清零。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CCTCIF2</name>
              <description>通道 x 清除通道传输完成中断标志。向此位写 1 可将 MDMA_ISRy 寄存器中的 CTCIFx 清零。</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CBRTIF2</name>
              <description>通道 x 清除块重复传输完成中断标志。向此位写 1 可将 MDMA_ISRy 寄存器中的 BRTIFx 清零。</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CBTIF2</name>
              <description>通道 x 清除块传输完成中断标志。向此位写 1 可将 MDMA_ISRy 寄存器中的 BTIFx 清零。</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CLTCIF2</name>
              <description>通道 x 清除缓冲区传输完成中断标志。向此位写 1 可将 MDMA_ISRy 寄存器中的 TCIFx 清零。</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C2ESR</name>
          <displayName>MDMA_C2ESR</displayName>
          <description>MDMA 通道 x 错误状态寄存器</description>
          <addressOffset>0xC8</addressOffset>
          <size>0x20</size>
          <access>read-only</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>TEA</name>
              <description>传输错误地址。在 MDMA 数据传输发生错误时，这些位由硬件置位与清零，与 TED 配合使用。该字段指示引发传输/访问错误的地址的低 7 位。软件可将其（截断至缓冲区传输长度大小）与当前 SAR/DAR 值相加来还原故障地址。注意：由于 FIFO 管理机制，SAR/DAR 当前值并不反映该最后地址。SAR/DAR 仅在（缓冲区）传完 TLEN+1 字节后才更新。注意：发生链接数据错误时此字段不会置位。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>7</bitWidth>
            </field>
            <field>
              <name>TED</name>
              <description>传输错误方向。在 MDMA 数据传输发生错误时，此位由硬件置位与清零。</description>
              <bitOffset>7</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>TELD</name>
              <description>传输错误（链接数据）。当读取块链接数据结构发生传输错误时，此位由硬件置位。软件向 DMA_IFCRy 寄存器中的 CTEIFx 位写 1 可将其清零。</description>
              <bitOffset>8</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>TEMD</name>
              <description>传输错误（掩码数据）。当写入掩码数据发生传输错误时，此位由硬件置位。软件向 DMA_IFCRy 寄存器中的 CTEIFx 位写 1 可将其清零。</description>
              <bitOffset>9</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>ASE</name>
              <description>地址/大小错误。当编程地址与数据大小不对齐时，此位由硬件置位。TED 将指示问题在源端还是目的端。软件向 DMA_IFCRy 寄存器中的 CTEIFx 位写 1 可将其清零。</description>
              <bitOffset>10</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>BSE</name>
              <description>块大小错误。当块大小不是源端或目的端数据大小的整数倍时，此位由硬件置位。TED 将指示问题在源端还是目的端。软件向 DMA_IFCRy 寄存器中的 CTEIFx 位写 1 可将其清零。</description>
              <bitOffset>11</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C2CR</name>
          <displayName>MDMA_C2CR</displayName>
          <description>此寄存器用于控制相应通道。</description>
          <addressOffset>0xCC</addressOffset>
          <size>0x20</size>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>EN</name>
              <description>通道使能</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>TEIE</name>
              <description>传输错误中断使能。此位由软件置位与清零。</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>CTCIE</name>
              <description>通道传输完成中断使能。此位由软件置位与清零。</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>BRTIE</name>
              <description>块重复传输中断使能。此位由软件置位与清零。</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>BTIE</name>
              <description>块传输中断使能。此位由软件置位与清零。</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>TCIE</name>
              <description>缓冲区传输完成中断使能。此位由软件置位与清零。</description>
              <bitOffset>5</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>PL</name>
              <description>优先级。这些位由软件置位与清零。这些位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>6</bitOffset>
              <bitWidth>2</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>BEX</name>
              <description>字节端序交换</description>
              <bitOffset>12</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>HEX</name>
              <description>半字端序交换</description>
              <bitOffset>13</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>WEX</name>
              <description>字端序交换</description>
              <bitOffset>14</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>SWRQ</name>
              <description>软件请求。向此位写 1 将使 MDMA_ISRy 寄存器中的 CRQAx 置位，从而激活通道 x 的请求。注意：可通过整个 CxCR 寄存器或地址偏移为 0x4E + 0x40*通道号的 8 位/16 位寄存器来激活 SWRQ。在软件请求的情况下，不会产生应答信号（无硬件信号，也不进行 CxMAR 写访问）。</description>
              <bitOffset>16</bitOffset>
              <bitWidth>1</bitWidth>
              <access>write-only</access>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C2TCR</name>
          <displayName>MDMA_C2TCR</displayName>
          <description>此寄存器用于配置相应通道。</description>
          <addressOffset>0xD0</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>SINC</name>
              <description>源地址增量模式。这些位由软件置位与清零。这些位受保护，仅当 EN 为 0 时才可写入。注意：当源端为 AHB 总线时（SBUS=1），禁止 SINC = 00。在链接列表模式下，在一个块（单次或重复块传输模式中的最后一个块）结束时，此寄存器将从存储器（地址由当前 LAR[31:0] + 0x00 给出）重新加载。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>DINC</name>
              <description>目的地址增量模式。这些位由软件置位与清零。这些位受保护，仅当 EN 为 0 时才可写入。注意：当目的端为 AHB 总线时（DBUS=1），禁止 DINC = 00。</description>
              <bitOffset>2</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>SSIZE</name>
              <description>源数据大小。这些位由软件置位与清零。这些位受保护，仅当 EN 为 0 时才可写入。注意：若为 TCM 访问/AHB 端口编程了 11 值，将发生传输错误（TEIF 位置位）。若 SINCOS &lt; SSIZE 且 SINC != 00，结果不可预测。注意：当源端为 TCM/AHB 总线时（SBUS=1），禁止 SSIZE = 11（双字）。</description>
              <bitOffset>4</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>DSIZE</name>
              <description>目的数据大小。这些位由软件置位与清零。这些位受保护，仅当 EN 为 0 时才可写入。注意：若为 TCM 访问/AHB 端口编程了 11 值，将发生传输错误（TEIF 位置位）。若 DINCOS &lt; DSIZE 且 DINC != 00，结果不可预测。注意：当目的端为 TCM/AHB 总线时（DBUS=1），禁止 DSIZE = 11（双字）。</description>
              <bitOffset>6</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>SINCOS</name>
              <description>源地址增量偏移大小</description>
              <bitOffset>8</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>DINCOS</name>
              <description>目的地址增量偏移</description>
              <bitOffset>10</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>SBURST</name>
              <description>源端突发传输配置</description>
              <bitOffset>12</bitOffset>
              <bitWidth>3</bitWidth>
            </field>
            <field>
              <name>DBURST</name>
              <description>目的端突发传输配置</description>
              <bitOffset>15</bitOffset>
              <bitWidth>3</bitWidth>
            </field>
            <field>
              <name>TLEN</name>
              <description>缓冲区传输长度</description>
              <bitOffset>18</bitOffset>
              <bitWidth>7</bitWidth>
            </field>
            <field>
              <name>PKE</name>
              <description>打包使能。此位由软件置位与清零。若源数据大小小于目的数据大小，将按 PAM 值进行填充。若源数据大小大于目的数据大小，将被截断。对齐方式根据 PAM[0] 值确定。此位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>25</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>PAM</name>
              <description>填充/对齐模式。这些位由软件置位与清零。情况 1：源数据大小小于目的数据大小——3 种选项有效。情况 2：源数据大小大于目的数据大小——多余部分被丢弃。当 PKE = 1 或 DSIZE=SSIZE 时，这些位被忽略。这些位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>26</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>TRGM</name>
              <description>触发模式。这些位由软件置位与清零。注意：若当前块的 TRGM 为 11，则通过链接列表机制在当前块结束时加载的所有值必须保持相同的 TRGM=11 值和相同的 SWRM 值，否则结果未定义。这些位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>28</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>SWRM</name>
              <description>软件请求模式。此位由软件置位与清零。若当前有硬件或软件请求处于活跃状态，此位的变更将延迟到当前传输完成之后。若 CxMAR 包含有效地址，CxMDR 的值也将写入 CxMAR 地址。此位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>30</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>BWM</name>
              <description>缓冲写模式。此位由软件置位与清零。此位受保护，仅当 EN 为 0 时才可写入。注意：所有 MDMA 目的端访问均为不可缓存访问。</description>
              <bitOffset>31</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C2BNDTR</name>
          <displayName>MDMA_C2BNDTR</displayName>
          <description>MDMA 通道 x 块数据传输数量寄存器</description>
          <addressOffset>0xD4</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>BNDT</name>
              <description>待传输数据块数量</description>
              <bitOffset>0</bitOffset>
              <bitWidth>17</bitWidth>
            </field>
            <field>
              <name>BRSUM</name>
              <description>块重复源地址更新模式。这些位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>18</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>BRDUM</name>
              <description>块重复目的地址更新模式。这些位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>19</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>BRC</name>
              <description>块重复计数。此字段包含当前块的重复次数（0 到 4095）。通道使能后，此寄存器为只读，指示剩余块数（不含当前块）。每次完整块传输完成后此寄存器递减。最后一个块传输完成后，此寄存器可保持为零，或自动从存储器重新加载（在链接列表模式下——即链接地址有效时）。这些位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>20</bitOffset>
              <bitWidth>12</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C2SAR</name>
          <displayName>MDMA_C2SAR</displayName>
          <description>MDMA 通道 x 源地址寄存器</description>
          <addressOffset>0xD8</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>SAR</name>
              <description>源地址基址</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C2DAR</name>
          <displayName>MDMA_C2DAR</displayName>
          <description>MDMA 通道 x 目的地址寄存器</description>
          <addressOffset>0xDC</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>DAR</name>
              <description>目的地址基址</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C2BRUR</name>
          <displayName>MDMA_C2BRUR</displayName>
          <description>MDMA 通道 x 块重复地址更新寄存器</description>
          <addressOffset>0xE0</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>SUV</name>
              <description>源地址更新值</description>
              <bitOffset>0</bitOffset>
              <bitWidth>16</bitWidth>
            </field>
            <field>
              <name>DUV</name>
              <description>目的地址更新值</description>
              <bitOffset>16</bitOffset>
              <bitWidth>16</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C2LAR</name>
          <displayName>MDMA_C2LAR</displayName>
          <description>MDMA 通道 x 链接地址寄存器</description>
          <addressOffset>0xE4</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>LAR</name>
              <description>链接地址寄存器</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C2TBR</name>
          <displayName>MDMA_C2TBR</displayName>
          <description>MDMA 通道 x 触发与总线选择寄存器</description>
          <addressOffset>0xE8</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>TSEL</name>
              <description>触发选择</description>
              <bitOffset>0</bitOffset>
              <bitWidth>6</bitWidth>
            </field>
            <field>
              <name>SBUS</name>
              <description>源总线选择。此位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>16</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DBUS</name>
              <description>目的总线选择。此位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>17</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C2MAR</name>
          <displayName>MDMA_C2MAR</displayName>
          <description>MDMA 通道 x 掩码地址寄存器</description>
          <addressOffset>0xF0</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>MAR</name>
              <description>掩码地址</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C2MDR</name>
          <displayName>MDMA_C2MDR</displayName>
          <description>MDMA 通道 x 掩码数据寄存器</description>
          <addressOffset>0xF4</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>MDR</name>
              <description>掩码数据</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C3ISR</name>
          <displayName>MDMA_C3ISR</displayName>
          <description>MDMA 通道 x 中断/状态寄存器</description>
          <addressOffset>0x100</addressOffset>
          <size>0x20</size>
          <access>read-only</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>TEIF3</name>
              <description>通道 x 传输错误中断标志。此位由硬件置位。软件向 DMA_IFCRy 寄存器的对应位写 1 可将其清零。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CTCIF3</name>
              <description>通道 x 通道传输完成中断标志。此位由硬件置位。软件向 DMA_IFCRy 寄存器的对应位写 1 可将其清零。当最后一个块传输完成且通道已自动禁用时，CTC 置位。当通道因 EN 位写 0 而挂起时，CTC 同样置位。</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>BRTIF3</name>
              <description>通道 x 块重复传输完成中断标志。此位由硬件置位。软件向 DMA_IFCRy 寄存器的对应位写 1 可将其清零。</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>BTIF3</name>
              <description>通道 x 块传输完成中断标志。此位由硬件置位。软件向 DMA_IFCRy 寄存器的对应位写 1 可将其清零。</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>TCIF3</name>
              <description>通道 x 缓冲区传输完成</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CRQA3</name>
              <description>通道 x 请求活跃标志</description>
              <bitOffset>16</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C3IFCR</name>
          <displayName>MDMA_C3IFCR</displayName>
          <description>MDMA 通道 x 中断标志清除寄存器</description>
          <addressOffset>0x104</addressOffset>
          <size>0x20</size>
          <access>write-only</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>CTEIF3</name>
              <description>通道 x 清除传输错误中断标志。向此位写 1 可将 MDMA_ISRy 寄存器中的 TEIFx 清零。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CCTCIF3</name>
              <description>通道 x 清除通道传输完成中断标志。向此位写 1 可将 MDMA_ISRy 寄存器中的 CTCIFx 清零。</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CBRTIF3</name>
              <description>通道 x 清除块重复传输完成中断标志。向此位写 1 可将 MDMA_ISRy 寄存器中的 BRTIFx 清零。</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CBTIF3</name>
              <description>通道 x 清除块传输完成中断标志。向此位写 1 可将 MDMA_ISRy 寄存器中的 BTIFx 清零。</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CLTCIF3</name>
              <description>通道 x 清除缓冲区传输完成中断标志。向此位写 1 可将 MDMA_ISRy 寄存器中的 TCIFx 清零。</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C3ESR</name>
          <displayName>MDMA_C3ESR</displayName>
          <description>MDMA 通道 x 错误状态寄存器</description>
          <addressOffset>0x108</addressOffset>
          <size>0x20</size>
          <access>read-only</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>TEA</name>
              <description>传输错误地址。在 MDMA 数据传输发生错误时，这些位由硬件置位与清零，与 TED 配合使用。该字段指示引发传输/访问错误的地址的低 7 位。软件可将其（截断至缓冲区传输长度大小）与当前 SAR/DAR 值相加来还原故障地址。注意：由于 FIFO 管理机制，SAR/DAR 当前值并不反映该最后地址。SAR/DAR 仅在（缓冲区）传完 TLEN+1 字节后才更新。注意：发生链接数据错误时此字段不会置位。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>7</bitWidth>
            </field>
            <field>
              <name>TED</name>
              <description>传输错误方向。在 MDMA 数据传输发生错误时，此位由硬件置位与清零。</description>
              <bitOffset>7</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>TELD</name>
              <description>传输错误（链接数据）。当读取块链接数据结构发生传输错误时，此位由硬件置位。软件向 DMA_IFCRy 寄存器中的 CTEIFx 位写 1 可将其清零。</description>
              <bitOffset>8</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>TEMD</name>
              <description>传输错误（掩码数据）。当写入掩码数据发生传输错误时，此位由硬件置位。软件向 DMA_IFCRy 寄存器中的 CTEIFx 位写 1 可将其清零。</description>
              <bitOffset>9</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>ASE</name>
              <description>地址/大小错误。当编程地址与数据大小不对齐时，此位由硬件置位。TED 将指示问题在源端还是目的端。软件向 DMA_IFCRy 寄存器中的 CTEIFx 位写 1 可将其清零。</description>
              <bitOffset>10</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>BSE</name>
              <description>块大小错误。当块大小不是源端或目的端数据大小的整数倍时，此位由硬件置位。TED 将指示问题在源端还是目的端。软件向 DMA_IFCRy 寄存器中的 CTEIFx 位写 1 可将其清零。</description>
              <bitOffset>11</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C3CR</name>
          <displayName>MDMA_C3CR</displayName>
          <description>此寄存器用于控制相应通道。</description>
          <addressOffset>0x10C</addressOffset>
          <size>0x20</size>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>EN</name>
              <description>通道使能</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>TEIE</name>
              <description>传输错误中断使能。此位由软件置位与清零。</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>CTCIE</name>
              <description>通道传输完成中断使能。此位由软件置位与清零。</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>BRTIE</name>
              <description>块重复传输中断使能。此位由软件置位与清零。</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>BTIE</name>
              <description>块传输中断使能。此位由软件置位与清零。</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>TCIE</name>
              <description>缓冲区传输完成中断使能。此位由软件置位与清零。</description>
              <bitOffset>5</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>PL</name>
              <description>优先级。这些位由软件置位与清零。这些位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>6</bitOffset>
              <bitWidth>2</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>BEX</name>
              <description>字节端序交换</description>
              <bitOffset>12</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>HEX</name>
              <description>半字端序交换</description>
              <bitOffset>13</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>WEX</name>
              <description>字端序交换</description>
              <bitOffset>14</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>SWRQ</name>
              <description>软件请求。向此位写 1 将使 MDMA_ISRy 寄存器中的 CRQAx 置位，从而激活通道 x 的请求。注意：可通过整个 CxCR 寄存器或地址偏移为 0x4E + 0x40*通道号的 8 位/16 位寄存器来激活 SWRQ。在软件请求的情况下，不会产生应答信号（无硬件信号，也不进行 CxMAR 写访问）。</description>
              <bitOffset>16</bitOffset>
              <bitWidth>1</bitWidth>
              <access>write-only</access>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C3TCR</name>
          <displayName>MDMA_C3TCR</displayName>
          <description>此寄存器用于配置相应通道。</description>
          <addressOffset>0x110</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>SINC</name>
              <description>源地址增量模式。这些位由软件置位与清零。这些位受保护，仅当 EN 为 0 时才可写入。注意：当源端为 AHB 总线时（SBUS=1），禁止 SINC = 00。在链接列表模式下，在一个块（单次或重复块传输模式中的最后一个块）结束时，此寄存器将从存储器（地址由当前 LAR[31:0] + 0x00 给出）重新加载。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>DINC</name>
              <description>目的地址增量模式。这些位由软件置位与清零。这些位受保护，仅当 EN 为 0 时才可写入。注意：当目的端为 AHB 总线时（DBUS=1），禁止 DINC = 00。</description>
              <bitOffset>2</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>SSIZE</name>
              <description>源数据大小。这些位由软件置位与清零。这些位受保护，仅当 EN 为 0 时才可写入。注意：若为 TCM 访问/AHB 端口编程了 11 值，将发生传输错误（TEIF 位置位）。若 SINCOS &lt; SSIZE 且 SINC != 00，结果不可预测。注意：当源端为 TCM/AHB 总线时（SBUS=1），禁止 SSIZE = 11（双字）。</description>
              <bitOffset>4</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>DSIZE</name>
              <description>目的数据大小。这些位由软件置位与清零。这些位受保护，仅当 EN 为 0 时才可写入。注意：若为 TCM 访问/AHB 端口编程了 11 值，将发生传输错误（TEIF 位置位）。若 DINCOS &lt; DSIZE 且 DINC != 00，结果不可预测。注意：当目的端为 TCM/AHB 总线时（DBUS=1），禁止 DSIZE = 11（双字）。</description>
              <bitOffset>6</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>SINCOS</name>
              <description>源地址增量偏移大小</description>
              <bitOffset>8</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>DINCOS</name>
              <description>目的地址增量偏移</description>
              <bitOffset>10</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>SBURST</name>
              <description>源端突发传输配置</description>
              <bitOffset>12</bitOffset>
              <bitWidth>3</bitWidth>
            </field>
            <field>
              <name>DBURST</name>
              <description>目的端突发传输配置</description>
              <bitOffset>15</bitOffset>
              <bitWidth>3</bitWidth>
            </field>
            <field>
              <name>TLEN</name>
              <description>缓冲区传输长度</description>
              <bitOffset>18</bitOffset>
              <bitWidth>7</bitWidth>
            </field>
            <field>
              <name>PKE</name>
              <description>打包使能。此位由软件置位与清零。若源数据大小小于目的数据大小，将按 PAM 值进行填充。若源数据大小大于目的数据大小，将被截断。对齐方式根据 PAM[0] 值确定。此位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>25</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>PAM</name>
              <description>填充/对齐模式。这些位由软件置位与清零。情况 1：源数据大小小于目的数据大小——3 种选项有效。情况 2：源数据大小大于目的数据大小——多余部分被丢弃。当 PKE = 1 或 DSIZE=SSIZE 时，这些位被忽略。这些位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>26</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>TRGM</name>
              <description>触发模式。这些位由软件置位与清零。注意：若当前块的 TRGM 为 11，则通过链接列表机制在当前块结束时加载的所有值必须保持相同的 TRGM=11 值和相同的 SWRM 值，否则结果未定义。这些位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>28</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>SWRM</name>
              <description>软件请求模式。此位由软件置位与清零。若当前有硬件或软件请求处于活跃状态，此位的变更将延迟到当前传输完成之后。若 CxMAR 包含有效地址，CxMDR 的值也将写入 CxMAR 地址。此位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>30</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>BWM</name>
              <description>缓冲写模式。此位由软件置位与清零。此位受保护，仅当 EN 为 0 时才可写入。注意：所有 MDMA 目的端访问均为不可缓存访问。</description>
              <bitOffset>31</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C3BNDTR</name>
          <displayName>MDMA_C3BNDTR</displayName>
          <description>MDMA 通道 x 块数据传输数量寄存器</description>
          <addressOffset>0x114</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>BNDT</name>
              <description>待传输数据块数量</description>
              <bitOffset>0</bitOffset>
              <bitWidth>17</bitWidth>
            </field>
            <field>
              <name>BRSUM</name>
              <description>块重复源地址更新模式。这些位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>18</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>BRDUM</name>
              <description>块重复目的地址更新模式。这些位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>19</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>BRC</name>
              <description>块重复计数。此字段包含当前块的重复次数（0 到 4095）。通道使能后，此寄存器为只读，指示剩余块数（不含当前块）。每次完整块传输完成后此寄存器递减。最后一个块传输完成后，此寄存器可保持为零，或自动从存储器重新加载（在链接列表模式下——即链接地址有效时）。这些位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>20</bitOffset>
              <bitWidth>12</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C3SAR</name>
          <displayName>MDMA_C3SAR</displayName>
          <description>MDMA 通道 x 源地址寄存器</description>
          <addressOffset>0x118</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>SAR</name>
              <description>源地址基址</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C3DAR</name>
          <displayName>MDMA_C3DAR</displayName>
          <description>MDMA 通道 x 目的地址寄存器</description>
          <addressOffset>0x11C</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>DAR</name>
              <description>目的地址基址</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C3BRUR</name>
          <displayName>MDMA_C3BRUR</displayName>
          <description>MDMA 通道 x 块重复地址更新寄存器</description>
          <addressOffset>0x120</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>SUV</name>
              <description>源地址更新值</description>
              <bitOffset>0</bitOffset>
              <bitWidth>16</bitWidth>
            </field>
            <field>
              <name>DUV</name>
              <description>目的地址更新值</description>
              <bitOffset>16</bitOffset>
              <bitWidth>16</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C3LAR</name>
          <displayName>MDMA_C3LAR</displayName>
          <description>MDMA 通道 x 链接地址寄存器</description>
          <addressOffset>0x124</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>LAR</name>
              <description>链接地址寄存器</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C3TBR</name>
          <displayName>MDMA_C3TBR</displayName>
          <description>MDMA 通道 x 触发与总线选择寄存器</description>
          <addressOffset>0x128</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>TSEL</name>
              <description>触发选择</description>
              <bitOffset>0</bitOffset>
              <bitWidth>6</bitWidth>
            </field>
            <field>
              <name>SBUS</name>
              <description>源总线选择。此位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>16</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DBUS</name>
              <description>目的总线选择。此位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>17</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C3MAR</name>
          <displayName>MDMA_C3MAR</displayName>
          <description>MDMA 通道 x 掩码地址寄存器</description>
          <addressOffset>0x130</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>MAR</name>
              <description>掩码地址</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C3MDR</name>
          <displayName>MDMA_C3MDR</displayName>
          <description>MDMA 通道 x 掩码数据寄存器</description>
          <addressOffset>0x134</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>MDR</name>
              <description>掩码数据</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C4ISR</name>
          <displayName>MDMA_C4ISR</displayName>
          <description>MDMA 通道 x 中断/状态寄存器</description>
          <addressOffset>0x140</addressOffset>
          <size>0x20</size>
          <access>read-only</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>TEIF4</name>
              <description>通道 x 传输错误中断标志。此位由硬件置位。软件向 DMA_IFCRy 寄存器的对应位写 1 可将其清零。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CTCIF4</name>
              <description>通道 x 通道传输完成中断标志。此位由硬件置位。软件向 DMA_IFCRy 寄存器的对应位写 1 可将其清零。当最后一个块传输完成且通道已自动禁用时，CTC 置位。当通道因 EN 位写 0 而挂起时，CTC 同样置位。</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>BRTIF4</name>
              <description>通道 x 块重复传输完成中断标志。此位由硬件置位。软件向 DMA_IFCRy 寄存器的对应位写 1 可将其清零。</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>BTIF4</name>
              <description>通道 x 块传输完成中断标志。此位由硬件置位。软件向 DMA_IFCRy 寄存器的对应位写 1 可将其清零。</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>TCIF4</name>
              <description>通道 x 缓冲区传输完成</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CRQA4</name>
              <description>通道 x 请求活跃标志</description>
              <bitOffset>16</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C4IFCR</name>
          <displayName>MDMA_C4IFCR</displayName>
          <description>MDMA 通道 x 中断标志清除寄存器</description>
          <addressOffset>0x144</addressOffset>
          <size>0x20</size>
          <access>write-only</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>CTEIF4</name>
              <description>通道 x 清除传输错误中断标志。向此位写 1 可将 MDMA_ISRy 寄存器中的 TEIFx 清零。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CCTCIF4</name>
              <description>通道 x 清除通道传输完成中断标志。向此位写 1 可将 MDMA_ISRy 寄存器中的 CTCIFx 清零。</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CBRTIF4</name>
              <description>通道 x 清除块重复传输完成中断标志。向此位写 1 可将 MDMA_ISRy 寄存器中的 BRTIFx 清零。</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CBTIF4</name>
              <description>通道 x 清除块传输完成中断标志。向此位写 1 可将 MDMA_ISRy 寄存器中的 BTIFx 清零。</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CLTCIF4</name>
              <description>通道 x 清除缓冲区传输完成中断标志。向此位写 1 可将 MDMA_ISRy 寄存器中的 TCIFx 清零。</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C4ESR</name>
          <displayName>MDMA_C4ESR</displayName>
          <description>MDMA 通道 x 错误状态寄存器</description>
          <addressOffset>0x148</addressOffset>
          <size>0x20</size>
          <access>read-only</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>TEA</name>
              <description>传输错误地址。在 MDMA 数据传输发生错误时，这些位由硬件置位与清零，与 TED 配合使用。该字段指示引发传输/访问错误的地址的低 7 位。软件可将其（截断至缓冲区传输长度大小）与当前 SAR/DAR 值相加来还原故障地址。注意：由于 FIFO 管理机制，SAR/DAR 当前值并不反映该最后地址。SAR/DAR 仅在（缓冲区）传完 TLEN+1 字节后才更新。注意：发生链接数据错误时此字段不会置位。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>7</bitWidth>
            </field>
            <field>
              <name>TED</name>
              <description>传输错误方向。在 MDMA 数据传输发生错误时，此位由硬件置位与清零。</description>
              <bitOffset>7</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>TELD</name>
              <description>传输错误（链接数据）。当读取块链接数据结构发生传输错误时，此位由硬件置位。软件向 DMA_IFCRy 寄存器中的 CTEIFx 位写 1 可将其清零。</description>
              <bitOffset>8</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>TEMD</name>
              <description>传输错误（掩码数据）。当写入掩码数据发生传输错误时，此位由硬件置位。软件向 DMA_IFCRy 寄存器中的 CTEIFx 位写 1 可将其清零。</description>
              <bitOffset>9</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>ASE</name>
              <description>地址/大小错误。当编程地址与数据大小不对齐时，此位由硬件置位。TED 将指示问题在源端还是目的端。软件向 DMA_IFCRy 寄存器中的 CTEIFx 位写 1 可将其清零。</description>
              <bitOffset>10</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>BSE</name>
              <description>块大小错误。当块大小不是源端或目的端数据大小的整数倍时，此位由硬件置位。TED 将指示问题在源端还是目的端。软件向 DMA_IFCRy 寄存器中的 CTEIFx 位写 1 可将其清零。</description>
              <bitOffset>11</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C4CR</name>
          <displayName>MDMA_C4CR</displayName>
          <description>此寄存器用于控制相应通道。</description>
          <addressOffset>0x14C</addressOffset>
          <size>0x20</size>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>EN</name>
              <description>通道使能</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>TEIE</name>
              <description>传输错误中断使能。此位由软件置位与清零。</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>CTCIE</name>
              <description>通道传输完成中断使能。此位由软件置位与清零。</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>BRTIE</name>
              <description>块重复传输中断使能。此位由软件置位与清零。</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>BTIE</name>
              <description>块传输中断使能。此位由软件置位与清零。</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>TCIE</name>
              <description>缓冲区传输完成中断使能。此位由软件置位与清零。</description>
              <bitOffset>5</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>PL</name>
              <description>优先级。这些位由软件置位与清零。这些位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>6</bitOffset>
              <bitWidth>2</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>BEX</name>
              <description>字节端序交换</description>
              <bitOffset>12</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>HEX</name>
              <description>半字端序交换</description>
              <bitOffset>13</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>WEX</name>
              <description>字端序交换</description>
              <bitOffset>14</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>SWRQ</name>
              <description>软件请求。向此位写 1 将使 MDMA_ISRy 寄存器中的 CRQAx 置位，从而激活通道 x 的请求。注意：可通过整个 CxCR 寄存器或地址偏移为 0x4E + 0x40*通道号的 8 位/16 位寄存器来激活 SWRQ。在软件请求的情况下，不会产生应答信号（无硬件信号，也不进行 CxMAR 写访问）。</description>
              <bitOffset>16</bitOffset>
              <bitWidth>1</bitWidth>
              <access>write-only</access>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C4TCR</name>
          <displayName>MDMA_C4TCR</displayName>
          <description>此寄存器用于配置相应通道。</description>
          <addressOffset>0x150</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>SINC</name>
              <description>源地址增量模式。这些位由软件置位与清零。这些位受保护，仅当 EN 为 0 时才可写入。注意：当源端为 AHB 总线时（SBUS=1），禁止 SINC = 00。在链接列表模式下，在一个块（单次或重复块传输模式中的最后一个块）结束时，此寄存器将从存储器（地址由当前 LAR[31:0] + 0x00 给出）重新加载。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>DINC</name>
              <description>目的地址增量模式。这些位由软件置位与清零。这些位受保护，仅当 EN 为 0 时才可写入。注意：当目的端为 AHB 总线时（DBUS=1），禁止 DINC = 00。</description>
              <bitOffset>2</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>SSIZE</name>
              <description>源数据大小。这些位由软件置位与清零。这些位受保护，仅当 EN 为 0 时才可写入。注意：若为 TCM 访问/AHB 端口编程了 11 值，将发生传输错误（TEIF 位置位）。若 SINCOS &lt; SSIZE 且 SINC != 00，结果不可预测。注意：当源端为 TCM/AHB 总线时（SBUS=1），禁止 SSIZE = 11（双字）。</description>
              <bitOffset>4</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>DSIZE</name>
              <description>目的数据大小。这些位由软件置位与清零。这些位受保护，仅当 EN 为 0 时才可写入。注意：若为 TCM 访问/AHB 端口编程了 11 值，将发生传输错误（TEIF 位置位）。若 DINCOS &lt; DSIZE 且 DINC != 00，结果不可预测。注意：当目的端为 TCM/AHB 总线时（DBUS=1），禁止 DSIZE = 11（双字）。</description>
              <bitOffset>6</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>SINCOS</name>
              <description>源地址增量偏移大小</description>
              <bitOffset>8</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>DINCOS</name>
              <description>目的地址增量偏移</description>
              <bitOffset>10</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>SBURST</name>
              <description>源端突发传输配置</description>
              <bitOffset>12</bitOffset>
              <bitWidth>3</bitWidth>
            </field>
            <field>
              <name>DBURST</name>
              <description>目的端突发传输配置</description>
              <bitOffset>15</bitOffset>
              <bitWidth>3</bitWidth>
            </field>
            <field>
              <name>TLEN</name>
              <description>缓冲区传输长度</description>
              <bitOffset>18</bitOffset>
              <bitWidth>7</bitWidth>
            </field>
            <field>
              <name>PKE</name>
              <description>打包使能。此位由软件置位与清零。若源数据大小小于目的数据大小，将按 PAM 值进行填充。若源数据大小大于目的数据大小，将被截断。对齐方式根据 PAM[0] 值确定。此位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>25</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>PAM</name>
              <description>填充/对齐模式。这些位由软件置位与清零。情况 1：源数据大小小于目的数据大小——3 种选项有效。情况 2：源数据大小大于目的数据大小——多余部分被丢弃。当 PKE = 1 或 DSIZE=SSIZE 时，这些位被忽略。这些位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>26</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>TRGM</name>
              <description>触发模式。这些位由软件置位与清零。注意：若当前块的 TRGM 为 11，则通过链接列表机制在当前块结束时加载的所有值必须保持相同的 TRGM=11 值和相同的 SWRM 值，否则结果未定义。这些位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>28</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>SWRM</name>
              <description>软件请求模式。此位由软件置位与清零。若当前有硬件或软件请求处于活跃状态，此位的变更将延迟到当前传输完成之后。若 CxMAR 包含有效地址，CxMDR 的值也将写入 CxMAR 地址。此位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>30</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>BWM</name>
              <description>缓冲写模式。此位由软件置位与清零。此位受保护，仅当 EN 为 0 时才可写入。注意：所有 MDMA 目的端访问均为不可缓存访问。</description>
              <bitOffset>31</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C4BNDTR</name>
          <displayName>MDMA_C4BNDTR</displayName>
          <description>MDMA 通道 x 块数据传输数量寄存器</description>
          <addressOffset>0x154</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>BNDT</name>
              <description>待传输数据块数量</description>
              <bitOffset>0</bitOffset>
              <bitWidth>17</bitWidth>
            </field>
            <field>
              <name>BRSUM</name>
              <description>块重复源地址更新模式。这些位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>18</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>BRDUM</name>
              <description>块重复目的地址更新模式。这些位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>19</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>BRC</name>
              <description>块重复计数。此字段包含当前块的重复次数（0 到 4095）。通道使能后，此寄存器为只读，指示剩余块数（不含当前块）。每次完整块传输完成后此寄存器递减。最后一个块传输完成后，此寄存器可保持为零，或自动从存储器重新加载（在链接列表模式下——即链接地址有效时）。这些位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>20</bitOffset>
              <bitWidth>12</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C4SAR</name>
          <displayName>MDMA_C4SAR</displayName>
          <description>MDMA 通道 x 源地址寄存器</description>
          <addressOffset>0x158</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>SAR</name>
              <description>源地址基址</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C4DAR</name>
          <displayName>MDMA_C4DAR</displayName>
          <description>MDMA 通道 x 目的地址寄存器</description>
          <addressOffset>0x15C</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>DAR</name>
              <description>目的地址基址</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C4BRUR</name>
          <displayName>MDMA_C4BRUR</displayName>
          <description>MDMA 通道 x 块重复地址更新寄存器</description>
          <addressOffset>0x160</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>SUV</name>
              <description>源地址更新值</description>
              <bitOffset>0</bitOffset>
              <bitWidth>16</bitWidth>
            </field>
            <field>
              <name>DUV</name>
              <description>目的地址更新值</description>
              <bitOffset>16</bitOffset>
              <bitWidth>16</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C4LAR</name>
          <displayName>MDMA_C4LAR</displayName>
          <description>MDMA 通道 x 链接地址寄存器</description>
          <addressOffset>0x164</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>LAR</name>
              <description>链接地址寄存器</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C4TBR</name>
          <displayName>MDMA_C4TBR</displayName>
          <description>MDMA 通道 x 触发与总线选择寄存器</description>
          <addressOffset>0x168</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>TSEL</name>
              <description>触发选择</description>
              <bitOffset>0</bitOffset>
              <bitWidth>6</bitWidth>
            </field>
            <field>
              <name>SBUS</name>
              <description>源总线选择。此位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>16</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DBUS</name>
              <description>目的总线选择。此位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>17</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C4MAR</name>
          <displayName>MDMA_C4MAR</displayName>
          <description>MDMA 通道 x 掩码地址寄存器</description>
          <addressOffset>0x170</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>MAR</name>
              <description>掩码地址</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C4MDR</name>
          <displayName>MDMA_C4MDR</displayName>
          <description>MDMA 通道 x 掩码数据寄存器</description>
          <addressOffset>0x174</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>MDR</name>
              <description>掩码数据</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C5ISR</name>
          <displayName>MDMA_C5ISR</displayName>
          <description>MDMA 通道 x 中断/状态寄存器</description>
          <addressOffset>0x180</addressOffset>
          <size>0x20</size>
          <access>read-only</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>TEIF5</name>
              <description>通道 x 传输错误中断标志。此位由硬件置位。软件向 DMA_IFCRy 寄存器的对应位写 1 可将其清零。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CTCIF5</name>
              <description>通道 x 通道传输完成中断标志。此位由硬件置位。软件向 DMA_IFCRy 寄存器的对应位写 1 可将其清零。当最后一个块传输完成且通道已自动禁用时，CTC 置位。当通道因 EN 位写 0 而挂起时，CTC 同样置位。</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>BRTIF5</name>
              <description>通道 x 块重复传输完成中断标志。此位由硬件置位。软件向 DMA_IFCRy 寄存器的对应位写 1 可将其清零。</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>BTIF5</name>
              <description>通道 x 块传输完成中断标志。此位由硬件置位。软件向 DMA_IFCRy 寄存器的对应位写 1 可将其清零。</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>TCIF5</name>
              <description>通道 x 缓冲区传输完成</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CRQA5</name>
              <description>通道 x 请求活跃标志</description>
              <bitOffset>16</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C5IFCR</name>
          <displayName>MDMA_C5IFCR</displayName>
          <description>MDMA 通道 x 中断标志清除寄存器</description>
          <addressOffset>0x184</addressOffset>
          <size>0x20</size>
          <access>write-only</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>CTEIF5</name>
              <description>通道 x 清除传输错误中断标志。向此位写 1 可将 MDMA_ISRy 寄存器中的 TEIFx 清零。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CCTCIF5</name>
              <description>通道 x 清除通道传输完成中断标志。向此位写 1 可将 MDMA_ISRy 寄存器中的 CTCIFx 清零。</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CBRTIF5</name>
              <description>通道 x 清除块重复传输完成中断标志。向此位写 1 可将 MDMA_ISRy 寄存器中的 BRTIFx 清零。</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CBTIF5</name>
              <description>通道 x 清除块传输完成中断标志。向此位写 1 可将 MDMA_ISRy 寄存器中的 BTIFx 清零。</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CLTCIF5</name>
              <description>通道 x 清除缓冲区传输完成中断标志。向此位写 1 可将 MDMA_ISRy 寄存器中的 TCIFx 清零。</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C5ESR</name>
          <displayName>MDMA_C5ESR</displayName>
          <description>MDMA 通道 x 错误状态寄存器</description>
          <addressOffset>0x188</addressOffset>
          <size>0x20</size>
          <access>read-only</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>TEA</name>
              <description>传输错误地址。在 MDMA 数据传输发生错误时，这些位由硬件置位与清零，与 TED 配合使用。该字段指示引发传输/访问错误的地址的低 7 位。软件可将其（截断至缓冲区传输长度大小）与当前 SAR/DAR 值相加来还原故障地址。注意：由于 FIFO 管理机制，SAR/DAR 当前值并不反映该最后地址。SAR/DAR 仅在（缓冲区）传完 TLEN+1 字节后才更新。注意：发生链接数据错误时此字段不会置位。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>7</bitWidth>
            </field>
            <field>
              <name>TED</name>
              <description>传输错误方向。在 MDMA 数据传输发生错误时，此位由硬件置位与清零。</description>
              <bitOffset>7</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>TELD</name>
              <description>传输错误（链接数据）。当读取块链接数据结构发生传输错误时，此位由硬件置位。软件向 DMA_IFCRy 寄存器中的 CTEIFx 位写 1 可将其清零。</description>
              <bitOffset>8</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>TEMD</name>
              <description>传输错误（掩码数据）。当写入掩码数据发生传输错误时，此位由硬件置位。软件向 DMA_IFCRy 寄存器中的 CTEIFx 位写 1 可将其清零。</description>
              <bitOffset>9</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>ASE</name>
              <description>地址/大小错误。当编程地址与数据大小不对齐时，此位由硬件置位。TED 将指示问题在源端还是目的端。软件向 DMA_IFCRy 寄存器中的 CTEIFx 位写 1 可将其清零。</description>
              <bitOffset>10</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>BSE</name>
              <description>块大小错误。当块大小不是源端或目的端数据大小的整数倍时，此位由硬件置位。TED 将指示问题在源端还是目的端。软件向 DMA_IFCRy 寄存器中的 CTEIFx 位写 1 可将其清零。</description>
              <bitOffset>11</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C5CR</name>
          <displayName>MDMA_C5CR</displayName>
          <description>此寄存器用于控制相应通道。</description>
          <addressOffset>0x18C</addressOffset>
          <size>0x20</size>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>EN</name>
              <description>通道使能</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>TEIE</name>
              <description>传输错误中断使能。此位由软件置位与清零。</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>CTCIE</name>
              <description>通道传输完成中断使能。此位由软件置位与清零。</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>BRTIE</name>
              <description>块重复传输中断使能。此位由软件置位与清零。</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>BTIE</name>
              <description>块传输中断使能。此位由软件置位与清零。</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>TCIE</name>
              <description>缓冲区传输完成中断使能。此位由软件置位与清零。</description>
              <bitOffset>5</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>PL</name>
              <description>优先级。这些位由软件置位与清零。这些位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>6</bitOffset>
              <bitWidth>2</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>BEX</name>
              <description>字节端序交换</description>
              <bitOffset>12</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>HEX</name>
              <description>半字端序交换</description>
              <bitOffset>13</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>WEX</name>
              <description>字端序交换</description>
              <bitOffset>14</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>SWRQ</name>
              <description>软件请求。向此位写 1 将使 MDMA_ISRy 寄存器中的 CRQAx 置位，从而激活通道 x 的请求。注意：可通过整个 CxCR 寄存器或地址偏移为 0x4E + 0x40*通道号的 8 位/16 位寄存器来激活 SWRQ。在软件请求的情况下，不会产生应答信号（无硬件信号，也不进行 CxMAR 写访问）。</description>
              <bitOffset>16</bitOffset>
              <bitWidth>1</bitWidth>
              <access>write-only</access>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C5TCR</name>
          <displayName>MDMA_C5TCR</displayName>
          <description>此寄存器用于配置相应通道。</description>
          <addressOffset>0x190</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>SINC</name>
              <description>源地址增量模式。这些位由软件置位与清零。这些位受保护，仅当 EN 为 0 时才可写入。注意：当源端为 AHB 总线时（SBUS=1），禁止 SINC = 00。在链接列表模式下，在一个块（单次或重复块传输模式中的最后一个块）结束时，此寄存器将从存储器（地址由当前 LAR[31:0] + 0x00 给出）重新加载。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>DINC</name>
              <description>目的地址增量模式。这些位由软件置位与清零。这些位受保护，仅当 EN 为 0 时才可写入。注意：当目的端为 AHB 总线时（DBUS=1），禁止 DINC = 00。</description>
              <bitOffset>2</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>SSIZE</name>
              <description>源数据大小。这些位由软件置位与清零。这些位受保护，仅当 EN 为 0 时才可写入。注意：若为 TCM 访问/AHB 端口编程了 11 值，将发生传输错误（TEIF 位置位）。若 SINCOS &lt; SSIZE 且 SINC != 00，结果不可预测。注意：当源端为 TCM/AHB 总线时（SBUS=1），禁止 SSIZE = 11（双字）。</description>
              <bitOffset>4</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>DSIZE</name>
              <description>目的数据大小。这些位由软件置位与清零。这些位受保护，仅当 EN 为 0 时才可写入。注意：若为 TCM 访问/AHB 端口编程了 11 值，将发生传输错误（TEIF 位置位）。若 DINCOS &lt; DSIZE 且 DINC != 00，结果不可预测。注意：当目的端为 TCM/AHB 总线时（DBUS=1），禁止 DSIZE = 11（双字）。</description>
              <bitOffset>6</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>SINCOS</name>
              <description>源地址增量偏移大小</description>
              <bitOffset>8</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>DINCOS</name>
              <description>目的地址增量偏移</description>
              <bitOffset>10</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>SBURST</name>
              <description>源端突发传输配置</description>
              <bitOffset>12</bitOffset>
              <bitWidth>3</bitWidth>
            </field>
            <field>
              <name>DBURST</name>
              <description>目的端突发传输配置</description>
              <bitOffset>15</bitOffset>
              <bitWidth>3</bitWidth>
            </field>
            <field>
              <name>TLEN</name>
              <description>缓冲区传输长度</description>
              <bitOffset>18</bitOffset>
              <bitWidth>7</bitWidth>
            </field>
            <field>
              <name>PKE</name>
              <description>打包使能。此位由软件置位与清零。若源数据大小小于目的数据大小，将按 PAM 值进行填充。若源数据大小大于目的数据大小，将被截断。对齐方式根据 PAM[0] 值确定。此位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>25</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>PAM</name>
              <description>填充/对齐模式。这些位由软件置位与清零。情况 1：源数据大小小于目的数据大小——3 种选项有效。情况 2：源数据大小大于目的数据大小——多余部分被丢弃。当 PKE = 1 或 DSIZE=SSIZE 时，这些位被忽略。这些位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>26</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>TRGM</name>
              <description>触发模式。这些位由软件置位与清零。注意：若当前块的 TRGM 为 11，则通过链接列表机制在当前块结束时加载的所有值必须保持相同的 TRGM=11 值和相同的 SWRM 值，否则结果未定义。这些位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>28</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>SWRM</name>
              <description>软件请求模式。此位由软件置位与清零。若当前有硬件或软件请求处于活跃状态，此位的变更将延迟到当前传输完成之后。若 CxMAR 包含有效地址，CxMDR 的值也将写入 CxMAR 地址。此位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>30</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>BWM</name>
              <description>缓冲写模式。此位由软件置位与清零。此位受保护，仅当 EN 为 0 时才可写入。注意：所有 MDMA 目的端访问均为不可缓存访问。</description>
              <bitOffset>31</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C5BNDTR</name>
          <displayName>MDMA_C5BNDTR</displayName>
          <description>MDMA 通道 x 块数据传输数量寄存器</description>
          <addressOffset>0x194</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>BNDT</name>
              <description>待传输数据块数量</description>
              <bitOffset>0</bitOffset>
              <bitWidth>17</bitWidth>
            </field>
            <field>
              <name>BRSUM</name>
              <description>块重复源地址更新模式。这些位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>18</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>BRDUM</name>
              <description>块重复目的地址更新模式。这些位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>19</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>BRC</name>
              <description>块重复计数。此字段包含当前块的重复次数（0 到 4095）。通道使能后，此寄存器为只读，指示剩余块数（不含当前块）。每次完整块传输完成后此寄存器递减。最后一个块传输完成后，此寄存器可保持为零，或自动从存储器重新加载（在链接列表模式下——即链接地址有效时）。这些位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>20</bitOffset>
              <bitWidth>12</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C5SAR</name>
          <displayName>MDMA_C5SAR</displayName>
          <description>MDMA 通道 x 源地址寄存器</description>
          <addressOffset>0x198</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>SAR</name>
              <description>源地址基址</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C5DAR</name>
          <displayName>MDMA_C5DAR</displayName>
          <description>MDMA 通道 x 目的地址寄存器</description>
          <addressOffset>0x19C</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>DAR</name>
              <description>目的地址基址</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C5BRUR</name>
          <displayName>MDMA_C5BRUR</displayName>
          <description>MDMA 通道 x 块重复地址更新寄存器</description>
          <addressOffset>0x1A0</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>SUV</name>
              <description>源地址更新值</description>
              <bitOffset>0</bitOffset>
              <bitWidth>16</bitWidth>
            </field>
            <field>
              <name>DUV</name>
              <description>目的地址更新值</description>
              <bitOffset>16</bitOffset>
              <bitWidth>16</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C5LAR</name>
          <displayName>MDMA_C5LAR</displayName>
          <description>MDMA 通道 x 链接地址寄存器</description>
          <addressOffset>0x1A4</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>LAR</name>
              <description>链接地址寄存器</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C5TBR</name>
          <displayName>MDMA_C5TBR</displayName>
          <description>MDMA 通道 x 触发与总线选择寄存器</description>
          <addressOffset>0x1A8</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>TSEL</name>
              <description>触发选择</description>
              <bitOffset>0</bitOffset>
              <bitWidth>6</bitWidth>
            </field>
            <field>
              <name>SBUS</name>
              <description>源总线选择。此位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>16</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DBUS</name>
              <description>目的总线选择。此位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>17</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C5MAR</name>
          <displayName>MDMA_C5MAR</displayName>
          <description>MDMA 通道 x 掩码地址寄存器</description>
          <addressOffset>0x1B0</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>MAR</name>
              <description>掩码地址</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C5MDR</name>
          <displayName>MDMA_C5MDR</displayName>
          <description>MDMA 通道 x 掩码数据寄存器</description>
          <addressOffset>0x1B4</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>MDR</name>
              <description>掩码数据</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C6ISR</name>
          <displayName>MDMA_C6ISR</displayName>
          <description>MDMA 通道 x 中断/状态寄存器</description>
          <addressOffset>0x1C0</addressOffset>
          <size>0x20</size>
          <access>read-only</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>TEIF6</name>
              <description>通道 x 传输错误中断标志。此位由硬件置位。软件向 DMA_IFCRy 寄存器的对应位写 1 可将其清零。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CTCIF6</name>
              <description>通道 x 通道传输完成中断标志。此位由硬件置位。软件向 DMA_IFCRy 寄存器的对应位写 1 可将其清零。当最后一个块传输完成且通道已自动禁用时，CTC 置位。当通道因 EN 位写 0 而挂起时，CTC 同样置位。</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>BRTIF6</name>
              <description>通道 x 块重复传输完成中断标志。此位由硬件置位。软件向 DMA_IFCRy 寄存器的对应位写 1 可将其清零。</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>BTIF6</name>
              <description>通道 x 块传输完成中断标志。此位由硬件置位。软件向 DMA_IFCRy 寄存器的对应位写 1 可将其清零。</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>TCIF6</name>
              <description>通道 x 缓冲区传输完成</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CRQA6</name>
              <description>通道 x 请求活跃标志</description>
              <bitOffset>16</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C6IFCR</name>
          <displayName>MDMA_C6IFCR</displayName>
          <description>MDMA 通道 x 中断标志清除寄存器</description>
          <addressOffset>0x1C4</addressOffset>
          <size>0x20</size>
          <access>write-only</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>CTEIF6</name>
              <description>通道 x 清除传输错误中断标志。向此位写 1 可将 MDMA_ISRy 寄存器中的 TEIFx 清零。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CCTCIF6</name>
              <description>通道 x 清除通道传输完成中断标志。向此位写 1 可将 MDMA_ISRy 寄存器中的 CTCIFx 清零。</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CBRTIF6</name>
              <description>通道 x 清除块重复传输完成中断标志。向此位写 1 可将 MDMA_ISRy 寄存器中的 BRTIFx 清零。</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CBTIF6</name>
              <description>通道 x 清除块传输完成中断标志。向此位写 1 可将 MDMA_ISRy 寄存器中的 BTIFx 清零。</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CLTCIF6</name>
              <description>通道 x 清除缓冲区传输完成中断标志。向此位写 1 可将 MDMA_ISRy 寄存器中的 TCIFx 清零。</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C6ESR</name>
          <displayName>MDMA_C6ESR</displayName>
          <description>MDMA 通道 x 错误状态寄存器</description>
          <addressOffset>0x1C8</addressOffset>
          <size>0x20</size>
          <access>read-only</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>TEA</name>
              <description>传输错误地址。在 MDMA 数据传输发生错误时，这些位由硬件置位与清零，与 TED 配合使用。该字段指示引发传输/访问错误的地址的低 7 位。软件可将其（截断至缓冲区传输长度大小）与当前 SAR/DAR 值相加来还原故障地址。注意：由于 FIFO 管理机制，SAR/DAR 当前值并不反映该最后地址。SAR/DAR 仅在（缓冲区）传完 TLEN+1 字节后才更新。注意：发生链接数据错误时此字段不会置位。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>7</bitWidth>
            </field>
            <field>
              <name>TED</name>
              <description>传输错误方向。在 MDMA 数据传输发生错误时，此位由硬件置位与清零。</description>
              <bitOffset>7</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>TELD</name>
              <description>传输错误（链接数据）。当读取块链接数据结构发生传输错误时，此位由硬件置位。软件向 DMA_IFCRy 寄存器中的 CTEIFx 位写 1 可将其清零。</description>
              <bitOffset>8</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>TEMD</name>
              <description>传输错误（掩码数据）。当写入掩码数据发生传输错误时，此位由硬件置位。软件向 DMA_IFCRy 寄存器中的 CTEIFx 位写 1 可将其清零。</description>
              <bitOffset>9</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>ASE</name>
              <description>地址/大小错误。当编程地址与数据大小不对齐时，此位由硬件置位。TED 将指示问题在源端还是目的端。软件向 DMA_IFCRy 寄存器中的 CTEIFx 位写 1 可将其清零。</description>
              <bitOffset>10</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>BSE</name>
              <description>块大小错误。当块大小不是源端或目的端数据大小的整数倍时，此位由硬件置位。TED 将指示问题在源端还是目的端。软件向 DMA_IFCRy 寄存器中的 CTEIFx 位写 1 可将其清零。</description>
              <bitOffset>11</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C6CR</name>
          <displayName>MDMA_C6CR</displayName>
          <description>此寄存器用于控制相应通道。</description>
          <addressOffset>0x1CC</addressOffset>
          <size>0x20</size>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>EN</name>
              <description>通道使能</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>TEIE</name>
              <description>传输错误中断使能。此位由软件置位与清零。</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>CTCIE</name>
              <description>通道传输完成中断使能。此位由软件置位与清零。</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>BRTIE</name>
              <description>块重复传输中断使能。此位由软件置位与清零。</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>BTIE</name>
              <description>块传输中断使能。此位由软件置位与清零。</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>TCIE</name>
              <description>缓冲区传输完成中断使能。此位由软件置位与清零。</description>
              <bitOffset>5</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>PL</name>
              <description>优先级。这些位由软件置位与清零。这些位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>6</bitOffset>
              <bitWidth>2</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>BEX</name>
              <description>字节端序交换</description>
              <bitOffset>12</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>HEX</name>
              <description>半字端序交换</description>
              <bitOffset>13</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>WEX</name>
              <description>字端序交换</description>
              <bitOffset>14</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>SWRQ</name>
              <description>软件请求。向此位写 1 将使 MDMA_ISRy 寄存器中的 CRQAx 置位，从而激活通道 x 的请求。注意：可通过整个 CxCR 寄存器或地址偏移为 0x4E + 0x40*通道号的 8 位/16 位寄存器来激活 SWRQ。在软件请求的情况下，不会产生应答信号（无硬件信号，也不进行 CxMAR 写访问）。</description>
              <bitOffset>16</bitOffset>
              <bitWidth>1</bitWidth>
              <access>write-only</access>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C6TCR</name>
          <displayName>MDMA_C6TCR</displayName>
          <description>此寄存器用于配置相应通道。</description>
          <addressOffset>0x1D0</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>SINC</name>
              <description>源地址增量模式。这些位由软件置位与清零。这些位受保护，仅当 EN 为 0 时才可写入。注意：当源端为 AHB 总线时（SBUS=1），禁止 SINC = 00。在链接列表模式下，在一个块（单次或重复块传输模式中的最后一个块）结束时，此寄存器将从存储器（地址由当前 LAR[31:0] + 0x00 给出）重新加载。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>DINC</name>
              <description>目的地址增量模式。这些位由软件置位与清零。这些位受保护，仅当 EN 为 0 时才可写入。注意：当目的端为 AHB 总线时（DBUS=1），禁止 DINC = 00。</description>
              <bitOffset>2</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>SSIZE</name>
              <description>源数据大小。这些位由软件置位与清零。这些位受保护，仅当 EN 为 0 时才可写入。注意：若为 TCM 访问/AHB 端口编程了 11 值，将发生传输错误（TEIF 位置位）。若 SINCOS &lt; SSIZE 且 SINC != 00，结果不可预测。注意：当源端为 TCM/AHB 总线时（SBUS=1），禁止 SSIZE = 11（双字）。</description>
              <bitOffset>4</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>DSIZE</name>
              <description>目的数据大小。这些位由软件置位与清零。这些位受保护，仅当 EN 为 0 时才可写入。注意：若为 TCM 访问/AHB 端口编程了 11 值，将发生传输错误（TEIF 位置位）。若 DINCOS &lt; DSIZE 且 DINC != 00，结果不可预测。注意：当目的端为 TCM/AHB 总线时（DBUS=1），禁止 DSIZE = 11（双字）。</description>
              <bitOffset>6</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>SINCOS</name>
              <description>源地址增量偏移大小</description>
              <bitOffset>8</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>DINCOS</name>
              <description>目的地址增量偏移</description>
              <bitOffset>10</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>SBURST</name>
              <description>源端突发传输配置</description>
              <bitOffset>12</bitOffset>
              <bitWidth>3</bitWidth>
            </field>
            <field>
              <name>DBURST</name>
              <description>目的端突发传输配置</description>
              <bitOffset>15</bitOffset>
              <bitWidth>3</bitWidth>
            </field>
            <field>
              <name>TLEN</name>
              <description>缓冲区传输长度</description>
              <bitOffset>18</bitOffset>
              <bitWidth>7</bitWidth>
            </field>
            <field>
              <name>PKE</name>
              <description>打包使能。此位由软件置位与清零。若源数据大小小于目的数据大小，将按 PAM 值进行填充。若源数据大小大于目的数据大小，将被截断。对齐方式根据 PAM[0] 值确定。此位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>25</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>PAM</name>
              <description>填充/对齐模式。这些位由软件置位与清零。情况 1：源数据大小小于目的数据大小——3 种选项有效。情况 2：源数据大小大于目的数据大小——多余部分被丢弃。当 PKE = 1 或 DSIZE=SSIZE 时，这些位被忽略。这些位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>26</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>TRGM</name>
              <description>触发模式。这些位由软件置位与清零。注意：若当前块的 TRGM 为 11，则通过链接列表机制在当前块结束时加载的所有值必须保持相同的 TRGM=11 值和相同的 SWRM 值，否则结果未定义。这些位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>28</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>SWRM</name>
              <description>软件请求模式。此位由软件置位与清零。若当前有硬件或软件请求处于活跃状态，此位的变更将延迟到当前传输完成之后。若 CxMAR 包含有效地址，CxMDR 的值也将写入 CxMAR 地址。此位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>30</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>BWM</name>
              <description>缓冲写模式。此位由软件置位与清零。此位受保护，仅当 EN 为 0 时才可写入。注意：所有 MDMA 目的端访问均为不可缓存访问。</description>
              <bitOffset>31</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C6BNDTR</name>
          <displayName>MDMA_C6BNDTR</displayName>
          <description>MDMA 通道 x 块数据传输数量寄存器</description>
          <addressOffset>0x1D4</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>BNDT</name>
              <description>待传输数据块数量</description>
              <bitOffset>0</bitOffset>
              <bitWidth>17</bitWidth>
            </field>
            <field>
              <name>BRSUM</name>
              <description>块重复源地址更新模式。这些位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>18</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>BRDUM</name>
              <description>块重复目的地址更新模式。这些位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>19</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>BRC</name>
              <description>块重复计数。此字段包含当前块的重复次数（0 到 4095）。通道使能后，此寄存器为只读，指示剩余块数（不含当前块）。每次完整块传输完成后此寄存器递减。最后一个块传输完成后，此寄存器可保持为零，或自动从存储器重新加载（在链接列表模式下——即链接地址有效时）。这些位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>20</bitOffset>
              <bitWidth>12</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C6SAR</name>
          <displayName>MDMA_C6SAR</displayName>
          <description>MDMA 通道 x 源地址寄存器</description>
          <addressOffset>0x1D8</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>SAR</name>
              <description>源地址基址</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C6DAR</name>
          <displayName>MDMA_C6DAR</displayName>
          <description>MDMA 通道 x 目的地址寄存器</description>
          <addressOffset>0x1DC</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>DAR</name>
              <description>目的地址基址</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C6BRUR</name>
          <displayName>MDMA_C6BRUR</displayName>
          <description>MDMA 通道 x 块重复地址更新寄存器</description>
          <addressOffset>0x1E0</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>SUV</name>
              <description>源地址更新值</description>
              <bitOffset>0</bitOffset>
              <bitWidth>16</bitWidth>
            </field>
            <field>
              <name>DUV</name>
              <description>目的地址更新值</description>
              <bitOffset>16</bitOffset>
              <bitWidth>16</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C6LAR</name>
          <displayName>MDMA_C6LAR</displayName>
          <description>MDMA 通道 x 链接地址寄存器</description>
          <addressOffset>0x1E4</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>LAR</name>
              <description>链接地址寄存器</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C6TBR</name>
          <displayName>MDMA_C6TBR</displayName>
          <description>MDMA 通道 x 触发与总线选择寄存器</description>
          <addressOffset>0x1E8</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>TSEL</name>
              <description>触发选择</description>
              <bitOffset>0</bitOffset>
              <bitWidth>6</bitWidth>
            </field>
            <field>
              <name>SBUS</name>
              <description>源总线选择。此位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>16</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DBUS</name>
              <description>目的总线选择。此位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>17</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C6MAR</name>
          <displayName>MDMA_C6MAR</displayName>
          <description>MDMA 通道 x 掩码地址寄存器</description>
          <addressOffset>0x1F0</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>MAR</name>
              <description>掩码地址</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C6MDR</name>
          <displayName>MDMA_C6MDR</displayName>
          <description>MDMA 通道 x 掩码数据寄存器</description>
          <addressOffset>0x1F4</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>MDR</name>
              <description>掩码数据</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C7ISR</name>
          <displayName>MDMA_C7ISR</displayName>
          <description>MDMA 通道 x 中断/状态寄存器</description>
          <addressOffset>0x200</addressOffset>
          <size>0x20</size>
          <access>read-only</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>TEIF7</name>
              <description>通道 x 传输错误中断标志。此位由硬件置位。软件向 DMA_IFCRy 寄存器的对应位写 1 可将其清零。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CTCIF7</name>
              <description>通道 x 通道传输完成中断标志。此位由硬件置位。软件向 DMA_IFCRy 寄存器的对应位写 1 可将其清零。当最后一个块传输完成且通道已自动禁用时，CTC 置位。当通道因 EN 位写 0 而挂起时，CTC 同样置位。</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>BRTIF7</name>
              <description>通道 x 块重复传输完成中断标志。此位由硬件置位。软件向 DMA_IFCRy 寄存器的对应位写 1 可将其清零。</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>BTIF7</name>
              <description>通道 x 块传输完成中断标志。此位由硬件置位。软件向 DMA_IFCRy 寄存器的对应位写 1 可将其清零。</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>TCIF7</name>
              <description>通道 x 缓冲区传输完成</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CRQA7</name>
              <description>通道 x 请求活跃标志</description>
              <bitOffset>16</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C7IFCR</name>
          <displayName>MDMA_C7IFCR</displayName>
          <description>MDMA 通道 x 中断标志清除寄存器</description>
          <addressOffset>0x204</addressOffset>
          <size>0x20</size>
          <access>write-only</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>CTEIF7</name>
              <description>通道 x 清除传输错误中断标志。向此位写 1 可将 MDMA_ISRy 寄存器中的 TEIFx 清零。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CCTCIF7</name>
              <description>通道 x 清除通道传输完成中断标志。向此位写 1 可将 MDMA_ISRy 寄存器中的 CTCIFx 清零。</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CBRTIF7</name>
              <description>通道 x 清除块重复传输完成中断标志。向此位写 1 可将 MDMA_ISRy 寄存器中的 BRTIFx 清零。</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CBTIF7</name>
              <description>通道 x 清除块传输完成中断标志。向此位写 1 可将 MDMA_ISRy 寄存器中的 BTIFx 清零。</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CLTCIF7</name>
              <description>通道 x 清除缓冲区传输完成中断标志。向此位写 1 可将 MDMA_ISRy 寄存器中的 TCIFx 清零。</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C7ESR</name>
          <displayName>MDMA_C7ESR</displayName>
          <description>MDMA 通道 x 错误状态寄存器</description>
          <addressOffset>0x208</addressOffset>
          <size>0x20</size>
          <access>read-only</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>TEA</name>
              <description>传输错误地址。在 MDMA 数据传输发生错误时，这些位由硬件置位与清零，与 TED 配合使用。该字段指示引发传输/访问错误的地址的低 7 位。软件可将其（截断至缓冲区传输长度大小）与当前 SAR/DAR 值相加来还原故障地址。注意：由于 FIFO 管理机制，SAR/DAR 当前值并不反映该最后地址。SAR/DAR 仅在（缓冲区）传完 TLEN+1 字节后才更新。注意：发生链接数据错误时此字段不会置位。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>7</bitWidth>
            </field>
            <field>
              <name>TED</name>
              <description>传输错误方向。在 MDMA 数据传输发生错误时，此位由硬件置位与清零。</description>
              <bitOffset>7</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>TELD</name>
              <description>传输错误（链接数据）。当读取块链接数据结构发生传输错误时，此位由硬件置位。软件向 DMA_IFCRy 寄存器中的 CTEIFx 位写 1 可将其清零。</description>
              <bitOffset>8</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>TEMD</name>
              <description>传输错误（掩码数据）。当写入掩码数据发生传输错误时，此位由硬件置位。软件向 DMA_IFCRy 寄存器中的 CTEIFx 位写 1 可将其清零。</description>
              <bitOffset>9</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>ASE</name>
              <description>地址/大小错误。当编程地址与数据大小不对齐时，此位由硬件置位。TED 将指示问题在源端还是目的端。软件向 DMA_IFCRy 寄存器中的 CTEIFx 位写 1 可将其清零。</description>
              <bitOffset>10</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>BSE</name>
              <description>块大小错误。当块大小不是源端或目的端数据大小的整数倍时，此位由硬件置位。TED 将指示问题在源端还是目的端。软件向 DMA_IFCRy 寄存器中的 CTEIFx 位写 1 可将其清零。</description>
              <bitOffset>11</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C7CR</name>
          <displayName>MDMA_C7CR</displayName>
          <description>此寄存器用于控制相应通道。</description>
          <addressOffset>0x20C</addressOffset>
          <size>0x20</size>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>EN</name>
              <description>通道使能</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>TEIE</name>
              <description>传输错误中断使能。此位由软件置位与清零。</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>CTCIE</name>
              <description>通道传输完成中断使能。此位由软件置位与清零。</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>BRTIE</name>
              <description>块重复传输中断使能。此位由软件置位与清零。</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>BTIE</name>
              <description>块传输中断使能。此位由软件置位与清零。</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>TCIE</name>
              <description>缓冲区传输完成中断使能。此位由软件置位与清零。</description>
              <bitOffset>5</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>PL</name>
              <description>优先级。这些位由软件置位与清零。这些位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>6</bitOffset>
              <bitWidth>2</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>BEX</name>
              <description>字节端序交换</description>
              <bitOffset>12</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>HEX</name>
              <description>半字端序交换</description>
              <bitOffset>13</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>WEX</name>
              <description>字端序交换</description>
              <bitOffset>14</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>SWRQ</name>
              <description>软件请求。向此位写 1 将使 MDMA_ISRy 寄存器中的 CRQAx 置位，从而激活通道 x 的请求。注意：可通过整个 CxCR 寄存器或地址偏移为 0x4E + 0x40*通道号的 8 位/16 位寄存器来激活 SWRQ。在软件请求的情况下，不会产生应答信号（无硬件信号，也不进行 CxMAR 写访问）。</description>
              <bitOffset>16</bitOffset>
              <bitWidth>1</bitWidth>
              <access>write-only</access>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C7TCR</name>
          <displayName>MDMA_C7TCR</displayName>
          <description>此寄存器用于配置相应通道。</description>
          <addressOffset>0x210</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>SINC</name>
              <description>源地址增量模式。这些位由软件置位与清零。这些位受保护，仅当 EN 为 0 时才可写入。注意：当源端为 AHB 总线时（SBUS=1），禁止 SINC = 00。在链接列表模式下，在一个块（单次或重复块传输模式中的最后一个块）结束时，此寄存器将从存储器（地址由当前 LAR[31:0] + 0x00 给出）重新加载。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>DINC</name>
              <description>目的地址增量模式。这些位由软件置位与清零。这些位受保护，仅当 EN 为 0 时才可写入。注意：当目的端为 AHB 总线时（DBUS=1），禁止 DINC = 00。</description>
              <bitOffset>2</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>SSIZE</name>
              <description>源数据大小。这些位由软件置位与清零。这些位受保护，仅当 EN 为 0 时才可写入。注意：若为 TCM 访问/AHB 端口编程了 11 值，将发生传输错误（TEIF 位置位）。若 SINCOS &lt; SSIZE 且 SINC != 00，结果不可预测。注意：当源端为 TCM/AHB 总线时（SBUS=1），禁止 SSIZE = 11（双字）。</description>
              <bitOffset>4</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>DSIZE</name>
              <description>目的数据大小。这些位由软件置位与清零。这些位受保护，仅当 EN 为 0 时才可写入。注意：若为 TCM 访问/AHB 端口编程了 11 值，将发生传输错误（TEIF 位置位）。若 DINCOS &lt; DSIZE 且 DINC != 00，结果不可预测。注意：当目的端为 TCM/AHB 总线时（DBUS=1），禁止 DSIZE = 11（双字）。</description>
              <bitOffset>6</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>SINCOS</name>
              <description>源地址增量偏移大小</description>
              <bitOffset>8</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>DINCOS</name>
              <description>目的地址增量偏移</description>
              <bitOffset>10</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>SBURST</name>
              <description>源端突发传输配置</description>
              <bitOffset>12</bitOffset>
              <bitWidth>3</bitWidth>
            </field>
            <field>
              <name>DBURST</name>
              <description>目的端突发传输配置</description>
              <bitOffset>15</bitOffset>
              <bitWidth>3</bitWidth>
            </field>
            <field>
              <name>TLEN</name>
              <description>缓冲区传输长度</description>
              <bitOffset>18</bitOffset>
              <bitWidth>7</bitWidth>
            </field>
            <field>
              <name>PKE</name>
              <description>打包使能。此位由软件置位与清零。若源数据大小小于目的数据大小，将按 PAM 值进行填充。若源数据大小大于目的数据大小，将被截断。对齐方式根据 PAM[0] 值确定。此位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>25</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>PAM</name>
              <description>填充/对齐模式。这些位由软件置位与清零。情况 1：源数据大小小于目的数据大小——3 种选项有效。情况 2：源数据大小大于目的数据大小——多余部分被丢弃。当 PKE = 1 或 DSIZE=SSIZE 时，这些位被忽略。这些位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>26</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>TRGM</name>
              <description>触发模式。这些位由软件置位与清零。注意：若当前块的 TRGM 为 11，则通过链接列表机制在当前块结束时加载的所有值必须保持相同的 TRGM=11 值和相同的 SWRM 值，否则结果未定义。这些位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>28</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>SWRM</name>
              <description>软件请求模式。此位由软件置位与清零。若当前有硬件或软件请求处于活跃状态，此位的变更将延迟到当前传输完成之后。若 CxMAR 包含有效地址，CxMDR 的值也将写入 CxMAR 地址。此位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>30</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>BWM</name>
              <description>缓冲写模式。此位由软件置位与清零。此位受保护，仅当 EN 为 0 时才可写入。注意：所有 MDMA 目的端访问均为不可缓存访问。</description>
              <bitOffset>31</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C7BNDTR</name>
          <displayName>MDMA_C7BNDTR</displayName>
          <description>MDMA 通道 x 块数据传输数量寄存器</description>
          <addressOffset>0x214</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>BNDT</name>
              <description>待传输数据块数量</description>
              <bitOffset>0</bitOffset>
              <bitWidth>17</bitWidth>
            </field>
            <field>
              <name>BRSUM</name>
              <description>块重复源地址更新模式。这些位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>18</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>BRDUM</name>
              <description>块重复目的地址更新模式。这些位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>19</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>BRC</name>
              <description>块重复计数。此字段包含当前块的重复次数（0 到 4095）。通道使能后，此寄存器为只读，指示剩余块数（不含当前块）。每次完整块传输完成后此寄存器递减。最后一个块传输完成后，此寄存器可保持为零，或自动从存储器重新加载（在链接列表模式下——即链接地址有效时）。这些位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>20</bitOffset>
              <bitWidth>12</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C7SAR</name>
          <displayName>MDMA_C7SAR</displayName>
          <description>MDMA 通道 x 源地址寄存器</description>
          <addressOffset>0x218</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>SAR</name>
              <description>源地址基址</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C7DAR</name>
          <displayName>MDMA_C7DAR</displayName>
          <description>MDMA 通道 x 目的地址寄存器</description>
          <addressOffset>0x21C</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>DAR</name>
              <description>目的地址基址</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C7BRUR</name>
          <displayName>MDMA_C7BRUR</displayName>
          <description>MDMA 通道 x 块重复地址更新寄存器</description>
          <addressOffset>0x220</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>SUV</name>
              <description>源地址更新值</description>
              <bitOffset>0</bitOffset>
              <bitWidth>16</bitWidth>
            </field>
            <field>
              <name>DUV</name>
              <description>目的地址更新值</description>
              <bitOffset>16</bitOffset>
              <bitWidth>16</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C7LAR</name>
          <displayName>MDMA_C7LAR</displayName>
          <description>MDMA 通道 x 链接地址寄存器</description>
          <addressOffset>0x224</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>LAR</name>
              <description>链接地址寄存器</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C7TBR</name>
          <displayName>MDMA_C7TBR</displayName>
          <description>MDMA 通道 x 触发与总线选择寄存器</description>
          <addressOffset>0x228</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>TSEL</name>
              <description>触发选择</description>
              <bitOffset>0</bitOffset>
              <bitWidth>6</bitWidth>
            </field>
            <field>
              <name>SBUS</name>
              <description>源总线选择。此位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>16</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DBUS</name>
              <description>目的总线选择。此位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>17</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C7MAR</name>
          <displayName>MDMA_C7MAR</displayName>
          <description>MDMA 通道 x 掩码地址寄存器</description>
          <addressOffset>0x230</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>MAR</name>
              <description>掩码地址</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C7MDR</name>
          <displayName>MDMA_C7MDR</displayName>
          <description>MDMA 通道 x 掩码数据寄存器</description>
          <addressOffset>0x234</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>MDR</name>
              <description>掩码数据</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C8ISR</name>
          <displayName>MDMA_C8ISR</displayName>
          <description>MDMA 通道 x 中断/状态寄存器</description>
          <addressOffset>0x240</addressOffset>
          <size>0x20</size>
          <access>read-only</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>TEIF8</name>
              <description>通道 x 传输错误中断标志。此位由硬件置位。软件向 DMA_IFCRy 寄存器的对应位写 1 可将其清零。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CTCIF8</name>
              <description>通道 x 通道传输完成中断标志。此位由硬件置位。软件向 DMA_IFCRy 寄存器的对应位写 1 可将其清零。当最后一个块传输完成且通道已自动禁用时，CTC 置位。当通道因 EN 位写 0 而挂起时，CTC 同样置位。</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>BRTIF8</name>
              <description>通道 x 块重复传输完成中断标志。此位由硬件置位。软件向 DMA_IFCRy 寄存器的对应位写 1 可将其清零。</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>BTIF8</name>
              <description>通道 x 块传输完成中断标志。此位由硬件置位。软件向 DMA_IFCRy 寄存器的对应位写 1 可将其清零。</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>TCIF8</name>
              <description>通道 x 缓冲区传输完成</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CRQA8</name>
              <description>通道 x 请求活跃标志</description>
              <bitOffset>16</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C8IFCR</name>
          <displayName>MDMA_C8IFCR</displayName>
          <description>MDMA 通道 x 中断标志清除寄存器</description>
          <addressOffset>0x244</addressOffset>
          <size>0x20</size>
          <access>write-only</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>CTEIF8</name>
              <description>通道 x 清除传输错误中断标志。向此位写 1 可将 MDMA_ISRy 寄存器中的 TEIFx 清零。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CCTCIF8</name>
              <description>通道 x 清除通道传输完成中断标志。向此位写 1 可将 MDMA_ISRy 寄存器中的 CTCIFx 清零。</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CBRTIF8</name>
              <description>通道 x 清除块重复传输完成中断标志。向此位写 1 可将 MDMA_ISRy 寄存器中的 BRTIFx 清零。</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CBTIF8</name>
              <description>通道 x 清除块传输完成中断标志。向此位写 1 可将 MDMA_ISRy 寄存器中的 BTIFx 清零。</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CLTCIF8</name>
              <description>通道 x 清除缓冲区传输完成中断标志。向此位写 1 可将 MDMA_ISRy 寄存器中的 TCIFx 清零。</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C8ESR</name>
          <displayName>MDMA_C8ESR</displayName>
          <description>MDMA 通道 x 错误状态寄存器</description>
          <addressOffset>0x248</addressOffset>
          <size>0x20</size>
          <access>read-only</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>TEA</name>
              <description>传输错误地址。在 MDMA 数据传输发生错误时，这些位由硬件置位与清零，与 TED 配合使用。该字段指示引发传输/访问错误的地址的低 7 位。软件可将其（截断至缓冲区传输长度大小）与当前 SAR/DAR 值相加来还原故障地址。注意：由于 FIFO 管理机制，SAR/DAR 当前值并不反映该最后地址。SAR/DAR 仅在（缓冲区）传完 TLEN+1 字节后才更新。注意：发生链接数据错误时此字段不会置位。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>7</bitWidth>
            </field>
            <field>
              <name>TED</name>
              <description>传输错误方向。在 MDMA 数据传输发生错误时，此位由硬件置位与清零。</description>
              <bitOffset>7</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>TELD</name>
              <description>传输错误（链接数据）。当读取块链接数据结构发生传输错误时，此位由硬件置位。软件向 DMA_IFCRy 寄存器中的 CTEIFx 位写 1 可将其清零。</description>
              <bitOffset>8</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>TEMD</name>
              <description>传输错误（掩码数据）。当写入掩码数据发生传输错误时，此位由硬件置位。软件向 DMA_IFCRy 寄存器中的 CTEIFx 位写 1 可将其清零。</description>
              <bitOffset>9</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>ASE</name>
              <description>地址/大小错误。当编程地址与数据大小不对齐时，此位由硬件置位。TED 将指示问题在源端还是目的端。软件向 DMA_IFCRy 寄存器中的 CTEIFx 位写 1 可将其清零。</description>
              <bitOffset>10</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>BSE</name>
              <description>块大小错误。当块大小不是源端或目的端数据大小的整数倍时，此位由硬件置位。TED 将指示问题在源端还是目的端。软件向 DMA_IFCRy 寄存器中的 CTEIFx 位写 1 可将其清零。</description>
              <bitOffset>11</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C8CR</name>
          <displayName>MDMA_C8CR</displayName>
          <description>此寄存器用于控制相应通道。</description>
          <addressOffset>0x24C</addressOffset>
          <size>0x20</size>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>EN</name>
              <description>通道使能</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>TEIE</name>
              <description>传输错误中断使能。此位由软件置位与清零。</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>CTCIE</name>
              <description>通道传输完成中断使能。此位由软件置位与清零。</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>BRTIE</name>
              <description>块重复传输中断使能。此位由软件置位与清零。</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>BTIE</name>
              <description>块传输中断使能。此位由软件置位与清零。</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>TCIE</name>
              <description>缓冲区传输完成中断使能。此位由软件置位与清零。</description>
              <bitOffset>5</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>PL</name>
              <description>优先级。这些位由软件置位与清零。这些位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>6</bitOffset>
              <bitWidth>2</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>BEX</name>
              <description>字节端序交换</description>
              <bitOffset>12</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>HEX</name>
              <description>半字端序交换</description>
              <bitOffset>13</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>WEX</name>
              <description>字端序交换</description>
              <bitOffset>14</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>SWRQ</name>
              <description>软件请求。向此位写 1 将使 MDMA_ISRy 寄存器中的 CRQAx 置位，从而激活通道 x 的请求。注意：可通过整个 CxCR 寄存器或地址偏移为 0x4E + 0x40*通道号的 8 位/16 位寄存器来激活 SWRQ。在软件请求的情况下，不会产生应答信号（无硬件信号，也不进行 CxMAR 写访问）。</description>
              <bitOffset>16</bitOffset>
              <bitWidth>1</bitWidth>
              <access>write-only</access>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C8TCR</name>
          <displayName>MDMA_C8TCR</displayName>
          <description>此寄存器用于配置相应通道。</description>
          <addressOffset>0x250</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>SINC</name>
              <description>源地址增量模式。这些位由软件置位与清零。这些位受保护，仅当 EN 为 0 时才可写入。注意：当源端为 AHB 总线时（SBUS=1），禁止 SINC = 00。在链接列表模式下，在一个块（单次或重复块传输模式中的最后一个块）结束时，此寄存器将从存储器（地址由当前 LAR[31:0] + 0x00 给出）重新加载。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>DINC</name>
              <description>目的地址增量模式。这些位由软件置位与清零。这些位受保护，仅当 EN 为 0 时才可写入。注意：当目的端为 AHB 总线时（DBUS=1），禁止 DINC = 00。</description>
              <bitOffset>2</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>SSIZE</name>
              <description>源数据大小。这些位由软件置位与清零。这些位受保护，仅当 EN 为 0 时才可写入。注意：若为 TCM 访问/AHB 端口编程了 11 值，将发生传输错误（TEIF 位置位）。若 SINCOS &lt; SSIZE 且 SINC != 00，结果不可预测。注意：当源端为 TCM/AHB 总线时（SBUS=1），禁止 SSIZE = 11（双字）。</description>
              <bitOffset>4</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>DSIZE</name>
              <description>目的数据大小。这些位由软件置位与清零。这些位受保护，仅当 EN 为 0 时才可写入。注意：若为 TCM 访问/AHB 端口编程了 11 值，将发生传输错误（TEIF 位置位）。若 DINCOS &lt; DSIZE 且 DINC != 00，结果不可预测。注意：当目的端为 TCM/AHB 总线时（DBUS=1），禁止 DSIZE = 11（双字）。</description>
              <bitOffset>6</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>SINCOS</name>
              <description>源地址增量偏移大小</description>
              <bitOffset>8</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>DINCOS</name>
              <description>目的地址增量偏移</description>
              <bitOffset>10</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>SBURST</name>
              <description>源端突发传输配置</description>
              <bitOffset>12</bitOffset>
              <bitWidth>3</bitWidth>
            </field>
            <field>
              <name>DBURST</name>
              <description>目的端突发传输配置</description>
              <bitOffset>15</bitOffset>
              <bitWidth>3</bitWidth>
            </field>
            <field>
              <name>TLEN</name>
              <description>缓冲区传输长度</description>
              <bitOffset>18</bitOffset>
              <bitWidth>7</bitWidth>
            </field>
            <field>
              <name>PKE</name>
              <description>打包使能。此位由软件置位与清零。若源数据大小小于目的数据大小，将按 PAM 值进行填充。若源数据大小大于目的数据大小，将被截断。对齐方式根据 PAM[0] 值确定。此位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>25</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>PAM</name>
              <description>填充/对齐模式。这些位由软件置位与清零。情况 1：源数据大小小于目的数据大小——3 种选项有效。情况 2：源数据大小大于目的数据大小——多余部分被丢弃。当 PKE = 1 或 DSIZE=SSIZE 时，这些位被忽略。这些位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>26</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>TRGM</name>
              <description>触发模式。这些位由软件置位与清零。注意：若当前块的 TRGM 为 11，则通过链接列表机制在当前块结束时加载的所有值必须保持相同的 TRGM=11 值和相同的 SWRM 值，否则结果未定义。这些位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>28</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>SWRM</name>
              <description>软件请求模式。此位由软件置位与清零。若当前有硬件或软件请求处于活跃状态，此位的变更将延迟到当前传输完成之后。若 CxMAR 包含有效地址，CxMDR 的值也将写入 CxMAR 地址。此位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>30</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>BWM</name>
              <description>缓冲写模式。此位由软件置位与清零。此位受保护，仅当 EN 为 0 时才可写入。注意：所有 MDMA 目的端访问均为不可缓存访问。</description>
              <bitOffset>31</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C8BNDTR</name>
          <displayName>MDMA_C8BNDTR</displayName>
          <description>MDMA 通道 x 块数据传输数量寄存器</description>
          <addressOffset>0x254</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>BNDT</name>
              <description>待传输数据块数量</description>
              <bitOffset>0</bitOffset>
              <bitWidth>17</bitWidth>
            </field>
            <field>
              <name>BRSUM</name>
              <description>块重复源地址更新模式。这些位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>18</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>BRDUM</name>
              <description>块重复目的地址更新模式。这些位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>19</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>BRC</name>
              <description>块重复计数。此字段包含当前块的重复次数（0 到 4095）。通道使能后，此寄存器为只读，指示剩余块数（不含当前块）。每次完整块传输完成后此寄存器递减。最后一个块传输完成后，此寄存器可保持为零，或自动从存储器重新加载（在链接列表模式下——即链接地址有效时）。这些位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>20</bitOffset>
              <bitWidth>12</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C8SAR</name>
          <displayName>MDMA_C8SAR</displayName>
          <description>MDMA 通道 x 源地址寄存器</description>
          <addressOffset>0x258</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>SAR</name>
              <description>源地址基址</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C8DAR</name>
          <displayName>MDMA_C8DAR</displayName>
          <description>MDMA 通道 x 目的地址寄存器</description>
          <addressOffset>0x25C</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>DAR</name>
              <description>目的地址基址</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C8BRUR</name>
          <displayName>MDMA_C8BRUR</displayName>
          <description>MDMA 通道 x 块重复地址更新寄存器</description>
          <addressOffset>0x260</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>SUV</name>
              <description>源地址更新值</description>
              <bitOffset>0</bitOffset>
              <bitWidth>16</bitWidth>
            </field>
            <field>
              <name>DUV</name>
              <description>目的地址更新值</description>
              <bitOffset>16</bitOffset>
              <bitWidth>16</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C8LAR</name>
          <displayName>MDMA_C8LAR</displayName>
          <description>MDMA 通道 x 链接地址寄存器</description>
          <addressOffset>0x264</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>LAR</name>
              <description>链接地址寄存器</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C8TBR</name>
          <displayName>MDMA_C8TBR</displayName>
          <description>MDMA 通道 x 触发与总线选择寄存器</description>
          <addressOffset>0x268</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>TSEL</name>
              <description>触发选择</description>
              <bitOffset>0</bitOffset>
              <bitWidth>6</bitWidth>
            </field>
            <field>
              <name>SBUS</name>
              <description>源总线选择。此位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>16</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DBUS</name>
              <description>目的总线选择。此位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>17</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C8MAR</name>
          <displayName>MDMA_C8MAR</displayName>
          <description>MDMA 通道 x 掩码地址寄存器</description>
          <addressOffset>0x270</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>MAR</name>
              <description>掩码地址</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C8MDR</name>
          <displayName>MDMA_C8MDR</displayName>
          <description>MDMA 通道 x 掩码数据寄存器</description>
          <addressOffset>0x274</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>MDR</name>
              <description>掩码数据</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C9ISR</name>
          <displayName>MDMA_C9ISR</displayName>
          <description>MDMA 通道 x 中断/状态寄存器</description>
          <addressOffset>0x280</addressOffset>
          <size>0x20</size>
          <access>read-only</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>TEIF9</name>
              <description>通道 x 传输错误中断标志。此位由硬件置位。软件向 DMA_IFCRy 寄存器的对应位写 1 可将其清零。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CTCIF9</name>
              <description>通道 x 通道传输完成中断标志。此位由硬件置位。软件向 DMA_IFCRy 寄存器的对应位写 1 可将其清零。当最后一个块传输完成且通道已自动禁用时，CTC 置位。当通道因 EN 位写 0 而挂起时，CTC 同样置位。</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>BRTIF9</name>
              <description>通道 x 块重复传输完成中断标志。此位由硬件置位。软件向 DMA_IFCRy 寄存器的对应位写 1 可将其清零。</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>BTIF9</name>
              <description>通道 x 块传输完成中断标志。此位由硬件置位。软件向 DMA_IFCRy 寄存器的对应位写 1 可将其清零。</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>TCIF9</name>
              <description>通道 x 缓冲区传输完成</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CRQA9</name>
              <description>通道 x 请求活跃标志</description>
              <bitOffset>16</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C9IFCR</name>
          <displayName>MDMA_C9IFCR</displayName>
          <description>MDMA 通道 x 中断标志清除寄存器</description>
          <addressOffset>0x284</addressOffset>
          <size>0x20</size>
          <access>write-only</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>CTEIF9</name>
              <description>通道 x 清除传输错误中断标志。向此位写 1 可将 MDMA_ISRy 寄存器中的 TEIFx 清零。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CCTCIF9</name>
              <description>通道 x 清除通道传输完成中断标志。向此位写 1 可将 MDMA_ISRy 寄存器中的 CTCIFx 清零。</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CBRTIF9</name>
              <description>通道 x 清除块重复传输完成中断标志。向此位写 1 可将 MDMA_ISRy 寄存器中的 BRTIFx 清零。</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CBTIF9</name>
              <description>通道 x 清除块传输完成中断标志。向此位写 1 可将 MDMA_ISRy 寄存器中的 BTIFx 清零。</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CLTCIF9</name>
              <description>通道 x 清除缓冲区传输完成中断标志。向此位写 1 可将 MDMA_ISRy 寄存器中的 TCIFx 清零。</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C9ESR</name>
          <displayName>MDMA_C9ESR</displayName>
          <description>MDMA 通道 x 错误状态寄存器</description>
          <addressOffset>0x288</addressOffset>
          <size>0x20</size>
          <access>read-only</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>TEA</name>
              <description>传输错误地址。在 MDMA 数据传输发生错误时，这些位由硬件置位与清零，与 TED 配合使用。该字段指示引发传输/访问错误的地址的低 7 位。软件可将其（截断至缓冲区传输长度大小）与当前 SAR/DAR 值相加来还原故障地址。注意：由于 FIFO 管理机制，SAR/DAR 当前值并不反映该最后地址。SAR/DAR 仅在（缓冲区）传完 TLEN+1 字节后才更新。注意：发生链接数据错误时此字段不会置位。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>7</bitWidth>
            </field>
            <field>
              <name>TED</name>
              <description>传输错误方向。在 MDMA 数据传输发生错误时，此位由硬件置位与清零。</description>
              <bitOffset>7</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>TELD</name>
              <description>传输错误（链接数据）。当读取块链接数据结构发生传输错误时，此位由硬件置位。软件向 DMA_IFCRy 寄存器中的 CTEIFx 位写 1 可将其清零。</description>
              <bitOffset>8</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>TEMD</name>
              <description>传输错误（掩码数据）。当写入掩码数据发生传输错误时，此位由硬件置位。软件向 DMA_IFCRy 寄存器中的 CTEIFx 位写 1 可将其清零。</description>
              <bitOffset>9</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>ASE</name>
              <description>地址/大小错误。当编程地址与数据大小不对齐时，此位由硬件置位。TED 将指示问题在源端还是目的端。软件向 DMA_IFCRy 寄存器中的 CTEIFx 位写 1 可将其清零。</description>
              <bitOffset>10</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>BSE</name>
              <description>块大小错误。当块大小不是源端或目的端数据大小的整数倍时，此位由硬件置位。TED 将指示问题在源端还是目的端。软件向 DMA_IFCRy 寄存器中的 CTEIFx 位写 1 可将其清零。</description>
              <bitOffset>11</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C9CR</name>
          <displayName>MDMA_C9CR</displayName>
          <description>此寄存器用于控制相应通道。</description>
          <addressOffset>0x28C</addressOffset>
          <size>0x20</size>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>EN</name>
              <description>通道使能</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>TEIE</name>
              <description>传输错误中断使能。此位由软件置位与清零。</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>CTCIE</name>
              <description>通道传输完成中断使能。此位由软件置位与清零。</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>BRTIE</name>
              <description>块重复传输中断使能。此位由软件置位与清零。</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>BTIE</name>
              <description>块传输中断使能。此位由软件置位与清零。</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>TCIE</name>
              <description>缓冲区传输完成中断使能。此位由软件置位与清零。</description>
              <bitOffset>5</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>PL</name>
              <description>优先级。这些位由软件置位与清零。这些位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>6</bitOffset>
              <bitWidth>2</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>BEX</name>
              <description>字节端序交换</description>
              <bitOffset>12</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>HEX</name>
              <description>半字端序交换</description>
              <bitOffset>13</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>WEX</name>
              <description>字端序交换</description>
              <bitOffset>14</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>SWRQ</name>
              <description>软件请求。向此位写 1 将使 MDMA_ISRy 寄存器中的 CRQAx 置位，从而激活通道 x 的请求。注意：可通过整个 CxCR 寄存器或地址偏移为 0x4E + 0x40*通道号的 8 位/16 位寄存器来激活 SWRQ。在软件请求的情况下，不会产生应答信号（无硬件信号，也不进行 CxMAR 写访问）。</description>
              <bitOffset>16</bitOffset>
              <bitWidth>1</bitWidth>
              <access>write-only</access>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C9TCR</name>
          <displayName>MDMA_C9TCR</displayName>
          <description>此寄存器用于配置相应通道。</description>
          <addressOffset>0x290</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>SINC</name>
              <description>源地址增量模式。这些位由软件置位与清零。这些位受保护，仅当 EN 为 0 时才可写入。注意：当源端为 AHB 总线时（SBUS=1），禁止 SINC = 00。在链接列表模式下，在一个块（单次或重复块传输模式中的最后一个块）结束时，此寄存器将从存储器（地址由当前 LAR[31:0] + 0x00 给出）重新加载。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>DINC</name>
              <description>目的地址增量模式。这些位由软件置位与清零。这些位受保护，仅当 EN 为 0 时才可写入。注意：当目的端为 AHB 总线时（DBUS=1），禁止 DINC = 00。</description>
              <bitOffset>2</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>SSIZE</name>
              <description>源数据大小。这些位由软件置位与清零。这些位受保护，仅当 EN 为 0 时才可写入。注意：若为 TCM 访问/AHB 端口编程了 11 值，将发生传输错误（TEIF 位置位）。若 SINCOS &lt; SSIZE 且 SINC != 00，结果不可预测。注意：当源端为 TCM/AHB 总线时（SBUS=1），禁止 SSIZE = 11（双字）。</description>
              <bitOffset>4</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>DSIZE</name>
              <description>目的数据大小。这些位由软件置位与清零。这些位受保护，仅当 EN 为 0 时才可写入。注意：若为 TCM 访问/AHB 端口编程了 11 值，将发生传输错误（TEIF 位置位）。若 DINCOS &lt; DSIZE 且 DINC != 00，结果不可预测。注意：当目的端为 TCM/AHB 总线时（DBUS=1），禁止 DSIZE = 11（双字）。</description>
              <bitOffset>6</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>SINCOS</name>
              <description>源地址增量偏移大小</description>
              <bitOffset>8</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>DINCOS</name>
              <description>目的地址增量偏移</description>
              <bitOffset>10</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>SBURST</name>
              <description>源端突发传输配置</description>
              <bitOffset>12</bitOffset>
              <bitWidth>3</bitWidth>
            </field>
            <field>
              <name>DBURST</name>
              <description>目的端突发传输配置</description>
              <bitOffset>15</bitOffset>
              <bitWidth>3</bitWidth>
            </field>
            <field>
              <name>TLEN</name>
              <description>缓冲区传输长度</description>
              <bitOffset>18</bitOffset>
              <bitWidth>7</bitWidth>
            </field>
            <field>
              <name>PKE</name>
              <description>打包使能。此位由软件置位与清零。若源数据大小小于目的数据大小，将按 PAM 值进行填充。若源数据大小大于目的数据大小，将被截断。对齐方式根据 PAM[0] 值确定。此位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>25</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>PAM</name>
              <description>填充/对齐模式。这些位由软件置位与清零。情况 1：源数据大小小于目的数据大小——3 种选项有效。情况 2：源数据大小大于目的数据大小——多余部分被丢弃。当 PKE = 1 或 DSIZE=SSIZE 时，这些位被忽略。这些位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>26</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>TRGM</name>
              <description>触发模式。这些位由软件置位与清零。注意：若当前块的 TRGM 为 11，则通过链接列表机制在当前块结束时加载的所有值必须保持相同的 TRGM=11 值和相同的 SWRM 值，否则结果未定义。这些位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>28</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>SWRM</name>
              <description>软件请求模式。此位由软件置位与清零。若当前有硬件或软件请求处于活跃状态，此位的变更将延迟到当前传输完成之后。若 CxMAR 包含有效地址，CxMDR 的值也将写入 CxMAR 地址。此位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>30</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>BWM</name>
              <description>缓冲写模式。此位由软件置位与清零。此位受保护，仅当 EN 为 0 时才可写入。注意：所有 MDMA 目的端访问均为不可缓存访问。</description>
              <bitOffset>31</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C9BNDTR</name>
          <displayName>MDMA_C9BNDTR</displayName>
          <description>MDMA 通道 x 块数据传输数量寄存器</description>
          <addressOffset>0x294</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>BNDT</name>
              <description>待传输数据块数量</description>
              <bitOffset>0</bitOffset>
              <bitWidth>17</bitWidth>
            </field>
            <field>
              <name>BRSUM</name>
              <description>块重复源地址更新模式。这些位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>18</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>BRDUM</name>
              <description>块重复目的地址更新模式。这些位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>19</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>BRC</name>
              <description>块重复计数。此字段包含当前块的重复次数（0 到 4095）。通道使能后，此寄存器为只读，指示剩余块数（不含当前块）。每次完整块传输完成后此寄存器递减。最后一个块传输完成后，此寄存器可保持为零，或自动从存储器重新加载（在链接列表模式下——即链接地址有效时）。这些位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>20</bitOffset>
              <bitWidth>12</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C9SAR</name>
          <displayName>MDMA_C9SAR</displayName>
          <description>MDMA 通道 x 源地址寄存器</description>
          <addressOffset>0x298</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>SAR</name>
              <description>源地址基址</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C9DAR</name>
          <displayName>MDMA_C9DAR</displayName>
          <description>MDMA 通道 x 目的地址寄存器</description>
          <addressOffset>0x29C</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>DAR</name>
              <description>目的地址基址</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C9BRUR</name>
          <displayName>MDMA_C9BRUR</displayName>
          <description>MDMA 通道 x 块重复地址更新寄存器</description>
          <addressOffset>0x2A0</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>SUV</name>
              <description>源地址更新值</description>
              <bitOffset>0</bitOffset>
              <bitWidth>16</bitWidth>
            </field>
            <field>
              <name>DUV</name>
              <description>目的地址更新值</description>
              <bitOffset>16</bitOffset>
              <bitWidth>16</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C9LAR</name>
          <displayName>MDMA_C9LAR</displayName>
          <description>MDMA 通道 x 链接地址寄存器</description>
          <addressOffset>0x2A4</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>LAR</name>
              <description>链接地址寄存器</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C9TBR</name>
          <displayName>MDMA_C9TBR</displayName>
          <description>MDMA 通道 x 触发与总线选择寄存器</description>
          <addressOffset>0x2A8</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>TSEL</name>
              <description>触发选择</description>
              <bitOffset>0</bitOffset>
              <bitWidth>6</bitWidth>
            </field>
            <field>
              <name>SBUS</name>
              <description>源总线选择。此位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>16</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DBUS</name>
              <description>目的总线选择。此位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>17</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C9MAR</name>
          <displayName>MDMA_C9MAR</displayName>
          <description>MDMA 通道 x 掩码地址寄存器</description>
          <addressOffset>0x2B0</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>MAR</name>
              <description>掩码地址</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C9MDR</name>
          <displayName>MDMA_C9MDR</displayName>
          <description>MDMA 通道 x 掩码数据寄存器</description>
          <addressOffset>0x2B4</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>MDR</name>
              <description>掩码数据</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C10ISR</name>
          <displayName>MDMA_C10ISR</displayName>
          <description>MDMA 通道 x 中断/状态寄存器</description>
          <addressOffset>0x2C0</addressOffset>
          <size>0x20</size>
          <access>read-only</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>TEIF10</name>
              <description>通道 x 传输错误中断标志。此位由硬件置位。软件向 DMA_IFCRy 寄存器的对应位写 1 可将其清零。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CTCIF10</name>
              <description>通道 x 通道传输完成中断标志。此位由硬件置位。软件向 DMA_IFCRy 寄存器的对应位写 1 可将其清零。当最后一个块传输完成且通道已自动禁用时，CTC 置位。当通道因 EN 位写 0 而挂起时，CTC 同样置位。</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>BRTIF10</name>
              <description>通道 x 块重复传输完成中断标志。此位由硬件置位。软件向 DMA_IFCRy 寄存器的对应位写 1 可将其清零。</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>BTIF10</name>
              <description>通道 x 块传输完成中断标志。此位由硬件置位。软件向 DMA_IFCRy 寄存器的对应位写 1 可将其清零。</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>TCIF10</name>
              <description>通道 x 缓冲区传输完成</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CRQA10</name>
              <description>通道 x 请求活跃标志</description>
              <bitOffset>16</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C10IFCR</name>
          <displayName>MDMA_C10IFCR</displayName>
          <description>MDMA 通道 x 中断标志清除寄存器</description>
          <addressOffset>0x2C4</addressOffset>
          <size>0x20</size>
          <access>write-only</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>CTEIF10</name>
              <description>通道 x 清除传输错误中断标志。向此位写 1 可将 MDMA_ISRy 寄存器中的 TEIFx 清零。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CCTCIF10</name>
              <description>通道 x 清除通道传输完成中断标志。向此位写 1 可将 MDMA_ISRy 寄存器中的 CTCIFx 清零。</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CBRTIF10</name>
              <description>通道 x 清除块重复传输完成中断标志。向此位写 1 可将 MDMA_ISRy 寄存器中的 BRTIFx 清零。</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CBTIF10</name>
              <description>通道 x 清除块传输完成中断标志。向此位写 1 可将 MDMA_ISRy 寄存器中的 BTIFx 清零。</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CLTCIF10</name>
              <description>通道 x 清除缓冲区传输完成中断标志。向此位写 1 可将 MDMA_ISRy 寄存器中的 TCIFx 清零。</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C10ESR</name>
          <displayName>MDMA_C10ESR</displayName>
          <description>MDMA 通道 x 错误状态寄存器</description>
          <addressOffset>0x2C8</addressOffset>
          <size>0x20</size>
          <access>read-only</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>TEA</name>
              <description>传输错误地址。在 MDMA 数据传输发生错误时，这些位由硬件置位与清零，与 TED 配合使用。该字段指示引发传输/访问错误的地址的低 7 位。软件可将其（截断至缓冲区传输长度大小）与当前 SAR/DAR 值相加来还原故障地址。注意：由于 FIFO 管理机制，SAR/DAR 当前值并不反映该最后地址。SAR/DAR 仅在（缓冲区）传完 TLEN+1 字节后才更新。注意：发生链接数据错误时此字段不会置位。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>7</bitWidth>
            </field>
            <field>
              <name>TED</name>
              <description>传输错误方向。在 MDMA 数据传输发生错误时，此位由硬件置位与清零。</description>
              <bitOffset>7</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>TELD</name>
              <description>传输错误（链接数据）。当读取块链接数据结构发生传输错误时，此位由硬件置位。软件向 DMA_IFCRy 寄存器中的 CTEIFx 位写 1 可将其清零。</description>
              <bitOffset>8</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>TEMD</name>
              <description>传输错误（掩码数据）。当写入掩码数据发生传输错误时，此位由硬件置位。软件向 DMA_IFCRy 寄存器中的 CTEIFx 位写 1 可将其清零。</description>
              <bitOffset>9</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>ASE</name>
              <description>地址/大小错误。当编程地址与数据大小不对齐时，此位由硬件置位。TED 将指示问题在源端还是目的端。软件向 DMA_IFCRy 寄存器中的 CTEIFx 位写 1 可将其清零。</description>
              <bitOffset>10</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>BSE</name>
              <description>块大小错误。当块大小不是源端或目的端数据大小的整数倍时，此位由硬件置位。TED 将指示问题在源端还是目的端。软件向 DMA_IFCRy 寄存器中的 CTEIFx 位写 1 可将其清零。</description>
              <bitOffset>11</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C10CR</name>
          <displayName>MDMA_C10CR</displayName>
          <description>此寄存器用于控制相应通道。</description>
          <addressOffset>0x2CC</addressOffset>
          <size>0x20</size>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>EN</name>
              <description>通道使能</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>TEIE</name>
              <description>传输错误中断使能。此位由软件置位与清零。</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>CTCIE</name>
              <description>通道传输完成中断使能。此位由软件置位与清零。</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>BRTIE</name>
              <description>块重复传输中断使能。此位由软件置位与清零。</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>BTIE</name>
              <description>块传输中断使能。此位由软件置位与清零。</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>TCIE</name>
              <description>缓冲区传输完成中断使能。此位由软件置位与清零。</description>
              <bitOffset>5</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>PL</name>
              <description>优先级。这些位由软件置位与清零。这些位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>6</bitOffset>
              <bitWidth>2</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>BEX</name>
              <description>字节端序交换</description>
              <bitOffset>12</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>HEX</name>
              <description>半字端序交换</description>
              <bitOffset>13</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>WEX</name>
              <description>字端序交换</description>
              <bitOffset>14</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>SWRQ</name>
              <description>软件请求。向此位写 1 将使 MDMA_ISRy 寄存器中的 CRQAx 置位，从而激活通道 x 的请求。注意：可通过整个 CxCR 寄存器或地址偏移为 0x4E + 0x40*通道号的 8 位/16 位寄存器来激活 SWRQ。在软件请求的情况下，不会产生应答信号（无硬件信号，也不进行 CxMAR 写访问）。</description>
              <bitOffset>16</bitOffset>
              <bitWidth>1</bitWidth>
              <access>write-only</access>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C10TCR</name>
          <displayName>MDMA_C10TCR</displayName>
          <description>此寄存器用于配置相应通道。</description>
          <addressOffset>0x2D0</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>SINC</name>
              <description>源地址增量模式。这些位由软件置位与清零。这些位受保护，仅当 EN 为 0 时才可写入。注意：当源端为 AHB 总线时（SBUS=1），禁止 SINC = 00。在链接列表模式下，在一个块（单次或重复块传输模式中的最后一个块）结束时，此寄存器将从存储器（地址由当前 LAR[31:0] + 0x00 给出）重新加载。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>DINC</name>
              <description>目的地址增量模式。这些位由软件置位与清零。这些位受保护，仅当 EN 为 0 时才可写入。注意：当目的端为 AHB 总线时（DBUS=1），禁止 DINC = 00。</description>
              <bitOffset>2</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>SSIZE</name>
              <description>源数据大小。这些位由软件置位与清零。这些位受保护，仅当 EN 为 0 时才可写入。注意：若为 TCM 访问/AHB 端口编程了 11 值，将发生传输错误（TEIF 位置位）。若 SINCOS &lt; SSIZE 且 SINC != 00，结果不可预测。注意：当源端为 TCM/AHB 总线时（SBUS=1），禁止 SSIZE = 11（双字）。</description>
              <bitOffset>4</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>DSIZE</name>
              <description>目的数据大小。这些位由软件置位与清零。这些位受保护，仅当 EN 为 0 时才可写入。注意：若为 TCM 访问/AHB 端口编程了 11 值，将发生传输错误（TEIF 位置位）。若 DINCOS &lt; DSIZE 且 DINC != 00，结果不可预测。注意：当目的端为 TCM/AHB 总线时（DBUS=1），禁止 DSIZE = 11（双字）。</description>
              <bitOffset>6</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>SINCOS</name>
              <description>源地址增量偏移大小</description>
              <bitOffset>8</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>DINCOS</name>
              <description>目的地址增量偏移</description>
              <bitOffset>10</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>SBURST</name>
              <description>源端突发传输配置</description>
              <bitOffset>12</bitOffset>
              <bitWidth>3</bitWidth>
            </field>
            <field>
              <name>DBURST</name>
              <description>目的端突发传输配置</description>
              <bitOffset>15</bitOffset>
              <bitWidth>3</bitWidth>
            </field>
            <field>
              <name>TLEN</name>
              <description>缓冲区传输长度</description>
              <bitOffset>18</bitOffset>
              <bitWidth>7</bitWidth>
            </field>
            <field>
              <name>PKE</name>
              <description>打包使能。此位由软件置位与清零。若源数据大小小于目的数据大小，将按 PAM 值进行填充。若源数据大小大于目的数据大小，将被截断。对齐方式根据 PAM[0] 值确定。此位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>25</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>PAM</name>
              <description>填充/对齐模式。这些位由软件置位与清零。情况 1：源数据大小小于目的数据大小——3 种选项有效。情况 2：源数据大小大于目的数据大小——多余部分被丢弃。当 PKE = 1 或 DSIZE=SSIZE 时，这些位被忽略。这些位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>26</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>TRGM</name>
              <description>触发模式。这些位由软件置位与清零。注意：若当前块的 TRGM 为 11，则通过链接列表机制在当前块结束时加载的所有值必须保持相同的 TRGM=11 值和相同的 SWRM 值，否则结果未定义。这些位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>28</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>SWRM</name>
              <description>软件请求模式。此位由软件置位与清零。若当前有硬件或软件请求处于活跃状态，此位的变更将延迟到当前传输完成之后。若 CxMAR 包含有效地址，CxMDR 的值也将写入 CxMAR 地址。此位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>30</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>BWM</name>
              <description>缓冲写模式。此位由软件置位与清零。此位受保护，仅当 EN 为 0 时才可写入。注意：所有 MDMA 目的端访问均为不可缓存访问。</description>
              <bitOffset>31</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C10BNDTR</name>
          <displayName>MDMA_C10BNDTR</displayName>
          <description>MDMA 通道 x 块数据传输数量寄存器</description>
          <addressOffset>0x2D4</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>BNDT</name>
              <description>待传输数据块数量</description>
              <bitOffset>0</bitOffset>
              <bitWidth>17</bitWidth>
            </field>
            <field>
              <name>BRSUM</name>
              <description>块重复源地址更新模式。这些位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>18</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>BRDUM</name>
              <description>块重复目的地址更新模式。这些位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>19</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>BRC</name>
              <description>块重复计数。此字段包含当前块的重复次数（0 到 4095）。通道使能后，此寄存器为只读，指示剩余块数（不含当前块）。每次完整块传输完成后此寄存器递减。最后一个块传输完成后，此寄存器可保持为零，或自动从存储器重新加载（在链接列表模式下——即链接地址有效时）。这些位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>20</bitOffset>
              <bitWidth>12</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C10SAR</name>
          <displayName>MDMA_C10SAR</displayName>
          <description>MDMA 通道 x 源地址寄存器</description>
          <addressOffset>0x2D8</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>SAR</name>
              <description>源地址基址</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C10DAR</name>
          <displayName>MDMA_C10DAR</displayName>
          <description>MDMA 通道 x 目的地址寄存器</description>
          <addressOffset>0x2DC</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>DAR</name>
              <description>目的地址基址</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C10BRUR</name>
          <displayName>MDMA_C10BRUR</displayName>
          <description>MDMA 通道 x 块重复地址更新寄存器</description>
          <addressOffset>0x2E0</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>SUV</name>
              <description>源地址更新值</description>
              <bitOffset>0</bitOffset>
              <bitWidth>16</bitWidth>
            </field>
            <field>
              <name>DUV</name>
              <description>目的地址更新值</description>
              <bitOffset>16</bitOffset>
              <bitWidth>16</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C10LAR</name>
          <displayName>MDMA_C10LAR</displayName>
          <description>MDMA 通道 x 链接地址寄存器</description>
          <addressOffset>0x2E4</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>LAR</name>
              <description>链接地址寄存器</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C10TBR</name>
          <displayName>MDMA_C10TBR</displayName>
          <description>MDMA 通道 x 触发与总线选择寄存器</description>
          <addressOffset>0x2E8</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>TSEL</name>
              <description>触发选择</description>
              <bitOffset>0</bitOffset>
              <bitWidth>6</bitWidth>
            </field>
            <field>
              <name>SBUS</name>
              <description>源总线选择。此位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>16</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DBUS</name>
              <description>目的总线选择。此位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>17</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C10MAR</name>
          <displayName>MDMA_C10MAR</displayName>
          <description>MDMA 通道 x 掩码地址寄存器</description>
          <addressOffset>0x2F0</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>MAR</name>
              <description>掩码地址</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C10MDR</name>
          <displayName>MDMA_C10MDR</displayName>
          <description>MDMA 通道 x 掩码数据寄存器</description>
          <addressOffset>0x2F4</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>MDR</name>
              <description>掩码数据</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C11ISR</name>
          <displayName>MDMA_C11ISR</displayName>
          <description>MDMA 通道 x 中断/状态寄存器</description>
          <addressOffset>0x300</addressOffset>
          <size>0x20</size>
          <access>read-only</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>TEIF11</name>
              <description>通道 x 传输错误中断标志。此位由硬件置位。软件向 DMA_IFCRy 寄存器的对应位写 1 可将其清零。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CTCIF11</name>
              <description>通道 x 通道传输完成中断标志。此位由硬件置位。软件向 DMA_IFCRy 寄存器的对应位写 1 可将其清零。当最后一个块传输完成且通道已自动禁用时，CTC 置位。当通道因 EN 位写 0 而挂起时，CTC 同样置位。</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>BRTIF11</name>
              <description>通道 x 块重复传输完成中断标志。此位由硬件置位。软件向 DMA_IFCRy 寄存器的对应位写 1 可将其清零。</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>BTIF11</name>
              <description>通道 x 块传输完成中断标志。此位由硬件置位。软件向 DMA_IFCRy 寄存器的对应位写 1 可将其清零。</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>TCIF11</name>
              <description>通道 x 缓冲区传输完成</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CRQA11</name>
              <description>通道 x 请求活跃标志</description>
              <bitOffset>16</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C11IFCR</name>
          <displayName>MDMA_C11IFCR</displayName>
          <description>MDMA 通道 x 中断标志清除寄存器</description>
          <addressOffset>0x304</addressOffset>
          <size>0x20</size>
          <access>write-only</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>CTEIF11</name>
              <description>通道 x 清除传输错误中断标志。向此位写 1 可将 MDMA_ISRy 寄存器中的 TEIFx 清零。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CCTCIF11</name>
              <description>通道 x 清除通道传输完成中断标志。向此位写 1 可将 MDMA_ISRy 寄存器中的 CTCIFx 清零。</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CBRTIF11</name>
              <description>通道 x 清除块重复传输完成中断标志。向此位写 1 可将 MDMA_ISRy 寄存器中的 BRTIFx 清零。</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CBTIF11</name>
              <description>通道 x 清除块传输完成中断标志。向此位写 1 可将 MDMA_ISRy 寄存器中的 BTIFx 清零。</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CLTCIF11</name>
              <description>通道 x 清除缓冲区传输完成中断标志。向此位写 1 可将 MDMA_ISRy 寄存器中的 TCIFx 清零。</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C11ESR</name>
          <displayName>MDMA_C11ESR</displayName>
          <description>MDMA 通道 x 错误状态寄存器</description>
          <addressOffset>0x308</addressOffset>
          <size>0x20</size>
          <access>read-only</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>TEA</name>
              <description>传输错误地址。在 MDMA 数据传输发生错误时，这些位由硬件置位与清零，与 TED 配合使用。该字段指示引发传输/访问错误的地址的低 7 位。软件可将其（截断至缓冲区传输长度大小）与当前 SAR/DAR 值相加来还原故障地址。注意：由于 FIFO 管理机制，SAR/DAR 当前值并不反映该最后地址。SAR/DAR 仅在（缓冲区）传完 TLEN+1 字节后才更新。注意：发生链接数据错误时此字段不会置位。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>7</bitWidth>
            </field>
            <field>
              <name>TED</name>
              <description>传输错误方向。在 MDMA 数据传输发生错误时，此位由硬件置位与清零。</description>
              <bitOffset>7</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>TELD</name>
              <description>传输错误（链接数据）。当读取块链接数据结构发生传输错误时，此位由硬件置位。软件向 DMA_IFCRy 寄存器中的 CTEIFx 位写 1 可将其清零。</description>
              <bitOffset>8</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>TEMD</name>
              <description>传输错误（掩码数据）。当写入掩码数据发生传输错误时，此位由硬件置位。软件向 DMA_IFCRy 寄存器中的 CTEIFx 位写 1 可将其清零。</description>
              <bitOffset>9</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>ASE</name>
              <description>地址/大小错误。当编程地址与数据大小不对齐时，此位由硬件置位。TED 将指示问题在源端还是目的端。软件向 DMA_IFCRy 寄存器中的 CTEIFx 位写 1 可将其清零。</description>
              <bitOffset>10</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>BSE</name>
              <description>块大小错误。当块大小不是源端或目的端数据大小的整数倍时，此位由硬件置位。TED 将指示问题在源端还是目的端。软件向 DMA_IFCRy 寄存器中的 CTEIFx 位写 1 可将其清零。</description>
              <bitOffset>11</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C11CR</name>
          <displayName>MDMA_C11CR</displayName>
          <description>此寄存器用于控制相应通道。</description>
          <addressOffset>0x30C</addressOffset>
          <size>0x20</size>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>EN</name>
              <description>通道使能</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>TEIE</name>
              <description>传输错误中断使能。此位由软件置位与清零。</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>CTCIE</name>
              <description>通道传输完成中断使能。此位由软件置位与清零。</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>BRTIE</name>
              <description>块重复传输中断使能。此位由软件置位与清零。</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>BTIE</name>
              <description>块传输中断使能。此位由软件置位与清零。</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>TCIE</name>
              <description>缓冲区传输完成中断使能。此位由软件置位与清零。</description>
              <bitOffset>5</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>PL</name>
              <description>优先级。这些位由软件置位与清零。这些位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>6</bitOffset>
              <bitWidth>2</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>BEX</name>
              <description>字节端序交换</description>
              <bitOffset>12</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>HEX</name>
              <description>半字端序交换</description>
              <bitOffset>13</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>WEX</name>
              <description>字端序交换</description>
              <bitOffset>14</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>SWRQ</name>
              <description>软件请求。向此位写 1 将使 MDMA_ISRy 寄存器中的 CRQAx 置位，从而激活通道 x 的请求。注意：可通过整个 CxCR 寄存器或地址偏移为 0x4E + 0x40*通道号的 8 位/16 位寄存器来激活 SWRQ。在软件请求的情况下，不会产生应答信号（无硬件信号，也不进行 CxMAR 写访问）。</description>
              <bitOffset>16</bitOffset>
              <bitWidth>1</bitWidth>
              <access>write-only</access>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C11TCR</name>
          <displayName>MDMA_C11TCR</displayName>
          <description>此寄存器用于配置相应通道。</description>
          <addressOffset>0x310</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>SINC</name>
              <description>源地址增量模式。这些位由软件置位与清零。这些位受保护，仅当 EN 为 0 时才可写入。注意：当源端为 AHB 总线时（SBUS=1），禁止 SINC = 00。在链接列表模式下，在一个块（单次或重复块传输模式中的最后一个块）结束时，此寄存器将从存储器（地址由当前 LAR[31:0] + 0x00 给出）重新加载。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>DINC</name>
              <description>目的地址增量模式。这些位由软件置位与清零。这些位受保护，仅当 EN 为 0 时才可写入。注意：当目的端为 AHB 总线时（DBUS=1），禁止 DINC = 00。</description>
              <bitOffset>2</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>SSIZE</name>
              <description>源数据大小。这些位由软件置位与清零。这些位受保护，仅当 EN 为 0 时才可写入。注意：若为 TCM 访问/AHB 端口编程了 11 值，将发生传输错误（TEIF 位置位）。若 SINCOS &lt; SSIZE 且 SINC != 00，结果不可预测。注意：当源端为 TCM/AHB 总线时（SBUS=1），禁止 SSIZE = 11（双字）。</description>
              <bitOffset>4</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>DSIZE</name>
              <description>目的数据大小。这些位由软件置位与清零。这些位受保护，仅当 EN 为 0 时才可写入。注意：若为 TCM 访问/AHB 端口编程了 11 值，将发生传输错误（TEIF 位置位）。若 DINCOS &lt; DSIZE 且 DINC != 00，结果不可预测。注意：当目的端为 TCM/AHB 总线时（DBUS=1），禁止 DSIZE = 11（双字）。</description>
              <bitOffset>6</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>SINCOS</name>
              <description>源地址增量偏移大小</description>
              <bitOffset>8</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>DINCOS</name>
              <description>目的地址增量偏移</description>
              <bitOffset>10</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>SBURST</name>
              <description>源端突发传输配置</description>
              <bitOffset>12</bitOffset>
              <bitWidth>3</bitWidth>
            </field>
            <field>
              <name>DBURST</name>
              <description>目的端突发传输配置</description>
              <bitOffset>15</bitOffset>
              <bitWidth>3</bitWidth>
            </field>
            <field>
              <name>TLEN</name>
              <description>缓冲区传输长度</description>
              <bitOffset>18</bitOffset>
              <bitWidth>7</bitWidth>
            </field>
            <field>
              <name>PKE</name>
              <description>打包使能。此位由软件置位与清零。若源数据大小小于目的数据大小，将按 PAM 值进行填充。若源数据大小大于目的数据大小，将被截断。对齐方式根据 PAM[0] 值确定。此位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>25</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>PAM</name>
              <description>填充/对齐模式。这些位由软件置位与清零。情况 1：源数据大小小于目的数据大小——3 种选项有效。情况 2：源数据大小大于目的数据大小——多余部分被丢弃。当 PKE = 1 或 DSIZE=SSIZE 时，这些位被忽略。这些位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>26</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>TRGM</name>
              <description>触发模式。这些位由软件置位与清零。注意：若当前块的 TRGM 为 11，则通过链接列表机制在当前块结束时加载的所有值必须保持相同的 TRGM=11 值和相同的 SWRM 值，否则结果未定义。这些位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>28</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>SWRM</name>
              <description>软件请求模式。此位由软件置位与清零。若当前有硬件或软件请求处于活跃状态，此位的变更将延迟到当前传输完成之后。若 CxMAR 包含有效地址，CxMDR 的值也将写入 CxMAR 地址。此位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>30</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>BWM</name>
              <description>缓冲写模式。此位由软件置位与清零。此位受保护，仅当 EN 为 0 时才可写入。注意：所有 MDMA 目的端访问均为不可缓存访问。</description>
              <bitOffset>31</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C11BNDTR</name>
          <displayName>MDMA_C11BNDTR</displayName>
          <description>MDMA 通道 x 块数据传输数量寄存器</description>
          <addressOffset>0x314</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>BNDT</name>
              <description>待传输数据块数量</description>
              <bitOffset>0</bitOffset>
              <bitWidth>17</bitWidth>
            </field>
            <field>
              <name>BRSUM</name>
              <description>块重复源地址更新模式。这些位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>18</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>BRDUM</name>
              <description>块重复目的地址更新模式。这些位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>19</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>BRC</name>
              <description>块重复计数。此字段包含当前块的重复次数（0 到 4095）。通道使能后，此寄存器为只读，指示剩余块数（不含当前块）。每次完整块传输完成后此寄存器递减。最后一个块传输完成后，此寄存器可保持为零，或自动从存储器重新加载（在链接列表模式下——即链接地址有效时）。这些位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>20</bitOffset>
              <bitWidth>12</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C11SAR</name>
          <displayName>MDMA_C11SAR</displayName>
          <description>MDMA 通道 x 源地址寄存器</description>
          <addressOffset>0x318</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>SAR</name>
              <description>源地址基址</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C11DAR</name>
          <displayName>MDMA_C11DAR</displayName>
          <description>MDMA 通道 x 目的地址寄存器</description>
          <addressOffset>0x31C</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>DAR</name>
              <description>目的地址基址</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C11BRUR</name>
          <displayName>MDMA_C11BRUR</displayName>
          <description>MDMA 通道 x 块重复地址更新寄存器</description>
          <addressOffset>0x320</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>SUV</name>
              <description>源地址更新值</description>
              <bitOffset>0</bitOffset>
              <bitWidth>16</bitWidth>
            </field>
            <field>
              <name>DUV</name>
              <description>目的地址更新值</description>
              <bitOffset>16</bitOffset>
              <bitWidth>16</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C11LAR</name>
          <displayName>MDMA_C11LAR</displayName>
          <description>MDMA 通道 x 链接地址寄存器</description>
          <addressOffset>0x324</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>LAR</name>
              <description>链接地址寄存器</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C11TBR</name>
          <displayName>MDMA_C11TBR</displayName>
          <description>MDMA 通道 x 触发与总线选择寄存器</description>
          <addressOffset>0x328</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>TSEL</name>
              <description>触发选择</description>
              <bitOffset>0</bitOffset>
              <bitWidth>6</bitWidth>
            </field>
            <field>
              <name>SBUS</name>
              <description>源总线选择。此位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>16</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DBUS</name>
              <description>目的总线选择。此位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>17</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C11MAR</name>
          <displayName>MDMA_C11MAR</displayName>
          <description>MDMA 通道 x 掩码地址寄存器</description>
          <addressOffset>0x330</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>MAR</name>
              <description>掩码地址</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C11MDR</name>
          <displayName>MDMA_C11MDR</displayName>
          <description>MDMA 通道 x 掩码数据寄存器</description>
          <addressOffset>0x334</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>MDR</name>
              <description>掩码数据</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C12ISR</name>
          <displayName>MDMA_C12ISR</displayName>
          <description>MDMA 通道 x 中断/状态寄存器</description>
          <addressOffset>0x340</addressOffset>
          <size>0x20</size>
          <access>read-only</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>TEIF12</name>
              <description>通道 x 传输错误中断标志。此位由硬件置位。软件向 DMA_IFCRy 寄存器的对应位写 1 可将其清零。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CTCIF12</name>
              <description>通道 x 通道传输完成中断标志。此位由硬件置位。软件向 DMA_IFCRy 寄存器的对应位写 1 可将其清零。当最后一个块传输完成且通道已自动禁用时，CTC 置位。当通道因 EN 位写 0 而挂起时，CTC 同样置位。</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>BRTIF12</name>
              <description>通道 x 块重复传输完成中断标志。此位由硬件置位。软件向 DMA_IFCRy 寄存器的对应位写 1 可将其清零。</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>BTIF12</name>
              <description>通道 x 块传输完成中断标志。此位由硬件置位。软件向 DMA_IFCRy 寄存器的对应位写 1 可将其清零。</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>TCIF12</name>
              <description>通道 x 缓冲区传输完成</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CRQA12</name>
              <description>通道 x 请求活跃标志</description>
              <bitOffset>16</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C12IFCR</name>
          <displayName>MDMA_C12IFCR</displayName>
          <description>MDMA 通道 x 中断标志清除寄存器</description>
          <addressOffset>0x344</addressOffset>
          <size>0x20</size>
          <access>write-only</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>CTEIF12</name>
              <description>通道 x 清除传输错误中断标志。向此位写 1 可将 MDMA_ISRy 寄存器中的 TEIFx 清零。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CCTCIF12</name>
              <description>通道 x 清除通道传输完成中断标志。向此位写 1 可将 MDMA_ISRy 寄存器中的 CTCIFx 清零。</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CBRTIF12</name>
              <description>通道 x 清除块重复传输完成中断标志。向此位写 1 可将 MDMA_ISRy 寄存器中的 BRTIFx 清零。</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CBTIF12</name>
              <description>通道 x 清除块传输完成中断标志。向此位写 1 可将 MDMA_ISRy 寄存器中的 BTIFx 清零。</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CLTCIF12</name>
              <description>通道 x 清除缓冲区传输完成中断标志。向此位写 1 可将 MDMA_ISRy 寄存器中的 TCIFx 清零。</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C12ESR</name>
          <displayName>MDMA_C12ESR</displayName>
          <description>MDMA 通道 x 错误状态寄存器</description>
          <addressOffset>0x348</addressOffset>
          <size>0x20</size>
          <access>read-only</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>TEA</name>
              <description>传输错误地址。在 MDMA 数据传输发生错误时，这些位由硬件置位与清零，与 TED 配合使用。该字段指示引发传输/访问错误的地址的低 7 位。软件可将其（截断至缓冲区传输长度大小）与当前 SAR/DAR 值相加来还原故障地址。注意：由于 FIFO 管理机制，SAR/DAR 当前值并不反映该最后地址。SAR/DAR 仅在（缓冲区）传完 TLEN+1 字节后才更新。注意：发生链接数据错误时此字段不会置位。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>7</bitWidth>
            </field>
            <field>
              <name>TED</name>
              <description>传输错误方向。在 MDMA 数据传输发生错误时，此位由硬件置位与清零。</description>
              <bitOffset>7</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>TELD</name>
              <description>传输错误（链接数据）。当读取块链接数据结构发生传输错误时，此位由硬件置位。软件向 DMA_IFCRy 寄存器中的 CTEIFx 位写 1 可将其清零。</description>
              <bitOffset>8</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>TEMD</name>
              <description>传输错误（掩码数据）。当写入掩码数据发生传输错误时，此位由硬件置位。软件向 DMA_IFCRy 寄存器中的 CTEIFx 位写 1 可将其清零。</description>
              <bitOffset>9</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>ASE</name>
              <description>地址/大小错误。当编程地址与数据大小不对齐时，此位由硬件置位。TED 将指示问题在源端还是目的端。软件向 DMA_IFCRy 寄存器中的 CTEIFx 位写 1 可将其清零。</description>
              <bitOffset>10</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>BSE</name>
              <description>块大小错误。当块大小不是源端或目的端数据大小的整数倍时，此位由硬件置位。TED 将指示问题在源端还是目的端。软件向 DMA_IFCRy 寄存器中的 CTEIFx 位写 1 可将其清零。</description>
              <bitOffset>11</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C12CR</name>
          <displayName>MDMA_C12CR</displayName>
          <description>此寄存器用于控制相应通道。</description>
          <addressOffset>0x34C</addressOffset>
          <size>0x20</size>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>EN</name>
              <description>通道使能</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>TEIE</name>
              <description>传输错误中断使能。此位由软件置位与清零。</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>CTCIE</name>
              <description>通道传输完成中断使能。此位由软件置位与清零。</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>BRTIE</name>
              <description>块重复传输中断使能。此位由软件置位与清零。</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>BTIE</name>
              <description>块传输中断使能。此位由软件置位与清零。</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>TCIE</name>
              <description>缓冲区传输完成中断使能。此位由软件置位与清零。</description>
              <bitOffset>5</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>PL</name>
              <description>优先级。这些位由软件置位与清零。这些位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>6</bitOffset>
              <bitWidth>2</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>BEX</name>
              <description>字节端序交换</description>
              <bitOffset>12</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>HEX</name>
              <description>半字端序交换</description>
              <bitOffset>13</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>WEX</name>
              <description>字端序交换</description>
              <bitOffset>14</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>SWRQ</name>
              <description>软件请求。向此位写 1 将使 MDMA_ISRy 寄存器中的 CRQAx 置位，从而激活通道 x 的请求。注意：可通过整个 CxCR 寄存器或地址偏移为 0x4E + 0x40*通道号的 8 位/16 位寄存器来激活 SWRQ。在软件请求的情况下，不会产生应答信号（无硬件信号，也不进行 CxMAR 写访问）。</description>
              <bitOffset>16</bitOffset>
              <bitWidth>1</bitWidth>
              <access>write-only</access>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C12TCR</name>
          <displayName>MDMA_C12TCR</displayName>
          <description>此寄存器用于配置相应通道。</description>
          <addressOffset>0x350</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>SINC</name>
              <description>源地址增量模式。这些位由软件置位与清零。这些位受保护，仅当 EN 为 0 时才可写入。注意：当源端为 AHB 总线时（SBUS=1），禁止 SINC = 00。在链接列表模式下，在一个块（单次或重复块传输模式中的最后一个块）结束时，此寄存器将从存储器（地址由当前 LAR[31:0] + 0x00 给出）重新加载。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>DINC</name>
              <description>目的地址增量模式。这些位由软件置位与清零。这些位受保护，仅当 EN 为 0 时才可写入。注意：当目的端为 AHB 总线时（DBUS=1），禁止 DINC = 00。</description>
              <bitOffset>2</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>SSIZE</name>
              <description>源数据大小。这些位由软件置位与清零。这些位受保护，仅当 EN 为 0 时才可写入。注意：若为 TCM 访问/AHB 端口编程了 11 值，将发生传输错误（TEIF 位置位）。若 SINCOS &lt; SSIZE 且 SINC != 00，结果不可预测。注意：当源端为 TCM/AHB 总线时（SBUS=1），禁止 SSIZE = 11（双字）。</description>
              <bitOffset>4</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>DSIZE</name>
              <description>目的数据大小。这些位由软件置位与清零。这些位受保护，仅当 EN 为 0 时才可写入。注意：若为 TCM 访问/AHB 端口编程了 11 值，将发生传输错误（TEIF 位置位）。若 DINCOS &lt; DSIZE 且 DINC != 00，结果不可预测。注意：当目的端为 TCM/AHB 总线时（DBUS=1），禁止 DSIZE = 11（双字）。</description>
              <bitOffset>6</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>SINCOS</name>
              <description>源地址增量偏移大小</description>
              <bitOffset>8</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>DINCOS</name>
              <description>目的地址增量偏移</description>
              <bitOffset>10</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>SBURST</name>
              <description>源端突发传输配置</description>
              <bitOffset>12</bitOffset>
              <bitWidth>3</bitWidth>
            </field>
            <field>
              <name>DBURST</name>
              <description>目的端突发传输配置</description>
              <bitOffset>15</bitOffset>
              <bitWidth>3</bitWidth>
            </field>
            <field>
              <name>TLEN</name>
              <description>缓冲区传输长度</description>
              <bitOffset>18</bitOffset>
              <bitWidth>7</bitWidth>
            </field>
            <field>
              <name>PKE</name>
              <description>打包使能。此位由软件置位与清零。若源数据大小小于目的数据大小，将按 PAM 值进行填充。若源数据大小大于目的数据大小，将被截断。对齐方式根据 PAM[0] 值确定。此位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>25</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>PAM</name>
              <description>填充/对齐模式。这些位由软件置位与清零。情况 1：源数据大小小于目的数据大小——3 种选项有效。情况 2：源数据大小大于目的数据大小——多余部分被丢弃。当 PKE = 1 或 DSIZE=SSIZE 时，这些位被忽略。这些位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>26</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>TRGM</name>
              <description>触发模式。这些位由软件置位与清零。注意：若当前块的 TRGM 为 11，则通过链接列表机制在当前块结束时加载的所有值必须保持相同的 TRGM=11 值和相同的 SWRM 值，否则结果未定义。这些位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>28</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>SWRM</name>
              <description>软件请求模式。此位由软件置位与清零。若当前有硬件或软件请求处于活跃状态，此位的变更将延迟到当前传输完成之后。若 CxMAR 包含有效地址，CxMDR 的值也将写入 CxMAR 地址。此位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>30</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>BWM</name>
              <description>缓冲写模式。此位由软件置位与清零。此位受保护，仅当 EN 为 0 时才可写入。注意：所有 MDMA 目的端访问均为不可缓存访问。</description>
              <bitOffset>31</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C12BNDTR</name>
          <displayName>MDMA_C12BNDTR</displayName>
          <description>MDMA 通道 x 块数据传输数量寄存器</description>
          <addressOffset>0x354</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>BNDT</name>
              <description>待传输数据块数量</description>
              <bitOffset>0</bitOffset>
              <bitWidth>17</bitWidth>
            </field>
            <field>
              <name>BRSUM</name>
              <description>块重复源地址更新模式。这些位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>18</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>BRDUM</name>
              <description>块重复目的地址更新模式。这些位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>19</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>BRC</name>
              <description>块重复计数。此字段包含当前块的重复次数（0 到 4095）。通道使能后，此寄存器为只读，指示剩余块数（不含当前块）。每次完整块传输完成后此寄存器递减。最后一个块传输完成后，此寄存器可保持为零，或自动从存储器重新加载（在链接列表模式下——即链接地址有效时）。这些位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>20</bitOffset>
              <bitWidth>12</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C12SAR</name>
          <displayName>MDMA_C12SAR</displayName>
          <description>MDMA 通道 x 源地址寄存器</description>
          <addressOffset>0x358</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>SAR</name>
              <description>源地址基址</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C12DAR</name>
          <displayName>MDMA_C12DAR</displayName>
          <description>MDMA 通道 x 目的地址寄存器</description>
          <addressOffset>0x35C</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>DAR</name>
              <description>目的地址基址</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C12BRUR</name>
          <displayName>MDMA_C12BRUR</displayName>
          <description>MDMA 通道 x 块重复地址更新寄存器</description>
          <addressOffset>0x360</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>SUV</name>
              <description>源地址更新值</description>
              <bitOffset>0</bitOffset>
              <bitWidth>16</bitWidth>
            </field>
            <field>
              <name>DUV</name>
              <description>目的地址更新值</description>
              <bitOffset>16</bitOffset>
              <bitWidth>16</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C12LAR</name>
          <displayName>MDMA_C12LAR</displayName>
          <description>MDMA 通道 x 链接地址寄存器</description>
          <addressOffset>0x364</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>LAR</name>
              <description>链接地址寄存器</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C12TBR</name>
          <displayName>MDMA_C12TBR</displayName>
          <description>MDMA 通道 x 触发与总线选择寄存器</description>
          <addressOffset>0x368</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>TSEL</name>
              <description>触发选择</description>
              <bitOffset>0</bitOffset>
              <bitWidth>6</bitWidth>
            </field>
            <field>
              <name>SBUS</name>
              <description>源总线选择。此位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>16</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DBUS</name>
              <description>目的总线选择。此位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>17</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C12MAR</name>
          <displayName>MDMA_C12MAR</displayName>
          <description>MDMA 通道 x 掩码地址寄存器</description>
          <addressOffset>0x370</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>MAR</name>
              <description>掩码地址</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C12MDR</name>
          <displayName>MDMA_C12MDR</displayName>
          <description>MDMA 通道 x 掩码数据寄存器</description>
          <addressOffset>0x374</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>MDR</name>
              <description>掩码数据</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C13ISR</name>
          <displayName>MDMA_C13ISR</displayName>
          <description>MDMA 通道 x 中断/状态寄存器</description>
          <addressOffset>0x380</addressOffset>
          <size>0x20</size>
          <access>read-only</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>TEIF13</name>
              <description>通道 x 传输错误中断标志。此位由硬件置位。软件向 DMA_IFCRy 寄存器的对应位写 1 可将其清零。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CTCIF13</name>
              <description>通道 x 通道传输完成中断标志。此位由硬件置位。软件向 DMA_IFCRy 寄存器的对应位写 1 可将其清零。当最后一个块传输完成且通道已自动禁用时，CTC 置位。当通道因 EN 位写 0 而挂起时，CTC 同样置位。</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>BRTIF13</name>
              <description>通道 x 块重复传输完成中断标志。此位由硬件置位。软件向 DMA_IFCRy 寄存器的对应位写 1 可将其清零。</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>BTIF13</name>
              <description>通道 x 块传输完成中断标志。此位由硬件置位。软件向 DMA_IFCRy 寄存器的对应位写 1 可将其清零。</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>TCIF13</name>
              <description>通道 x 缓冲区传输完成</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CRQA13</name>
              <description>通道 x 请求活跃标志</description>
              <bitOffset>16</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C13IFCR</name>
          <displayName>MDMA_C13IFCR</displayName>
          <description>MDMA 通道 x 中断标志清除寄存器</description>
          <addressOffset>0x384</addressOffset>
          <size>0x20</size>
          <access>write-only</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>CTEIF13</name>
              <description>通道 x 清除传输错误中断标志。向此位写 1 可将 MDMA_ISRy 寄存器中的 TEIFx 清零。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CCTCIF13</name>
              <description>通道 x 清除通道传输完成中断标志。向此位写 1 可将 MDMA_ISRy 寄存器中的 CTCIFx 清零。</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CBRTIF13</name>
              <description>通道 x 清除块重复传输完成中断标志。向此位写 1 可将 MDMA_ISRy 寄存器中的 BRTIFx 清零。</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CBTIF13</name>
              <description>通道 x 清除块传输完成中断标志。向此位写 1 可将 MDMA_ISRy 寄存器中的 BTIFx 清零。</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CLTCIF13</name>
              <description>通道 x 清除缓冲区传输完成中断标志。向此位写 1 可将 MDMA_ISRy 寄存器中的 TCIFx 清零。</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C13ESR</name>
          <displayName>MDMA_C13ESR</displayName>
          <description>MDMA 通道 x 错误状态寄存器</description>
          <addressOffset>0x388</addressOffset>
          <size>0x20</size>
          <access>read-only</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>TEA</name>
              <description>传输错误地址。在 MDMA 数据传输发生错误时，这些位由硬件置位与清零，与 TED 配合使用。该字段指示引发传输/访问错误的地址的低 7 位。软件可将其（截断至缓冲区传输长度大小）与当前 SAR/DAR 值相加来还原故障地址。注意：由于 FIFO 管理机制，SAR/DAR 当前值并不反映该最后地址。SAR/DAR 仅在（缓冲区）传完 TLEN+1 字节后才更新。注意：发生链接数据错误时此字段不会置位。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>7</bitWidth>
            </field>
            <field>
              <name>TED</name>
              <description>传输错误方向。在 MDMA 数据传输发生错误时，此位由硬件置位与清零。</description>
              <bitOffset>7</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>TELD</name>
              <description>传输错误（链接数据）。当读取块链接数据结构发生传输错误时，此位由硬件置位。软件向 DMA_IFCRy 寄存器中的 CTEIFx 位写 1 可将其清零。</description>
              <bitOffset>8</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>TEMD</name>
              <description>传输错误（掩码数据）。当写入掩码数据发生传输错误时，此位由硬件置位。软件向 DMA_IFCRy 寄存器中的 CTEIFx 位写 1 可将其清零。</description>
              <bitOffset>9</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>ASE</name>
              <description>地址/大小错误。当编程地址与数据大小不对齐时，此位由硬件置位。TED 将指示问题在源端还是目的端。软件向 DMA_IFCRy 寄存器中的 CTEIFx 位写 1 可将其清零。</description>
              <bitOffset>10</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>BSE</name>
              <description>块大小错误。当块大小不是源端或目的端数据大小的整数倍时，此位由硬件置位。TED 将指示问题在源端还是目的端。软件向 DMA_IFCRy 寄存器中的 CTEIFx 位写 1 可将其清零。</description>
              <bitOffset>11</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C13CR</name>
          <displayName>MDMA_C13CR</displayName>
          <description>此寄存器用于控制相应通道。</description>
          <addressOffset>0x38C</addressOffset>
          <size>0x20</size>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>EN</name>
              <description>通道使能</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>TEIE</name>
              <description>传输错误中断使能。此位由软件置位与清零。</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>CTCIE</name>
              <description>通道传输完成中断使能。此位由软件置位与清零。</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>BRTIE</name>
              <description>块重复传输中断使能。此位由软件置位与清零。</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>BTIE</name>
              <description>块传输中断使能。此位由软件置位与清零。</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>TCIE</name>
              <description>缓冲区传输完成中断使能。此位由软件置位与清零。</description>
              <bitOffset>5</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>PL</name>
              <description>优先级。这些位由软件置位与清零。这些位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>6</bitOffset>
              <bitWidth>2</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>BEX</name>
              <description>字节端序交换</description>
              <bitOffset>12</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>HEX</name>
              <description>半字端序交换</description>
              <bitOffset>13</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>WEX</name>
              <description>字端序交换</description>
              <bitOffset>14</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>SWRQ</name>
              <description>软件请求。向此位写 1 将使 MDMA_ISRy 寄存器中的 CRQAx 置位，从而激活通道 x 的请求。注意：可通过整个 CxCR 寄存器或地址偏移为 0x4E + 0x40*通道号的 8 位/16 位寄存器来激活 SWRQ。在软件请求的情况下，不会产生应答信号（无硬件信号，也不进行 CxMAR 写访问）。</description>
              <bitOffset>16</bitOffset>
              <bitWidth>1</bitWidth>
              <access>write-only</access>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C13TCR</name>
          <displayName>MDMA_C13TCR</displayName>
          <description>此寄存器用于配置相应通道。</description>
          <addressOffset>0x390</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>SINC</name>
              <description>源地址增量模式。这些位由软件置位与清零。这些位受保护，仅当 EN 为 0 时才可写入。注意：当源端为 AHB 总线时（SBUS=1），禁止 SINC = 00。在链接列表模式下，在一个块（单次或重复块传输模式中的最后一个块）结束时，此寄存器将从存储器（地址由当前 LAR[31:0] + 0x00 给出）重新加载。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>DINC</name>
              <description>目的地址增量模式。这些位由软件置位与清零。这些位受保护，仅当 EN 为 0 时才可写入。注意：当目的端为 AHB 总线时（DBUS=1），禁止 DINC = 00。</description>
              <bitOffset>2</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>SSIZE</name>
              <description>源数据大小。这些位由软件置位与清零。这些位受保护，仅当 EN 为 0 时才可写入。注意：若为 TCM 访问/AHB 端口编程了 11 值，将发生传输错误（TEIF 位置位）。若 SINCOS &lt; SSIZE 且 SINC != 00，结果不可预测。注意：当源端为 TCM/AHB 总线时（SBUS=1），禁止 SSIZE = 11（双字）。</description>
              <bitOffset>4</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>DSIZE</name>
              <description>目的数据大小。这些位由软件置位与清零。这些位受保护，仅当 EN 为 0 时才可写入。注意：若为 TCM 访问/AHB 端口编程了 11 值，将发生传输错误（TEIF 位置位）。若 DINCOS &lt; DSIZE 且 DINC != 00，结果不可预测。注意：当目的端为 TCM/AHB 总线时（DBUS=1），禁止 DSIZE = 11（双字）。</description>
              <bitOffset>6</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>SINCOS</name>
              <description>源地址增量偏移大小</description>
              <bitOffset>8</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>DINCOS</name>
              <description>目的地址增量偏移</description>
              <bitOffset>10</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>SBURST</name>
              <description>源端突发传输配置</description>
              <bitOffset>12</bitOffset>
              <bitWidth>3</bitWidth>
            </field>
            <field>
              <name>DBURST</name>
              <description>目的端突发传输配置</description>
              <bitOffset>15</bitOffset>
              <bitWidth>3</bitWidth>
            </field>
            <field>
              <name>TLEN</name>
              <description>缓冲区传输长度</description>
              <bitOffset>18</bitOffset>
              <bitWidth>7</bitWidth>
            </field>
            <field>
              <name>PKE</name>
              <description>打包使能。此位由软件置位与清零。若源数据大小小于目的数据大小，将按 PAM 值进行填充。若源数据大小大于目的数据大小，将被截断。对齐方式根据 PAM[0] 值确定。此位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>25</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>PAM</name>
              <description>填充/对齐模式。这些位由软件置位与清零。情况 1：源数据大小小于目的数据大小——3 种选项有效。情况 2：源数据大小大于目的数据大小——多余部分被丢弃。当 PKE = 1 或 DSIZE=SSIZE 时，这些位被忽略。这些位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>26</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>TRGM</name>
              <description>触发模式。这些位由软件置位与清零。注意：若当前块的 TRGM 为 11，则通过链接列表机制在当前块结束时加载的所有值必须保持相同的 TRGM=11 值和相同的 SWRM 值，否则结果未定义。这些位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>28</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>SWRM</name>
              <description>软件请求模式。此位由软件置位与清零。若当前有硬件或软件请求处于活跃状态，此位的变更将延迟到当前传输完成之后。若 CxMAR 包含有效地址，CxMDR 的值也将写入 CxMAR 地址。此位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>30</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>BWM</name>
              <description>缓冲写模式。此位由软件置位与清零。此位受保护，仅当 EN 为 0 时才可写入。注意：所有 MDMA 目的端访问均为不可缓存访问。</description>
              <bitOffset>31</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C13BNDTR</name>
          <displayName>MDMA_C13BNDTR</displayName>
          <description>MDMA 通道 x 块数据传输数量寄存器</description>
          <addressOffset>0x394</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>BNDT</name>
              <description>待传输数据块数量</description>
              <bitOffset>0</bitOffset>
              <bitWidth>17</bitWidth>
            </field>
            <field>
              <name>BRSUM</name>
              <description>块重复源地址更新模式。这些位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>18</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>BRDUM</name>
              <description>块重复目的地址更新模式。这些位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>19</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>BRC</name>
              <description>块重复计数。此字段包含当前块的重复次数（0 到 4095）。通道使能后，此寄存器为只读，指示剩余块数（不含当前块）。每次完整块传输完成后此寄存器递减。最后一个块传输完成后，此寄存器可保持为零，或自动从存储器重新加载（在链接列表模式下——即链接地址有效时）。这些位受保护，仅当 EN 为 0 时才可写入。</description>
              <bitOffset>20</bitOffset>
              <bitWidth>12</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C13SAR</name>
          <displayName>MDMA_C13SAR</displayName>
          <description>MDMA 通道 x 源地址寄存器</description>
          <addressOffset>0x398</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>SAR</name>
              <description>源地址基址</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C13DAR</name>
          <displayName>MDMA_C13DAR</displayName>
          <description>MDMA 通道 x 目的地址寄存器</description>
          <addressOffset>0x39C</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>DAR</name>
              <description>目的地址基址</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MDMA_C13BRUR</name>
          <displayName>MDMA_C13BRUR</displayName>
          <description>MDMA 通道 x 块重复地址更新寄存器</description>
          <addressOffset>0x3A0</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>SUV</name>
              <description>源地址更新值</description>
              <bitOffset>0</bitOffset>
              <bitWidth>16</bitWidth>
