          <resetValue>0x00000000</resetValue>
          <resetMask>0xFFFFFFFF</resetMask>
          <fields>
            <field>
              <name>MA</name>
              <description>存储器地址。存放存储器的基地址，数据即从该地址读出或写入。当 MSIZE[1:0] = 01（16 位）时，MA[31:0] 的位 0 被忽略，访问自动对齐到半字地址。当 MSIZE = 10（32 位）时，MA[31:0] 的位 1 和位 0 被忽略，访问自动对齐到字地址。在存储器到存储器模式下，若 DIR = 1 则此寄存器标识存储器源地址，若 DIR = 0 则标识存储器目标地址。在外设到外设模式下，若 DIR = 1 则此寄存器标识外设源地址，若 DIR = 0 则标识外设目标地址。注意：此寄存器由软件置位和清零。通道使能（EN = 1）时不得写入此寄存器。通道使能（EN = 1）时此寄存器并非只读。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
              <access>read-write</access>
            </field>
          </fields>
        </register>
        <register>
          <name>BDMA_CCR1</name>
          <displayName>BDMA_CCR1</displayName>
          <description>BDMA 通道 1 配置寄存器</description>
          <addressOffset>0x1c</addressOffset>
          <size>0x20</size>
          <resetValue>0x00000000</resetValue>
          <resetMask>0xFFFFFFFF</resetMask>
          <fields>
            <field>
              <name>EN</name>
              <description>通道使能。当通道发生传输错误时，硬件会清零此位。在 BDMA_ISR 寄存器的 TEIFx 位被清零（通过置位 BDMA_IFCR 寄存器的 CTEIFx 位）之前，软件无法再次置位此位（即重新激活通道 x）。注意：此位由软件置位和清零。</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>B_0x0</name>
                  <description>禁止</description>
                  <value>0x0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>B_0x1</name>
                  <description>使能</description>
                  <value>0x1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>TCIE</name>
              <description>传输完成中断使能。注意：此位由软件置位和清零。通道使能（EN = 1）时不得写入此位。通道使能（EN = 1）时此位并非只读。</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
